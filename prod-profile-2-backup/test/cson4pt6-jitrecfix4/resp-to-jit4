The `emitBXexit` needs a complete rewrite. Here's the correct version:

```cpp
// jit_ppc.cpp - Complete replacement for emitBXexit
static void emitBXexit(Ctx& ctx, uint8_t /*unused*/, bool /*unused*/, uint32_t /*unused*/) {
    // Precondition: original Rm value stored in FRAME_SCR2 by caller
    
    ctx.E(ppc_lwz(TA, FRAME_SCR2, 1));     // TA = Rm (original value)
    
    // Compute new PC = Rm & ~1, store to FRAME_SCR1
    ctx.E(ppc_rlwinm(TB, TA, 0, 0, 30));   // TB = Rm & ~1
    ctx.E(ppc_stw(TB, FRAME_SCR1, 1));     // save new PC to SCR1
    
    // Extract T bit from Rm[0]  
    ctx.E(ppc_rlwinm(TC, TA, 27, 31, 31)); // TC = Rm[0] rotated to bit0
    // Actually: rlwinm rD,rS,SH,MB,ME
    // We want bit 0 of TA in bit 5 position of TC
    // rlwinm TC, TA, 5, 26, 26  means:
    //   rotate TA left 5, then mask keeping only bit 26 (MSB notation) = bit 5 (LSB)
    ctx.E(ppc_rlwinm(TC, TA, 5, 26, 26));  // TC = (Rm << 5) & (1<<5)
    
    // Clear T bit in CPSR (bit 5 LSB = bit 26 MSB)
    // rlwinm RCPSR,RCPSR,0,27,25 clears bit26 (MSB) keeping rest
    // MB=27,ME=25 wraps around: keeps bits 27..31 and 0..25 (MSB), clears bit 26
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 27, 25)); // CPSR &= ~(1<<5) [LSB bit5 = MSB bit26]
    
    // Set T bit from Rm[0]
    ctx.E(ppc_or(RCPSR, RCPSR, TC));        // CPSR |= (Rm[0] << 5)
    
    // Sync ARM regs r0-r14 to interpreter
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_stw(RA[i], FRAME_REGSYNC + i * 4, 1));
    
    ctx.E(ppc_mr(TA, RINTERP));
    ctx.E(ppc_addi(TB, 1, (int16_t)FRAME_REGSYNC));
    ctx.E(ppc_mr(TC, RCPSR));
    ctx.call((void*)JitHelp_syncTo);
    
    // Store exit info with new PC
    ctx.E(ppc_mr(TA, RCPUIDX));
    ctx.E(ppc_lwz(TB, FRAME_SCR1, 1));         // new PC (Rm & ~1)
    ctx.E(ppc_mr(TC, RCPSR));
    ctx.E(ppc_addi(TD, 0, (int16_t)EXIT_NORMAL));
    ctx.call((void*)JitHelp_storeExit);
    
    emitEpilogue(ctx);
}
```

## Fix 3: Critical — NULL Pointer in GBA Boot (Invalid reads from 0x0)

The GBA reads from 0x00000000 because `memory.read` is being called before memory maps are set up, OR the JIT is reading opcodes before the GBA ROM is mapped. The fix is in `compile()`:

```cpp
// jit_ppc.cpp - Replace compile() opcode fetch section
static JitBlock* compile(Interpreter* interp, Core* core,
                          uint32_t armPC, bool arm7, int cpuIdx) {
    if (!validPC(armPC, core->gbaMode)) return nullptr;
    
    bool thumb = interp->isThumb();
    size_t bkt = hashPC(armPC);
    JitBlock& slot = cache[bkt];
    if (slot.valid && slot.armPC == armPC && slot.thumb == thumb) return &slot;
    if (codePos + BLK_WDS >= JIT_WORDS) flushJitCache();

    Ctx ctx;
    ctx.base = codeBuf + codePos; ctx.cur = ctx.base;
    ctx.cap  = JIT_WORDS - codePos;
    ctx.thumb = thumb; ctx.arm7 = arm7; ctx.done = false;
    ctx.blockPC = armPC; ctx.cpuIdx = cpuIdx;
    ctx.interp = interp; ctx.core = core;

    emitPrologue(ctx);
    emitSyncFrom(ctx);

    uint32_t curPC = armPC;
    int n = 0;

    while (n < (int)BLK_ARMS && !ctx.done) {
        if (thumb) {
            // SAFETY: verify address before reading
            if (!validPC(curPC, core->gbaMode)) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
                break;
            }
            
            uint16_t op = core->memory.read<uint16_t>(arm7, curPC);
            
            // Check for BL/BLX (32-bit thumb instruction)
            if (((op >> 11) & 0x1F) == 0x1E) {
                if (!validPC(curPC + 2, core->gbaMode)) {
                    emitExit(ctx, curPC, EXIT_FALLBACK);
                    ctx.done = true;
                    break;
                }
                uint16_t op2 = core->memory.read<uint16_t>(arm7, curPC + 2);
                uint8_t bb = (op2 >> 11) & 0x1F;
                if (bb == 0x1F || bb == 0x1C) {
                    emitT_bl(ctx, op, op2, curPC);
                    curPC += 4; n += 2;
                    continue;
                }
            }
            
            bool ok = dispThumb(ctx, op, curPC);
            if (!ok) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
            } else {
                curPC += 2; n++;
                uint8_t h = (op >> 12) & 0xF;
                if (h == 0xD || h == 0xE || h == 0xF) ctx.done = true;
            }
        } else {
            // SAFETY: verify address before reading
            if (!validPC(curPC, core->gbaMode)) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
                break;
            }
            
            uint32_t op = core->memory.read<uint32_t>(arm7, curPC);
            
            // Detect NOP (mov r0, r0 = 0xE1A00000) loop detection
            bool ok = dispARM(ctx, op, curPC);
            if (!ok) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
            } else {
                curPC += 4; n++;
                uint32_t it = (op >> 25) & 7;
                if (it == 5) ctx.done = true;
                if ((op & 0x0FFFFFF0) == 0x012FFF10) ctx.done = true;
                if ((op & 0x0E000000) == 0x0A000000) ctx.done = true; // B/BL
            }
        }
    }

    if (!ctx.done) {
        emitExit(ctx, curPC, EXIT_NORMAL);
    }

    size_t wds = ctx.sz();
    if (wds == 0) return nullptr;  // SAFETY: empty block
    
    dcbst(ctx.base, wds);
    slot = {armPC, ctx.base, (uint32_t)wds, thumb, true};
    codePos += wds;
    return &slot;
}
```

