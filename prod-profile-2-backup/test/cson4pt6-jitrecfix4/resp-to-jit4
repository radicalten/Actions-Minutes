    bool      valid;
};

static const size_t CSIZ = 1u << 13;   // 8192 slots
static JitBlock cache[CSIZ];

static size_t hashPC(uint32_t pc) { return (pc >> 1) & (CSIZ - 1); }

void flushJitCache() {
    codePos = 0;
    for (size_t i = 0; i < CSIZ; i++) cache[i].valid = false;
}

static void dcbst(uint32_t* p, size_t n) {
    DCFlushRange(p, n * 4);
    ICInvalidateRange(p, n * 4);
}

// ============================================================
// Emit context
// ============================================================
struct Ctx {
    uint32_t* base;
    uint32_t* cur;
    size_t    cap;
    bool      thumb;
    bool      arm7;
    bool      done;
    uint32_t  blockPC;
    int       cpuIdx;
    Interpreter* interp;
    Core*        core;

    void E(uint32_t w) {
        if ((size_t)(cur - base) < cap) *cur++ = w;
    }

    size_t sz() const { return (size_t)(cur - base); }

    // Load a 32-bit constant into rt
    void li(uint8_t rt, uint32_t v) {
        uint32_t t[2];
        int n = emit_li32(t, rt, v);
        for (int i = 0; i < n; i++) E(t[i]);
    }

    // Emit an indirect call through RCALL (r11)
    void call(void* fn) {
        uint32_t a = (uint32_t)(uintptr_t)fn;
        E(ppc_addis(RCALL, 0, (int16_t)(a >> 16)));
        E(ppc_ori(RCALL, RCALL, (uint16_t)(a & 0xFFFF)));
        E(ppc_mtctr(RCALL));
        E(ppc_bctr(true));   // bctrl — sets LR to next instruction
    }

    // Load Core* from frame into d
    void ldCore(uint8_t d = TA) { E(ppc_lwz(d, FRAME_CORE, 1)); }
};

// ============================================================
// C helpers (called from JIT-generated code)
// ============================================================
extern "C" {

// Pull ARM r0-r14 and CPSR from the interpreter into JIT registers
void JitHelp_syncFrom(Interpreter* interp, uint32_t* regs, uint32_t* outCPSR) {
    uint32_t** p = interp->getRegisters();
    for (int i = 0; i < 15; i++) regs[i] = *p[i];
    *outCPSR = interp->getCpsrRef();
}

// Push ARM r0-r14 and CPSR back into the interpreter (does NOT touch PC)
void JitHelp_syncTo(Interpreter* interp, uint32_t* regs, uint32_t cpsr) {
    uint32_t** p = interp->getRegisters();
    for (int i = 0; i < 15; i++) *p[i] = regs[i];
    interp->getCpsrRef() = cpsr;
}

// Record exit information before returning from a JIT block
void JitHelp_storeExit(int cpuIdx, uint32_t nextPC, uint32_t cpsr, int reason) {
    g_exitPC    [cpuIdx] = nextPC;
    g_exitCPSR  [cpuIdx] = cpsr;
    g_exitReason[cpuIdx] = reason;
}

// Memory accessors
uint32_t JitHelp_r32(Core* c, int a, uint32_t ad) { return c->memory.read<uint32_t>((bool)a, ad); }
uint16_t JitHelp_r16(Core* c, int a, uint32_t ad) { return c->memory.read<uint16_t>((bool)a, ad); }
uint8_t  JitHelp_r8 (Core* c, int a, uint32_t ad) { return c->memory.read<uint8_t> ((bool)a, ad); }
void JitHelp_w32(Core* c, int a, uint32_t ad, uint32_t v) { c->memory.write<uint32_t>((bool)a, ad, v); }
void JitHelp_w16(Core* c, int a, uint32_t ad, uint16_t v) { c->memory.write<uint16_t>((bool)a, ad, v); }
void JitHelp_w8 (Core* c, int a, uint32_t ad, uint8_t  v) { c->memory.write<uint8_t> ((bool)a, ad, v); }

// Advance the scheduler by 64 cycles and fire any pending events
void JitHelp_tick(Core* core) {
    core->globalCycles += 64;
    while (!core->events.empty() &&
           core->globalCycles >= core->events.front().cycles) {
        SchedEvent e = core->events.front();
        core->events.erase(core->events.begin());
        core->tasks[e.task]();
    }
}

} // extern "C"

// ============================================================
// Block prologue / epilogue
// ============================================================
static void emitPrologue(Ctx& ctx) {
    ctx.E(ppc_mflr(0));
    ctx.E(ppc_stwu(1, -(int16_t)FRAME_SIZE, 1));
    ctx.E(ppc_stw(0, FRAME_LR, 1));
    for (int r = 14; r <= 31; r++)
        ctx.E(ppc_stw(r, FRAME_R14 + (r-14)*4, 1));
    // Store Interpreter* into RINTERP, Core* into frame
    ctx.li(RINTERP, (uint32_t)(uintptr_t)ctx.interp);
    ctx.li(TA, (uint32_t)(uintptr_t)ctx.core);
    ctx.E(ppc_stw(TA, FRAME_CORE, 1));
    ctx.E(ppc_addi(RCPUIDX, 0, (int16_t)ctx.cpuIdx));
}

static void emitEpilogue(Ctx& ctx) {
    for (int r = 14; r <= 31; r++)
        ctx.E(ppc_lwz(r, FRAME_R14 + (r-14)*4, 1));
    ctx.E(ppc_lwz(0, FRAME_LR, 1));
    ctx.E(ppc_mtlr(0));
    ctx.E(ppc_addi(1, 1, (int16_t)FRAME_SIZE));
    ctx.E(ppc_blr());
}

// ============================================================
// Sync ARM state from interpreter at block entry
// ============================================================
static void emitSyncFrom(Ctx& ctx) {
    ctx.E(ppc_mr(TA, RINTERP));
    ctx.E(ppc_addi(TB, 1, (int16_t)FRAME_REGSYNC));
    ctx.E(ppc_addi(TC, 1, (int16_t)FRAME_SCR0));
    ctx.call((void*)JitHelp_syncFrom);
    // Load ARM r0-r14 into PPC r14-r28
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_lwz(RA[i], FRAME_REGSYNC + i*4, 1));
    // Load CPSR into RCPSR
    ctx.E(ppc_lwz(RCPSR, FRAME_SCR0, 1));
}

// ============================================================
// Block exit: sync state out, store exit info, return
//
// nextPC : the ARM address the guest should execute next
// reason : EXIT_NORMAL or EXIT_FALLBACK
// ============================================================
static void emitExit(Ctx& ctx, uint32_t nextPC, int reason) {
    // 1. Spill ARM r0-r14 to the sync area
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_stw(RA[i], FRAME_REGSYNC + i*4, 1));

    // 2. JitHelp_syncTo(interp, &regsync, cpsr)
    ctx.E(ppc_mr(TA, RINTERP));
    ctx.E(ppc_addi(TB, 1, (int16_t)FRAME_REGSYNC));
    ctx.E(ppc_mr(TC, RCPSR));
    ctx.call((void*)JitHelp_syncTo);

    // 3. JitHelp_storeExit(cpuIdx, nextPC, cpsr, reason)
    ctx.E(ppc_mr(TA, RCPUIDX));
    ctx.li(TB, nextPC);
    ctx.E(ppc_mr(TC, RCPSR));
    ctx.E(ppc_addi(TD, 0, (int16_t)reason));
    ctx.call((void*)JitHelp_storeExit);

    // 4. Return
    emitEpilogue(ctx);
}

// ============================================================
// Condition evaluation (uses CR7)
//
// ARM CPSR layout (LSB numbering):
//   bit 31 = N, bit 30 = Z, bit 29 = C, bit 28 = V
//
// PPC mtcrf 0x01, RCPSR copies GPR bits 31..28 into CR7:
//   CR7[LT] = GPR bit 31 = N
//   CR7[GT] = GPR bit 30 = Z
//   CR7[EQ] = GPR bit 29 = C
//   CR7[SO] = GPR bit 28 = V
//
// In the 'bc' BI field, CR7 bits are numbered 28..31 (MSB from CR):
//   BI=28 -> CR7[LT] = N
//   BI=29 -> CR7[GT] = Z
//   BI=30 -> CR7[EQ] = C
//   BI=31 -> CR7[SO] = V
// ============================================================
static void emitLoadCR7(Ctx& ctx) {
    ctx.E(ppc_mtcrf(0x01, RCPSR));
}

struct CB { uint8_t bo, bi; bool ok; };

// Return the PPC branch condition for an ARM condition code.
// Only the four single-flag conditions (EQ/NE/CS/CC/MI/PL/VS/VC) and AL
// are handled here; all multi-flag conditions fall back to the interpreter.
static CB condPpc(uint8_t c) {
    // BO=12: branch if CRbi SET
    // BO=4:  branch if CRbi CLEAR
    switch (c) {
        case 0:  return {12, 29, true};  // EQ: Z set   (CR7[GT])
        case 1:  return { 4, 29, true};  // NE: Z clear
        case 2:  return {12, 30, true};  // CS: C set   (CR7[EQ])
        case 3:  return { 4, 30, true};  // CC: C clear
        case 4:  return {12, 28, true};  // MI: N set   (CR7[LT])
        case 5:  return { 4, 28, true};  // PL: N clear
        case 6:  return {12, 31, true};  // VS: V set   (CR7[SO])
        case 7:  return { 4, 31, true};  // VC: V clear
        // HI/LS/GE/LT/GT/LE require multi-flag checks; fall back
        case 8:  return { 0,  0, false}; // HI
        case 9:  return { 0,  0, false}; // LS
        case 10: return { 0,  0, false}; // GE
        case 11: return { 0,  0, false}; // LT
        case 12: return { 0,  0, false}; // GT
        case 13: return { 0,  0, false}; // LE
        case 14: return {20,  0, true};  // AL (always)
        default: return { 0,  0, false};
    }
}

// Emit a conditional skip over the next instructions.
// Returns the index of the bc instruction to be back-patched, or SIZE_MAX
// if no branch was emitted (AL condition or unsupported).
static size_t emitCondSkip(Ctx& ctx, uint8_t cond) {
    if (cond == 14) return SIZE_MAX;   // AL — always execute
    emitLoadCR7(ctx);
    CB cb = condPpc(cond);
    if (!cb.ok) return SIZE_MAX;       // unsupported condition
    // Emit branch that skips the conditional body when condition is NOT met
    uint8_t inv = (cb.bo == 12) ? 4 : (cb.bo == 4 ? 12 : 20);
    size_t idx = ctx.sz();
    // Use +4 as placeholder; patchSkip overwrites the offset field
    ctx.E(ppc_bc(inv, cb.bi, 4));
    return idx;
}

// Back-patch the bc at index idx to skip to the current emit position
static void patchSkip(Ctx& ctx, size_t idx) {
    if (idx == SIZE_MAX) return;
    int32_t off = (int32_t)((ctx.sz() - idx) * 4);
    ctx.base[idx] = (ctx.base[idx] & 0xFFFF0003u) | (uint32_t)(off & 0xFFFC);
}

// ============================================================
// Flag update helpers
// ============================================================

// Update N and Z in RCPSR from register r
static void setNZ(Ctx& ctx, uint8_t r) {
    // Clear N (bit 31) and Z (bit 30) from CPSR
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 2, 31));   // keep bits 29..0, clear 31..30
    // Copy new N from r[31]
    ctx.E(ppc_rlwimi(RCPSR, r, 0, 0, 0));         // CPSR[31] = r[31]
    // Compute Z: set CPSR[30] if r == 0
    ctx.E(ppc_cmpi(6, r, 0));                     // compare r with 0 using CR6
    ctx.E(ppc_mfcr(TA));
    // CR6[EQ] is at bit position 26 (MSB) = bit 5 (LSB) of CR.
    // We want it at CPSR bit 30 (LSB).  Shift left by 25 gives bit30.
    ctx.E(ppc_rlwinm(TA, TA, 25, 1, 1));          // TA = CR6[EQ] at bit30 (LSB)
    ctx.E(ppc_or(RCPSR, RCPSR, TA));
}

// Update C in RCPSR from XER[CA] (valid after addc/subfc/adde/subfe)
// XER[CA] lives at bit 29 (LSB) of XER, which is the same position as CPSR[C].
static void setC_xer(Ctx& ctx) {
    ctx.E(ppc_mfxer(TA));
    // XER[CA] is at bit 29 (LSB).  Mask it out, then splice into RCPSR.
    ctx.E(ppc_rlwinm(TA, TA, 0, 2, 2));            // keep only XER[CA] at bit29(LSB)
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 3, 1));      // clear CPSR[C] (bit29 LSB = bit2 MSB), wrap mask
    ctx.E(ppc_or(RCPSR, RCPSR, TA));
}

// Update V in RCPSR for addition (overflow if signs of a and b match but differ from result)
static void setV_add(Ctx& ctx, uint8_t res, uint8_t a, uint8_t b) {
    ctx.E(ppc_xor(TA, res, a));   // TA = res ^ a
    ctx.E(ppc_xor(TB, res, b));   // TB = res ^ b
    ctx.E(ppc_and(TA, TA, TB));   // TA = (res^a) & (res^b)  — bit31 set iff overflow
    // Move bit31 of TA to bit28 (LSB) = CPSR[V]
    ctx.E(ppc_rlwinm(TA, TA, 4, 3, 3));            // TA = bit31->bit28, masked
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 4, 2));      // clear CPSR[V] (bit28 LSB = bit3 MSB), wrap mask
    ctx.E(ppc_or(RCPSR, RCPSR, TA));
}

// Update V in RCPSR for subtraction (res = a - b)
static void setV_sub(Ctx& ctx, uint8_t res, uint8_t a, uint8_t b) {
    ctx.E(ppc_xor(TA, a, b));     // TA = a ^ b
    ctx.E(ppc_xor(TB, a, res));   // TB = a ^ res
    ctx.E(ppc_and(TA, TA, TB));   // TA = (a^b) & (a^res) — bit31 set iff overflow
    ctx.E(ppc_rlwinm(TA, TA, 4, 3, 3));
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 4, 2));
    ctx.E(ppc_or(RCPSR, RCPSR, TA));
}

// Update C in RCPSR from bit0 of register cr (used after shifter operations)
static void setC_bit0(Ctx& ctx, uint8_t cr) {
    // Bit 0 of cr -> bit 29 (LSB) of RCPSR
    ctx.E(ppc_rlwinm(TA, cr, 29, 2, 2));           // TA = cr[0] at bit29(LSB)
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 3, 1));      // clear CPSR[C]
    ctx.E(ppc_or(RCPSR, RCPSR, TA));
}

// ============================================================
// Barrel shifter
// Results go into dst.  When sc==true the carry-out goes into TC[0].
// ============================================================
static void sLslI(Ctx& ctx, uint8_t d, uint8_t s, int i, bool sc) {
    if (i == 0) {
        if (d != s) ctx.E(ppc_mr(d, s));
        if (sc) ctx.E(ppc_rlwinm(TC, RCPSR, 3, 31, 31));  // carry unchanged: TC = CPSR[C]
    } else if (i < 32) {
        if (sc) ctx.E(ppc_rlwinm(TC, s, (uint8_t)i, 31, 31));        // last bit shifted out
        ctx.E(ppc_rlwinm(d, s, (uint8_t)i, 0, (uint8_t)(31-i)));
    } else if (i == 32) {
        if (sc) ctx.E(ppc_rlwinm(TC, s, 0, 31, 31));      // bit0 of s
        ctx.E(ppc_addi(d, 0, 0));
    } else {
        if (sc) ctx.E(ppc_addi(TC, 0, 0));
        ctx.E(ppc_addi(d, 0, 0));
    }
}

static void sLsrI(Ctx& ctx, uint8_t d, uint8_t s, int i, bool sc) {
    if (i == 0 || i == 32) {
        if (sc) ctx.E(ppc_rlwinm(TC, s, 1, 31, 31));      // MSB of s
        ctx.E(ppc_addi(d, 0, 0));
    } else if (i < 32) {
        if (sc) ctx.E(ppc_rlwinm(TC, s, (uint8_t)(33-i), 31, 31));
        ctx.E(ppc_rlwinm(d, s, (uint8_t)(32-i), (uint8_t)i, 31));
    } else {
        if (sc) ctx.E(ppc_addi(TC, 0, 0));
        ctx.E(ppc_addi(d, 0, 0));
    }
}

static void sAsrI(Ctx& ctx, uint8_t d, uint8_t s, int i, bool sc) {
    if (i <= 0 || i >= 32) {
        if (sc) ctx.E(ppc_rlwinm(TC, s, 1, 31, 31));      // MSB of s
        ctx.E(ppc_srawi(d, s, 31));
    } else {
        if (sc) ctx.E(ppc_rlwinm(TC, s, (uint8_t)(33-i), 31, 31));
        ctx.E(ppc_srawi(d, s, (uint8_t)i));
    }
}

static void sRorI(Ctx& ctx, uint8_t d, uint8_t s, int i, bool sc) {
    if (i == 0) {
        // RRX: result = (CPSR[C] << 31) | (s >> 1)
        ctx.E(ppc_rlwinm(TA, RCPSR, 3, 31, 31));           // TA = CPSR[C] at bit0
        if (sc) ctx.E(ppc_rlwinm(TC, s, 0, 31, 31));       // TC = s[0] (carry out)
        ctx.E(ppc_rlwinm(d, s, 31, 1, 31));                // d = s >> 1
        ctx.E(ppc_rlwimi(d, TA, 31, 0, 0));               // d[31] = old CPSR[C]
    } else {
        i &= 31; if (!i) i = 32;
        if (i < 32) {
            if (sc) ctx.E(ppc_rlwinm(TC, s, (uint8_t)(33-i), 31, 31));
            ctx.E(ppc_rlwinm(d, s, (uint8_t)(32-i), 0, 31));
        } else {
            if (d != s) ctx.E(ppc_mr(d, s));
            if (sc) ctx.E(ppc_rlwinm(TC, s, 1, 31, 31));
        }
    }
}

// Emit the ARM barrel shifter for a data-processing operand.
// Writes result into dst.  If sc is true, also sets TC[0] = carry-out.
// Returns true iff carry was computed into TC.
static bool emitShifter(Ctx& ctx, uint32_t op, uint8_t dst, bool sc) {
    bool isImm = (op >> 25) & 1;
    if (isImm) {
        uint32_t v = op & 0xFF, rot = ((op >> 8) & 0xF) * 2;
        if (rot) v = (v >> rot) | (v << (32 - rot));
        ctx.li(dst, v);
        if (sc && rot) {
            // Carry = bit31 of the rotated immediate
            ctx.E(ppc_rlwinm(TC, dst, 1, 31, 31));
            return true;
        }
        return false;
    }

    uint8_t rm = op & 0xF, pRm = RA[rm], st = (op >> 5) & 3;
    bool isReg = (op >> 4) & 1;

    if (!isReg) {
        int sa = (op >> 7) & 0x1F;
        switch (st) {
            case 0: sLslI(ctx, dst, pRm, sa,       sc); break;
            case 1: sLsrI(ctx, dst, pRm, sa?sa:32, sc); break;
            case 2: sAsrI(ctx, dst, pRm, sa?sa:32, sc); break;
            case 3: sRorI(ctx, dst, pRm, sa,       sc); break;
        }
        return sc;
    } else {
        // Register-controlled shift — carry output not implemented here
        uint8_t rs = (op >> 8) & 0xF, pRs = RA[rs];
        ctx.E(ppc_rlwinm(TD, pRs, 0, 24, 31));    // TD = Rs & 0xFF
        ctx.E(ppc_mr(TA, pRm));
        switch (st) {
            case 0: ctx.E(ppc_slw(dst, TA, TD));  break;
            case 1: ctx.E(ppc_srw(dst, TA, TD));  break;
            case 2: ctx.E(ppc_sraw(dst, TA, TD)); break;
            case 3:
                ctx.E(ppc_subfic(TB, TD, 32));
                ctx.E(ppc_rlwnm(dst, TA, TB, 0, 31));
                break;
        }
        return false;
    }
}

// ============================================================
// Data-processing instructions
// ============================================================
enum DP { AND=0, EOR, SUB, RSB, ADD, ADC, SBC, RSC,
          TST,   TEQ, CMP, CMN, ORR, MOV, BIC, MVN };

static bool emitDP(Ctx& ctx, uint32_t op, uint32_t curPC) {
    uint8_t cond = (op >> 28) & 0xF;
    uint8_t dop  = (op >> 21) & 0xF;
    bool    s    = (op >> 20) & 1;
    uint8_t rn   = (op >> 16) & 0xF;
    uint8_t rd   = (op >> 12) & 0xF;
    if (rd == 15) return false;      // PC as destination: fall back

    uint8_t pRd = RA[rd];

    // If Rn == PC, compute the pipeline-adjusted value and save it
    bool rnIsPC = (rn == 15);
    uint8_t srcRn;
    if (rnIsPC) {
        uint32_t pcVal = curPC + (ctx.thumb ? 4u : 8u);
        ctx.li(TD, pcVal);
        ctx.E(ppc_stw(TD, FRAME_SCR3, 1));
        srcRn = TD;
    } else {
        srcRn = RA[rn];
    }

    size_t si = emitCondSkip(ctx, cond);
    if (si == SIZE_MAX && cond != 14) return false;   // unsupported condition

    bool needCin  = (dop == ADC || dop == SBC || dop == RSC);
    bool logCarry = s && (dop == AND || dop == EOR || dop == TST || dop == TEQ ||
                          dop == ORR || dop == MOV || dop == BIC || dop == MVN);

    // Load carry-in into XER before shifting (shifter may clobber TA)
    if (needCin) {
        ctx.E(ppc_rlwinm(TA, RCPSR, 0, 2, 2));    // isolate CPSR[C] at bit29(LSB)
        ctx.E(ppc_mtxer(TA));
    }

    // Emit the barrel shifter; result lands in TA
    bool carrySet = emitShifter(ctx, op, TA, logCarry);

    // Reload PC-derived Rn if the shifter clobbered TD
    if (rnIsPC) {
        ctx.E(ppc_lwz(TD, FRAME_SCR3, 1));
        srcRn = TD;
    }

    bool needV = s && (dop == ADD || dop == SUB || dop == RSB || dop == CMN ||
                       dop == CMP || dop == ADC || dop == SBC || dop == RSC);
    if (needV) {
        // Save operands for overflow detection after the ALU op
        ctx.E(ppc_stw(TA, FRAME_SCR0, 1));        // op2
        ctx.E(ppc_stw(srcRn, FRAME_SCR1, 1));     // Rn
    }

    bool    isTest = (dop == TST || dop == TEQ || dop == CMP || dop == CMN);
    uint8_t res    = isTest ? TC : pRd;

    switch ((DP)dop) {
        case AND: case TST: ctx.E(ppc_and  (res, srcRn, TA)); break;
        case EOR: case TEQ: ctx.E(ppc_xor  (res, srcRn, TA)); break;
        case SUB: case CMP: ctx.E(ppc_subfc(res, TA, srcRn)); break;   // res = Rn - op2
        case RSB:           ctx.E(ppc_subfc(res, srcRn, TA)); break;   // res = op2 - Rn
        case ADD: case CMN: ctx.E(ppc_addc (res, srcRn, TA)); break;
        case ADC:           ctx.E(ppc_adde (res, srcRn, TA)); break;
        case SBC:           ctx.E(ppc_subfe(res, TA, srcRn)); break;
        case RSC:           ctx.E(ppc_subfe(res, srcRn, TA)); break;
        case ORR:           ctx.E(ppc_or   (res, srcRn, TA)); break;
        case MOV:           if (res != TA) ctx.E(ppc_mr(res, TA)); break;
        case BIC:           ctx.E(ppc_andc (res, srcRn, TA)); break;
        case MVN:           ctx.E(ppc_nor  (res, TA, TA));    break;
    }

    if (s) {
        uint8_t opA, opB;
        if (needV) {
            ctx.E(ppc_lwz(TA, FRAME_SCR0, 1)); opB = TA;    // op2
            ctx.E(ppc_lwz(TD, FRAME_SCR1, 1)); opA = TD;    // Rn
        } else {
            opA = srcRn; opB = TA;
        }
        switch ((DP)dop) {
            case ADD: case CMN:
                setNZ(ctx, res); setC_xer(ctx); setV_add(ctx, res, opA, opB); break;
            case ADC:
                setNZ(ctx, res); setC_xer(ctx); setV_add(ctx, res, opA, opB); break;
            case SUB: case CMP:
                setNZ(ctx, res); setC_xer(ctx); setV_sub(ctx, res, opA, opB); break;
            case RSB:
                setNZ(ctx, res); setC_xer(ctx); setV_sub(ctx, res, opB, opA); break;
            case SBC:
                setNZ(ctx, res); setC_xer(ctx); setV_sub(ctx, res, opA, opB); break;
            case RSC:
                setNZ(ctx, res); setC_xer(ctx); setV_sub(ctx, res, opB, opA); break;
            default:
                setNZ(ctx, res);
                if (carrySet) setC_bit0(ctx, TC);
                break;
        }
    }

    patchSkip(ctx, si);
    return true;
}

// ============================================================
// BX / branch helper: update T-bit and exit
//
// Precondition: the original Rm value has been stored in FRAME_SCR2
//               by the caller BEFORE any registers were clobbered.
// ============================================================
static void emitBXexit(Ctx& ctx) {
    // Load original Rm
    ctx.E(ppc_lwz(TA, FRAME_SCR2, 1));     // TA = Rm (original)

    // New PC = Rm & ~1
    ctx.E(ppc_rlwinm(TB, TA, 0, 0, 30));   // TB = Rm & ~1
    ctx.E(ppc_stw(TB, FRAME_SCR1, 1));     // save new PC

    // Update CPSR T-bit (bit 5, LSB) from Rm[0]
    // Step 1: extract Rm[0] and position it at bit5 (LSB)
    //   rlwinm TC, TA, 5, 26, 26
    //   — rotate TA left 5; mask keeps only bit 26 (MSB) = bit 5 (LSB)
    ctx.E(ppc_rlwinm(TC, TA, 5, 26, 26));

    // Step 2: clear old T-bit in RCPSR
    //   bit 5 (LSB) = bit 26 (MSB, rlwinm notation)
    //   rlwinm RCPSR, RCPSR, 0, MB=27, ME=25 wraps:
    //     keeps bits 27..31 (MSB) and 0..25 (MSB), clearing bit 26 (MSB)
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 27, 25));

    // Step 3: set new T-bit
    ctx.E(ppc_or(RCPSR, RCPSR, TC));

    // Spill ARM r0-r14 and sync to interpreter
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_stw(RA[i], FRAME_REGSYNC + i*4, 1));
    ctx.E(ppc_mr(TA, RINTERP));
    ctx.E(ppc_addi(TB, 1, (int16_t)FRAME_REGSYNC));
    ctx.E(ppc_mr(TC, RCPSR));
    ctx.call((void*)JitHelp_syncTo);

    // Store exit: new PC (Rm & ~1), normal exit
    ctx.E(ppc_mr(TA, RCPUIDX));
    ctx.E(ppc_lwz(TB, FRAME_SCR1, 1));         // new PC
    ctx.E(ppc_mr(TC, RCPSR));
    ctx.E(ppc_addi(TD, 0, (int16_t)EXIT_NORMAL));
    ctx.call((void*)JitHelp_storeExit);

    emitEpilogue(ctx);
}

// ============================================================
// ARM BX instruction
// ============================================================
static bool emitBX(Ctx& ctx, uint32_t op, uint32_t curPC) {
    uint8_t cond = (op >> 28) & 0xF;
    uint8_t rm   = op & 0xF;
    if (rm == 15) return false;
    uint8_t pRm = RA[rm];

    // Save Rm immediately before any possible clobbering
    ctx.E(ppc_stw(pRm, FRAME_SCR2, 1));

    size_t si = emitCondSkip(ctx, cond);
    if (si == SIZE_MAX && cond != 14) return false;

    emitBXexit(ctx);

    if (si != SIZE_MAX) {
        // Condition not met: fall through to next instruction
        patchSkip(ctx, si);
        emitExit(ctx, curPC + 4, EXIT_NORMAL);
    }

    ctx.done = true;
    return true;
}

// ============================================================
// ARM branch (B / BL / BLX-immediate)
// ============================================================
static bool emitBranch(Ctx& ctx, uint32_t op, uint32_t curPC) {
    // BX Rm
    if ((op & 0x0FFFFFF0) == 0x012FFF10) return emitBX(ctx, op, curPC);
    // BLX Rm — mode switch; fall back to interpreter
    if ((op & 0x0FFFFFF0) == 0x012FFF30) return false;

    // B / BL
    if ((op & 0x0E000000) == 0x0A000000) {
        uint8_t  cond = (op >> 28) & 0xF;
        bool     lk   = (op >> 24) & 1;
        int32_t  off  = (int32_t)(op << 8) >> 6;  // sign-extend 24-bit offset * 4
        uint32_t tgt  = curPC + 8 + off;

        size_t si = emitCondSkip(ctx, cond);
        if (si == SIZE_MAX && cond != 14) return false;

        if (lk) ctx.li(RA[14], curPC + 4);        // LR = return address
        emitExit(ctx, tgt, EXIT_NORMAL);

        if (si != SIZE_MAX) {
            patchSkip(ctx, si);
            emitExit(ctx, curPC + 4, EXIT_NORMAL);
        }
        ctx.done = true;
        return true;
    }
    return false;
}

// ============================================================
// Load/Store (single register, no PC involvement)
// ============================================================
static bool emitLS(Ctx& ctx, uint32_t op, uint32_t curPC) {
    uint8_t cond = (op >> 28) & 0xF;
    bool ld   = (op >> 20) & 1;
    bool by   = (op >> 22) & 1;
    bool up   = (op >> 23) & 1;
    bool pre  = (op >> 24) & 1;
    bool wb   = (op >> 21) & 1;
    bool immO = !((op >> 25) & 1);
    uint8_t rn = (op >> 16) & 0xF;
    uint8_t rd = (op >> 12) & 0xF;
    if (rd == 15 || rn == 15) return false;
    uint8_t pRn = RA[rn], pRd = RA[rd];

    size_t si = emitCondSkip(ctx, cond);
    if (si == SIZE_MAX && cond != 14) return false;

    // Compute offset into TA
    if (immO) ctx.li(TA, op & 0xFFF);
    else      ctx.E(ppc_mr(TA, RA[op & 0xF]));

    // Compute effective address into TB
    if (pre) {
        if (up) ctx.E(ppc_add (TB, pRn, TA));
        else    ctx.E(ppc_subf(TB, TA, pRn));
    } else {
        ctx.E(ppc_mr(TB, pRn));
    }

    // Spill offset and address
    ctx.E(ppc_stw(TA, FRAME_SCR0, 1));   // offset
    ctx.E(ppc_stw(TB, FRAME_SCR1, 1));   // address

    // Set up call arguments
    ctx.ldCore(TA);
    ctx.E(ppc_addi(TB, 0, ctx.arm7 ? 1 : 0));
    ctx.E(ppc_lwz(TC, FRAME_SCR1, 1));
    if (!ld) ctx.E(ppc_mr(TD, pRd));     // store value

    void* fn = ld ? (by ? (void*)JitHelp_r8 : (void*)JitHelp_r32)
                  : (by ? (void*)JitHelp_w8 : (void*)JitHelp_w32);
    ctx.call(fn);

    if (ld) ctx.E(ppc_mr(pRd, TA));

    // Writeback
    ctx.E(ppc_lwz(TA, FRAME_SCR0, 1));
    if (!pre) {
        if (up) ctx.E(ppc_add (pRn, pRn, TA));
        else    ctx.E(ppc_subf(pRn, TA, pRn));
    } else if (wb && rn != rd) {
        ctx.E(ppc_lwz(pRn, FRAME_SCR1, 1));
    }

    patchSkip(ctx, si);
    return true;
}

// ============================================================
// Multiply (32-bit result only; long multiply falls back)
// ============================================================
static bool emitMul(Ctx& ctx, uint32_t op) {
    bool    s   = (op >> 20) & 1;
    bool    acc = (op >> 21) & 1;
    bool    lng = (op >> 23) & 1;
    uint8_t rd  = (op >> 16) & 0xF;
    uint8_t rn  = (op >> 12) & 0xF;
    uint8_t rs  = (op >>  8) & 0xF;
    uint8_t rm  =  op        & 0xF;
    if (rd == 15 || rm == 15 || rs == 15) return false;
    if (lng) return false;    // UMULL/SMULL/UMLAL/SMLAL — fall back

    uint8_t pRd = RA[rd], pRn = RA[rn], pRs = RA[rs], pRm = RA[rm];
    if (acc) {
        ctx.E(ppc_mullw(TA, pRm, pRs));
        ctx.E(ppc_add(pRd, TA, pRn));
    } else {
        ctx.E(ppc_mullw(pRd, pRm, pRs));
    }
    if (s) setNZ(ctx, pRd);
    return true;
}

// ============================================================
// ARM instruction dispatcher
// ============================================================
static bool dispARM(Ctx& ctx, uint32_t op, uint32_t curPC) {
    uint8_t cond = (op >> 28) & 0xF;
    if (cond == 15) return false;   // unconditional encoding; fall back

    uint32_t it = (op >> 25) & 7;
    switch (it) {
        case 0: case 1:
            if ((op & 0x0FC000F0) == 0x00000090) return emitMul(ctx, op);
            if ((op & 0x0FFFFFF0) == 0x012FFF10 ||
                (op & 0x0FFFFFF0) == 0x012FFF30) return emitBranch(ctx, op, curPC);
            // MSR/MRS, SWP, half-word/dual-word loads, DSP: fall back
            if ((op & 0x0FB00FF0) == 0x01000000 ||
                (op & 0x0FB00000) == 0x03200000 ||
                (op & 0x0DB0F000) == 0x010F0000 ||
                (op & 0x0E000090) == 0x00000090) return false;
            return emitDP(ctx, op, curPC);
        case 2: case 3: return emitLS(ctx, op, curPC);
        case 4:         return false;   // block data transfer: fall back
        case 5:         return emitBranch(ctx, op, curPC);
        default:        return false;
    }
}

// ============================================================
// Thumb emitters
// ============================================================

// Format 1: shift by immediate (LSL/LSR/ASR)
static bool emitT_shifts(Ctx& ctx, uint16_t op) {
    uint8_t ty = (op >> 11) & 3;
    uint8_t rd =  op        & 7;
    uint8_t rs = (op >>  3) & 7;
    int     i  = (op >>  6) & 0x1F;
    uint8_t pRd = RA[rd], pRs = RA[rs];
    switch (ty) {
        case 0: sLslI(ctx, pRd, pRs, i,       true); break;
        case 1: sLsrI(ctx, pRd, pRs, i?i:32, true); break;
        case 2: sAsrI(ctx, pRd, pRs, i?i:32, true); break;
        default: return false;
    }
    setNZ(ctx, pRd);
    setC_bit0(ctx, TC);
    return true;
}

// Format 2: add/subtract register or 3-bit immediate
static bool emitT_addSub3(Ctx& ctx, uint16_t op) {
    uint8_t rd   =  op        & 7;
    uint8_t rs   = (op >>  3) & 7;
    bool    sub  = (op >>  9) & 1;
    bool    imm3 = (op >> 10) & 1;
    uint8_t pRd  = RA[rd], pRs = RA[rs];
    if (imm3) ctx.li(TA, (op >> 6) & 7);
    else      ctx.E(ppc_mr(TA, RA[(op >> 6) & 7]));
    ctx.E(ppc_mr(TB, pRs));
    if (sub) {
        ctx.E(ppc_subfc(pRd, TA, TB));
        setNZ(ctx, pRd); setC_xer(ctx); setV_sub(ctx, pRd, TB, TA);
    } else {
        ctx.E(ppc_addc(pRd, TB, TA));
        setNZ(ctx, pRd); setC_xer(ctx); setV_add(ctx, pRd, TB, TA);
    }
    return true;
}

// Format 3: move/compare/add/subtract 8-bit immediate
static bool emitT_imm8(Ctx& ctx, uint16_t op) {
    uint8_t ty  = (op >> 11) & 3;
    uint8_t rd  = (op >>  8) & 7;
    uint8_t pRd = RA[rd];
    uint8_t imm =  op        & 0xFF;
    switch (ty) {
        case 0:   // MOV
            ctx.li(pRd, imm);
            setNZ(ctx, pRd);
            return true;
        case 1: { // CMP
            ctx.li(TA, imm);
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_subfc(TC, TA, TB));
            setNZ(ctx, TC); setC_xer(ctx); setV_sub(ctx, TC, TB, TA);
            return true;
        }
        case 2: { // ADD
            ctx.li(TA, imm);
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_addc(pRd, TB, TA));
            setNZ(ctx, pRd); setC_xer(ctx); setV_add(ctx, pRd, TB, TA);
            return true;
        }
        case 3: { // SUB
            ctx.li(TA, imm);
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_subfc(pRd, TA, TB));
            setNZ(ctx, pRd); setC_xer(ctx); setV_sub(ctx, pRd, TB, TA);
            return true;
        }
    }
    return false;
}

// Format 4: ALU operations
static bool emitT_alu(Ctx& ctx, uint16_t op) {
    uint8_t rd  =  op        & 7;
    uint8_t rs  = (op >>  3) & 7;
    uint8_t o   = (op >>  6) & 0xF;
    uint8_t pRd = RA[rd], pRs = RA[rs];
    switch (o) {
        case 0:  ctx.E(ppc_and  (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 1:  ctx.E(ppc_xor  (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 2:  ctx.E(ppc_slw  (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 3:  ctx.E(ppc_srw  (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 4:  ctx.E(ppc_sraw (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 5: { // ADC
            ctx.E(ppc_rlwinm(TA, RCPSR, 0, 2, 2));
            ctx.E(ppc_mtxer(TA));
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_adde(pRd, TB, pRs));
            setNZ(ctx, pRd); setC_xer(ctx); setV_add(ctx, pRd, TB, pRs);
            break;
        }
        case 6: { // SBC
            ctx.E(ppc_rlwinm(TA, RCPSR, 0, 2, 2));
            ctx.E(ppc_mtxer(TA));
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_subfe(pRd, pRs, TB));
            setNZ(ctx, pRd); setC_xer(ctx); setV_sub(ctx, pRd, TB, pRs);
            break;
        }
        case 7: { // ROR
            ctx.E(ppc_subfic(TA, pRs, 32));
            ctx.E(ppc_rlwnm(pRd, pRd, TA, 0, 31));
            setNZ(ctx, pRd);
            break;
        }
        case 8: { // TST
            ctx.E(ppc_and(TA, pRd, pRs));
            setNZ(ctx, TA);
            break;
        }
        case 9: { // NEG (RSB #0)
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_addi(TA, 0, 0));
            ctx.E(ppc_subfc(pRd, TB, TA));
            setNZ(ctx, pRd); setC_xer(ctx); setV_sub(ctx, pRd, TA, TB);
            break;
        }
        case 10: { // CMP
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_subfc(TA, pRs, TB));
            setNZ(ctx, TA); setC_xer(ctx); setV_sub(ctx, TA, TB, pRs);
            break;
        }
        case 11: { // CMN
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_addc(TA, TB, pRs));
            setNZ(ctx, TA); setC_xer(ctx); setV_add(ctx, TA, TB, pRs);
            break;
        }
        case 12: ctx.E(ppc_or   (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 13: ctx.E(ppc_mullw(pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 14: ctx.E(ppc_andc (pRd, pRd, pRs)); setNZ(ctx, pRd); break;
        case 15: ctx.E(ppc_nor  (pRd, pRs, pRs)); setNZ(ctx, pRd); break;
        default: return false;
    }
    return true;
}

// Format 5: hi-register operations / BX
static bool emitT_hiReg(Ctx& ctx, uint16_t op, uint32_t curPC) {
    uint8_t o  = (op >>  8) & 3;
    uint8_t h1 = (op >>  7) & 1;
    uint8_t h2 = (op >>  6) & 1;
    uint8_t rs = ((op >> 3) & 7) | (h2 << 3);
    uint8_t rd = ( op       & 7) | (h1 << 3);
    if (rd == 15 || rs == 15) return false;
    uint8_t pRd = RA[rd], pRs = RA[rs];
    switch (o) {
        case 0: ctx.E(ppc_add(pRd, pRd, pRs)); break;
        case 1: {
            ctx.E(ppc_mr(TB, pRd));
            ctx.E(ppc_subfc(TA, pRs, TB));
            setNZ(ctx, TA); setC_xer(ctx); setV_sub(ctx, TA, TB, pRs);
            break;
        }
        case 2: ctx.E(ppc_mr(pRd, pRs)); break;
        case 3: { // BX Rs
            ctx.E(ppc_stw(pRs, FRAME_SCR2, 1));
            emitBXexit(ctx);
            ctx.done = true;
            break;
        }
    }
    return true;
}

// Format 6: PC-relative load
static bool emitT_ldrPc(Ctx& ctx, uint16_t op, uint32_t curPC) {
    uint8_t  rd   = (op >> 8) & 7;
    uint32_t addr = ((curPC + 4) & ~3u) + ((op & 0xFF) << 2);
    ctx.ldCore(TA);
    ctx.E(ppc_addi(TB, 0, ctx.arm7 ? 1 : 0));
    ctx.li(TC, addr);
    ctx.call((void*)JitHelp_r32);
    ctx.E(ppc_mr(RA[rd], TA));
    return true;
}

// Formats 7/8: load/store with register offset
static bool emitT_memReg(Ctx& ctx, uint16_t op) {
    uint8_t rd   =  op        & 7;
    uint8_t rb   = (op >>  3) & 7;
    uint8_t ro   = (op >>  6) & 7;
    uint8_t pRd  = RA[rd], pRb = RA[rb], pRo = RA[ro];
    uint8_t op97 = (op >>  9) & 7;

    void* fn  = nullptr;
    bool  ld  = true;
    switch (op97) {
        case 0: fn = (void*)JitHelp_w32; ld = false; break;
        case 1: fn = (void*)JitHelp_w8;  ld = false; break;
        case 2: fn = (void*)JitHelp_r16; break;
        case 3: fn = (void*)JitHelp_r8;  break;
        case 4: fn = (void*)JitHelp_r32; break;
        case 5: fn = (void*)JitHelp_r8;  break;
        case 6: fn = (void*)JitHelp_r16; break;
        case 7: fn = (void*)JitHelp_r16; break;
        default: return false;
    }

    ctx.E(ppc_add(TC, pRb, pRo));
    ctx.E(ppc_stw(TC, FRAME_SCR0, 1));
    ctx.ldCore(TA);
    ctx.E(ppc_addi(TB, 0, ctx.arm7 ? 1 : 0));
    ctx.E(ppc_lwz(TC, FRAME_SCR0, 1));
    if (!ld) ctx.E(ppc_mr(TD, pRd));
    ctx.call(fn);
    if (ld) {
        if      (op97 == 3) ctx.E(ppc_extsb(pRd, TA));
        else if (op97 == 7) ctx.E(ppc_extsh(pRd, TA));
        else                ctx.E(ppc_mr(pRd, TA));
    }
    return true;
}

// Formats 9/10: load/store with immediate offset
static bool emitT_memImm(Ctx& ctx, uint16_t op) {
    uint8_t rd   =  op        & 7;
    uint8_t rb   = (op >>  3) & 7;
    uint8_t pRd  = RA[rd], pRb = RA[rb];
    bool    ld   = (op >> 11) & 1;
    uint8_t h    = (op >> 12) & 0xF;
    bool    by   = (h == 7);
    bool    hw   = (h == 8);
    uint32_t off = ((op >> 6) & 0x1F) * (hw ? 2u : (by ? 1u : 4u));

    ctx.li(TC, off);
    ctx.E(ppc_add(TC, pRb, TC));
    ctx.E(ppc_stw(TC, FRAME_SCR0, 1));
    ctx.ldCore(TA);
    ctx.E(ppc_addi(TB, 0, ctx.arm7 ? 1 : 0));
    ctx.E(ppc_lwz(TC, FRAME_SCR0, 1));
    if (!ld) ctx.E(ppc_mr(TD, pRd));
    void* fn = ld ? (hw ? (void*)JitHelp_r16 : (by ? (void*)JitHelp_r8 : (void*)JitHelp_r32))
                  : (hw ? (void*)JitHelp_w16 : (by ? (void*)JitHelp_w8 : (void*)JitHelp_w32));
    ctx.call(fn);
    if (ld) ctx.E(ppc_mr(pRd, TA));
    return true;
}

// Formats 11/9 (SP-relative): load/store SP-relative or PC-relative
static bool emitT_spLoad(Ctx& ctx, uint16_t op, uint32_t curPC) {
    bool    ld   = (op >> 11) & 1;
    uint8_t rd   = (op >>  8) & 7;
    uint8_t pRd  = RA[rd];
    bool    sp   = ((op >> 12) & 0xF) == 0x9;
    uint32_t off = (op & 0xFF) << 2;

    if (sp) {
        ctx.li(TA, off);
        ctx.E(ppc_add(TC, RA[13], TA));
    } else {
        ctx.li(TC, ((curPC + 4) & ~3u) + off);
    }
    ctx.E(ppc_stw(TC, FRAME_SCR0, 1));
    ctx.ldCore(TA);
    ctx.E(ppc_addi(TB, 0, ctx.arm7 ? 1 : 0));
    ctx.E(ppc_lwz(TC, FRAME_SCR0, 1));
    if (!ld) ctx.E(ppc_mr(TD, pRd));
    ctx.call(ld ? (void*)JitHelp_r32 : (void*)JitHelp_w32);
    if (ld) ctx.E(ppc_mr(pRd, TA));
    return true;
}

// Formats 16/18: conditional and unconditional branches
static bool emitT_branch(Ctx& ctx, uint16_t op, uint32_t curPC) {
    uint8_t h = (op >> 12) & 0xF;

    if (h == 0xE) {
        // Unconditional branch
        int32_t off = (int32_t)(op << 21) >> 20;
        emitExit(ctx, (uint32_t)(curPC + 4 + off), EXIT_NORMAL);
        ctx.done = true;
        return true;
    }

    if (h == 0xD) {
        // Conditional branch
        uint8_t cond = (op >> 8) & 0xF;
        if (cond == 0xF) return false;   // SWI encoding

        int32_t  off  = (int8_t)(op & 0xFF); off <<= 1;
        uint32_t tgt  = curPC + 4 + off;
        uint32_t fall = curPC + 2;

        emitLoadCR7(ctx);
        CB cb = condPpc(cond);
        if (!cb.ok) return false;

        uint8_t inv = (cb.bo == 12) ? 4 : (cb.bo == 4 ? 12 : 20);
        size_t si = ctx.sz();
        ctx.E(ppc_bc(inv, cb.bi, 4));    // placeholder; patched below

        emitExit(ctx, tgt, EXIT_NORMAL);
        patchSkip(ctx, si);
        emitExit(ctx, fall, EXIT_NORMAL);
        ctx.done = true;
        return true;
    }
    return false;
}

// Format 19: BL / BLX (32-bit Thumb instruction pair)
static bool emitT_bl(Ctx& ctx, uint16_t op1, uint16_t op2, uint32_t curPC) {
    int32_t  hi  = (int32_t)((op1 & 0x7FF) << 21) >> 9;
    int32_t  lo  = (op2 & 0x7FF) << 1;
    uint32_t tgt = curPC + 4 + hi + lo;
    bool     blx = ((op2 >> 11) & 0x1F) == 0x1C;

    ctx.li(RA[14], (curPC + 4) | 1u);   // LR = return address with T-bit set

    if (blx) {
        // BLX: switch to ARM mode
        tgt &= ~3u;
        // Clear T-bit (bit 5 LSB = bit 26 MSB) in RCPSR
        ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 27, 25));
    }

    emitExit(ctx, tgt & ~1u, EXIT_NORMAL);
    ctx.done = true;
    return true;
}

// ============================================================
// Thumb instruction dispatcher
// ============================================================
static bool dispThumb(Ctx& ctx, uint16_t op, uint32_t curPC) {
    uint8_t h = (op >> 12) & 0xF;
    switch (h) {
        case 0x0: {
            uint8_t b = (op >> 11) & 3;
            if (b < 3) return emitT_shifts(ctx, op);
            return emitT_addSub3(ctx, op);
        }
        case 0x1: return emitT_imm8(ctx, op);
        case 0x2: {
            uint8_t b = (op >> 10) & 3;
            if (b == 0) return emitT_alu(ctx, op);
            if (b == 1) return emitT_hiReg(ctx, op, curPC);
            return emitT_ldrPc(ctx, op, curPC);
        }
        case 0x3: return emitT_memReg(ctx, op);
        case 0x4: return emitT_memReg(ctx, op);
        case 0x5: return emitT_memReg(ctx, op);
        case 0x6: return emitT_memImm(ctx, op);
        case 0x7: return emitT_memImm(ctx, op);
        case 0x8: return emitT_memImm(ctx, op);
        case 0x9: return emitT_spLoad(ctx, op, curPC);
        case 0xD: return emitT_branch(ctx, op, curPC);
        case 0xE: return emitT_branch(ctx, op, curPC);
        // 0xA (ADD PC/SP), 0xB (misc), 0xC (LDM/STM), 0xF (BL setup):
        // all fall back to the interpreter
        default: return false;
    }
}

// ============================================================
// Address validity check
// ============================================================
static bool validPC(uint32_t pc, bool gba) {
    pc &= ~1u;
    if (gba) {
        return (pc < 0x4000u)                                         // BIOS
            || (pc >= 0x02000000u && pc < 0x02040000u)                // EWRAM
            || (pc >= 0x03000000u && pc < 0x03008000u)                // IWRAM
            || (pc >= 0x08000000u && pc < 0x0E000000u);               // ROM
    }
    // NDS
    return (pc < 0x4000u)                                             // ARM9 BIOS
        || (pc >= 0x02000000u && pc < 0x02400000u)                    // Main RAM
        || (pc >= 0x03000000u && pc < 0x03800000u)                    // Shared WRAM
        || (pc >= 0xFFFF0000u);                                       // ARM7 BIOS
}

// ============================================================
// Block compiler
// ============================================================
static JitBlock* compile(Interpreter* interp, Core* core,
                          uint32_t armPC, bool arm7, int cpuIdx) {
    // Reject obviously invalid PCs
    if (!validPC(armPC, core->gbaMode)) return nullptr;

    bool thumb = interp->isThumb();

    // Cache lookup
    size_t bkt = hashPC(armPC);
    JitBlock& slot = cache[bkt];
    if (slot.valid && slot.armPC == armPC && slot.thumb == thumb) return &slot;

    // Check buffer space
    if (codePos + BLK_WDS >= JIT_WORDS) flushJitCache();

    Ctx ctx;
    ctx.base    = codeBuf + codePos;
    ctx.cur     = ctx.base;
    ctx.cap     = JIT_WORDS - codePos;
    ctx.thumb   = thumb;
    ctx.arm7    = arm7;
    ctx.done    = false;
    ctx.blockPC = armPC;
    ctx.cpuIdx  = cpuIdx;
    ctx.interp  = interp;
    ctx.core    = core;

    emitPrologue(ctx);
    emitSyncFrom(ctx);

    uint32_t curPC = armPC;
    int n = 0;

    while (n < (int)BLK_ARMS && !ctx.done) {
        // Validate PC before each fetch
        if (!validPC(curPC, core->gbaMode)) {
            emitExit(ctx, curPC, EXIT_FALLBACK);
            ctx.done = true;
            break;
        }

        if (thumb) {
            uint16_t op = core->memory.read<uint16_t>(arm7, curPC);

            // Check for 32-bit BL/BLX pair
            if (((op >> 11) & 0x1F) == 0x1E) {
                if (!validPC(curPC + 2, core->gbaMode)) {
                    emitExit(ctx, curPC, EXIT_FALLBACK);
                    ctx.done = true;
                    break;
                }
                uint16_t op2 = core->memory.read<uint16_t>(arm7, curPC + 2);
                uint8_t  bb  = (op2 >> 11) & 0x1F;
                if (bb == 0x1F || bb == 0x1C) {
                    emitT_bl(ctx, op, op2, curPC);
                    curPC += 4; n += 2;
                    continue;
                }
            }

            bool ok = dispThumb(ctx, op, curPC);
            if (!ok) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
            } else {
                curPC += 2; n++;
                uint8_t h = (op >> 12) & 0xF;
                // Branches and SWI always end the block
                if (h == 0xD || h == 0xE || h == 0xF) ctx.done = true;
            }
        } else {
            uint32_t op = core->memory.read<uint32_t>(arm7, curPC);

            bool ok = dispARM(ctx, op, curPC);
            if (!ok) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
            } else {
                curPC += 4; n++;
                uint32_t it = (op >> 25) & 7;
                // B/BL (it==5), BX, or any branch instruction ends the block
                if (it == 5) ctx.done = true;
                if ((op & 0x0FFFFFF0) == 0x012FFF10) ctx.done = true;  // BX Rm
                if ((op & 0x0E000000) == 0x0A000000) ctx.done = true;  // B/BL
            }
        }
    }

    // If the block did not end with an explicit exit, emit one now
    if (!ctx.done) {
        emitExit(ctx, curPC, EXIT_NORMAL);
    }

    size_t wds = ctx.sz();
    if (wds == 0) return nullptr;   // Nothing emitted — safety guard

    dcbst(ctx.base, wds);

    slot = { armPC, ctx.base, (uint32_t)wds, thumb, true };
    codePos += wds;
    return &slot;
}

// ============================================================
// JIT run loops
// ============================================================

void runJitNds(Core& core) {
    for (int cpu = 0; cpu < 2; cpu++) {
        Interpreter& interp = core.interpreter[cpu];
        if (interp.halted) continue;

        uint32_t pc = interp.getActualPC();

        // Reject obviously bad PCs before attempting compilation
        if (pc == 0 || pc == 0xFFFFFFFFu) {
            interp.jitRunOpcode();
            continue;
        }

        JitBlock* b = compile(&interp, &core, pc, cpu == 1, cpu);
        if (b && b->nW > 0) {
            executeBlock_asm(b->code);

            uint32_t exitPC  = g_exitPC[cpu];
            int      reason  = g_exitReason[cpu];

            // Validate the exit PC before handing it to setPC()
            if (exitPC != 0 && exitPC != 0xFFFFFFFFu) {
                interp.setPC(exitPC);
                if (reason == EXIT_FALLBACK) {
                    // Interpreter handles the one opcode we couldn't compile
                    interp.jitRunOpcode();
                }
            } else {
                // Bad exit PC: let the interpreter recover
                interp.jitRunOpcode();
            }
        } else {
            interp.jitRunOpcode();
        }
    }
    JitHelp_tick(&core);
}

void runJitGba(Core& core) {
    Interpreter& interp = core.interpreter[1];
    if (!interp.halted) {
        uint32_t pc = interp.getActualPC();

        if (pc == 0 || pc == 0xFFFFFFFFu) {
            interp.jitRunOpcode();
        } else {
            JitBlock* b = compile(&interp, &core, pc, true, 1);
            if (b && b->nW > 0) {
                executeBlock_asm(b->code);

                uint32_t exitPC = g_exitPC[1];
                int      reason = g_exitReason[1];

                if (exitPC != 0 && exitPC != 0xFFFFFFFFu) {
                    interp.setPC(exitPC);
                    if (reason == EXIT_FALLBACK) {
                        interp.jitRunOpcode();
                    }
                } else {
                    interp.jitRunOpcode();
                }
            } else {
                interp.jitRunOpcode();
            }
        }
    }
    JitHelp_tick(&core);
}

// ============================================================
// Init / shutdown / invalidation
// ============================================================

bool initJit(Core* core) {
    codeBuf = (uint32_t*)memalign(32, JIT_BYTES);
    if (!codeBuf) {
        printf("[JIT] code buffer allocation failed\n");
        return false;
    }
    codePos = 0;
    for (size_t i = 0; i < CSIZ; i++) cache[i].valid = false;
    g_exitPC[0] = g_exitPC[1] = 0;
    g_exitCPSR[0] = g_exitCPSR[1] = 0;
    g_exitReason[0] = g_exitReason[1] = EXIT_NORMAL;
    printf("[JIT] code buffer at %p (%zu KB)\n", (void*)codeBuf, JIT_BYTES >> 10);
    if (core) core->setRunFunc(core->gbaMode ? runJitGba : runJitNds);
    return true;
}

void shutdownJit(Core* core) {
    if (core) {
        core->setRunFunc(core->gbaMode
            ? static_cast<void(*)(Core&)>(&Interpreter::runCoreSingle<true, 0>)
            : &Interpreter::runCoreNds);
    }
    free(codeBuf);
    codeBuf = nullptr;
    codePos = 0;
    for (size_t i = 0; i < CSIZ; i++) cache[i].valid = false;
}

void invalidateJitRange(uint32_t start, uint32_t end) {
    for (size_t i = 0; i < CSIZ; i++) {
        if (cache[i].valid &&
            cache[i].armPC >= start &&
            cache[i].armPC <  end) {
            cache[i].valid = false;
        }
    }
}

} // namespace JitPpc
