The compile function's `validPC` call also needs updating to use `compilablePC`:

```cpp
static JitBlock* compile(Interpreter* interp, Core* core,
                          uint32_t armPC, bool arm7, int cpuIdx) {
    // Use compilablePC here — we only JIT real ROM/RAM regions
    if (!compilablePC(armPC, core->gbaMode)) return nullptr;

    bool   thumb = interp->isThumb();
    size_t bkt   = hashPC(armPC);

    {
        JitBlock& slot = cache[bkt];
        if (slot.valid
            && slot.armPC == armPC
            && slot.thumb == thumb
            && slot.gen   == cacheGen
            && slot.code  >= codeBuf
            && slot.code  <  codeBuf + JIT_WORDS)
            return &slot;
        if (!slot.valid || slot.gen != cacheGen)
            slot.valid = false;
    }

    if (codePos + BLK_WDS >= JIT_WORDS) {
        flushJitCache();
    }

    JitBlock& slot = cache[bkt];

    Ctx ctx;
    ctx.base    = codeBuf + codePos;
    ctx.cur     = ctx.base;
    ctx.cap     = JIT_WORDS - codePos;
    ctx.thumb   = thumb;
    ctx.arm7    = arm7;
    ctx.done    = false;
    ctx.blockPC = armPC;
    ctx.cpuIdx  = cpuIdx;
    ctx.interp  = interp;
    ctx.core    = core;

    emitPrologue(ctx);
    emitSyncFrom(ctx);

    uint32_t curPC = armPC;
    int n = 0;

    while (n < (int)BLK_ARMS && !ctx.done) {
        // Inside the block, use compilablePC for fetch validity.
        // If PC leaves compilable range mid-block, exit with FALLBACK
        // so the interpreter handles the non-JIT region.
        if (!compilablePC(curPC, core->gbaMode)) {
            emitExit(ctx, curPC, EXIT_FALLBACK);
            ctx.done = true; break;
        }

        if (thumb) {
            uint16_t op = core->memory.read<uint16_t>(arm7, curPC);

            if (((op >> 11) & 0x1F) == 0x1E) {
                if (!compilablePC(curPC + 2, core->gbaMode)) {
                    emitExit(ctx, curPC, EXIT_FALLBACK);
                    ctx.done = true; break;
                }
                uint16_t op2 = core->memory.read<uint16_t>(arm7, curPC + 2);
                uint8_t  bb  = (op2 >> 11) & 0x1F;
                if (bb == 0x1F || bb == 0x1C) {
                    emitT_bl(ctx, op, op2, curPC);
                    curPC += 4; n += 2; continue;
                }
            }

            bool ok = dispThumb(ctx, op, curPC);
            if (!ok) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
            } else {
                curPC += 2; n++;
                uint8_t h = (op >> 12) & 0xF;
                if (h == 0xD || h == 0xE || h == 0xF) ctx.done = true;
            }
        } else {
            uint32_t op = core->memory.read<uint32_t>(arm7, curPC);

            bool ok = dispARM(ctx, op, curPC);
            if (!ok) {
                emitExit(ctx, curPC, EXIT_FALLBACK);
                ctx.done = true;
            } else {
                curPC += 4; n++;
                uint32_t it = (op >> 25) & 7;
                if (it == 5)                         ctx.done = true;
                if ((op & 0x0FFFFFF0) == 0x012FFF10) ctx.done = true;
                if ((op & 0x0E000000) == 0x0A000000) ctx.done = true;
            }
        }
    }

    if (!ctx.done) emitExit(ctx, curPC, EXIT_NORMAL);

    size_t wds = ctx.sz();
    if (wds == 0) return nullptr;

    flushICache(ctx.base, wds);

    slot.armPC = armPC;
    slot.code  = ctx.base;
    slot.nW    = (uint32_t)wds;
    slot.gen   = cacheGen;
    slot.thumb = thumb;
    slot.valid = true;

    codePos += wds;
    return &slot;
}
```

The key changes and why each one is necessary:

| Change | Why |
|---|---|
| Split `validPC` into `compilablePC` and `handleablePC` | `validPC` was doing two different jobs: deciding if we can JIT a PC, and deciding if an exit PC from the JIT is sensible. These are different questions. `0x000E2B04` is a valid ARM address (HLE handles it) but not JIT-compilable |
| GBA `compilablePC` excludes BIOS range entirely | GBA HLE BIOS does not map real ROM to `0x0..0x3FFF`, so the JIT cannot fetch opcodes from there. Previous code included `pc >= 4 && pc < 0x4000` which still allowed fetching from near-BIOS addresses |
| Run loop uses `handleablePC` instead of `compilablePC` for exit PC check | The old `isGoodPC` called `validPC` on exit PCs, which rejected `0x000E2B04` and skipped the `setPC` call. This left the interpreter's PC pointing at the last JIT-executed instruction, causing it to re-execute indefinitely |
| `setPC(exitPC)` called for ALL handleable exit PCs | Even HLE BIOS addresses need `setPC` so that `flushPipeline` refills the pipeline from the right address and the interpreter executes the correct next instruction |
