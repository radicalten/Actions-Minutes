// ---------------------------------------------------------------------------
// getSamples — zero-allocation audio pull.
//
// Called from the audio thread.  `dst` must point to caller-owned storage
// of at least count * sizeof(uint32_t) bytes.  count must equal SPU_BUF_FRAMES
// (enforced by the static_assert in wii_audio.h via the frame-count macros).
//
// Returns true  → dst filled with fresh emulator audio.
// Returns false → dst filled with silence (emulator is behind).
// ---------------------------------------------------------------------------
bool Spu::getSamples(uint32_t *dst, int count) {
    // Clamp to our fixed buffer size so we never overread.
    if (count > SPU_BUF_FRAMES) count = SPU_BUF_FRAMES;

    bool wait = false;

    if (Settings::fpsLimiter == 2) {
        // Busy-wait up to one frame period.
        u64 startTime = PPCGetTickCount();
        u64 timeout   = PPCUsToTicks(1000000 / 60);
        while (true) {
            PPCIrqState st = PPCIrqLockByMsr();
            bool isReady   = ready;
            PPCIrqUnlockByMsr(st);
            if (isReady) break;
            if (PPCGetTickCount() - startTime > timeout) { wait = true; break; }
            KThreadYield();
        }
    }
    else if (Settings::fpsLimiter == 1) {
        // Block until emulator signals.
        PPCIrqState st = PPCIrqLockByMsr();
        bool isReady   = ready;
        PPCIrqUnlockByMsr(st);
        if (!isReady)
            KThrQueueBlock(&waitQueue2, 1);
    }
    else {
        // Non-blocking: return silence if data is not ready.
        PPCIrqState st = PPCIrqLockByMsr();
        if (!ready) wait = true;
        PPCIrqUnlockByMsr(st);
    }

    if (wait) {
        // Silence: copy last known sample across the whole output.
        // Read from whichever buffer is NOT currently being written;
        // that buffer still holds the previous complete frame.
        PPCIrqState st  = PPCIrqLockByMsr();
        int         ri  = writeIdx ^ 1;          // the "read" buffer index
        uint32_t    last = (buffers[ri][SPU_BUF_FRAMES - 1]);
        PPCIrqUnlockByMsr(st);

        for (int i = 0; i < count; i++) dst[i] = last;
        return false;
    }

    // Copy from the completed buffer (opposite side of current write buffer).
    {
        PPCIrqState st = PPCIrqLockByMsr();
        int ri = writeIdx ^ 1;
        memcpy(dst, buffers[ri], (size_t)count * sizeof(uint32_t));
        ready = false;
        PPCIrqUnlockByMsr(st);
    }

    if (Settings::fpsLimiter == 1)
        KThrQueueUnblockAllByValue(&waitQueue1, 1);

    return true;
}

// ---------------------------------------------------------------------------
// pushSample — called from the emulator thread (runSample / runGbaSample).
//
// Accumulates samples into buffers[writeIdx].  When the buffer is full,
// swaps the write index (making the completed buffer visible to the reader)
// and signals the audio thread.
// ---------------------------------------------------------------------------
void Spu::pushSample(int16_t sampleLeft, int16_t sampleRight) {
    buffers[writeIdx][bufferPointer++] =
        ((uint32_t)(uint16_t)sampleRight << 16) |
        ((uint32_t)(uint16_t)sampleLeft  & 0xFFFF);

    if (bufferPointer < SPU_BUF_FRAMES) return;   // buffer not yet full

    // Buffer is full — apply back-pressure then swap.

    if (Settings::fpsLimiter == 2) {
        u64 startTime = PPCGetTickCount();
        u64 timeout   = PPCUsToTicks(1000000);     // 1 s hard cap
        while (true) {
            PPCIrqState st = PPCIrqLockByMsr();
            bool isReady   = ready;
            PPCIrqUnlockByMsr(st);
            if (!isReady) break;
            if (PPCGetTickCount() - startTime > timeout) break;
            KThreadYield();
        }
    }
    else if (Settings::fpsLimiter == 1) {
        PPCIrqState st = PPCIrqLockByMsr();
        bool isReady   = ready;
        PPCIrqUnlockByMsr(st);
        if (isReady)
            KThrQueueBlock(&waitQueue1, 1);
    }
    // fpsLimiter == 0: no back-pressure, just overwrite.

    // Atomically flip the write buffer and signal ready.
    {
        PPCIrqState st = PPCIrqLockByMsr();
        writeIdx  ^= 1;          // new write side; old side is now the read side
        ready      = true;
        PPCIrqUnlockByMsr(st);
    }

    bufferPointer = 0;           // reset write pointer for new buffer

    if (Settings::fpsLimiter == 1)
        KThrQueueUnblockAllByValue(&waitQueue2, 1);
}

