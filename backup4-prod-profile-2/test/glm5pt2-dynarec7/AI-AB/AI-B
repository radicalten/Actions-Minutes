## 2. Fix the Thumb SP-adjust decoder

Your existing `emitT_addSpPc()` has this:

```cpp
uint8_t s = (op >> 8) & 0xF;
if (s == 0) {
```

That is too broad and does not properly distinguish the Thumb `ADD/SUB SP, #imm` format.

Replace the full function with:

```cpp
static bool emitT_addSpPc(Ctx& ctx, uint16_t op, uint32_t curPC) {
    /*
     * 1010 Rd imm8:
     *   ADD Rd, PC, #imm
     *   ADD Rd, SP, #imm
     *
     * 1011 0000 0iiiiiii:
     *   ADD SP, #imm
     *
     * 1011 0000 1iiiiiii:
     *   SUB SP, #imm
     */

    /* ADD Rd, PC/SP, #imm */
    if ((op & 0xF000) == 0xA000) {
        const uint8_t rd = (op >> 8) & 7;
        const bool fromSp = (op & 0x0800) != 0;
        const uint32_t imm = (uint32_t)(op & 0xFF) << 2;

        if (fromSp) {
            ctx.li(TA, imm);
            ctx.E(ppc_add(RA[rd], RA[13], TA));
        } else {
            ctx.li(RA[rd], ((curPC + 4) & ~3u) + imm);
        }
        return true;
    }

    /* ADD/SUB SP, #imm */
    if ((op & 0xFF00) == 0xB000 ||
        (op & 0xFF00) == 0xB080) {
        const bool sub = (op & 0x0080) != 0;
        const uint32_t imm = (uint32_t)(op & 0x7F) << 2;

        ctx.li(TA, imm);

        if (sub)
            ctx.E(ppc_subf(RA[13], TA, RA[13]));
        else
            ctx.E(ppc_add(RA[13], RA[13], TA));

        return true;
    }

    return false;
}
```

