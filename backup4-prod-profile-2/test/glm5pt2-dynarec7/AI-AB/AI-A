+int JitHelp_thumbAluShift(uint32_t op, uint32_t* regs, uint32_t* cpsrInOut) {
+    if (!regs || !cpsrInOut) return -1;
+
+    const uint8_t rd = op & 7;
+    const uint8_t rs = (op >> 3) & 7;
+    const uint8_t sub = (op >> 6) & 0xF;
+
+    uint32_t value  = regs[rd];
+    uint32_t amount = regs[rs] & 0xFFu;
+    uint32_t result = value;
+    uint32_t carry  = 0;
+    bool carryChanged = false;
+
+    switch (sub) {
+        case 2: // LSL Rd, Rs
+            if (amount == 0) {
+                result = value;
+            } else if (amount < 32) {
+                carry = (value >> (32 - amount)) & 1u;
+                result = value << amount;
+                carryChanged = true;
+            } else if (amount == 32) {
+                carry = value & 1u;
+                result = 0;
+                carryChanged = true;
+            } else {
+                carry = 0;
+                result = 0;
+                carryChanged = true;
+            }
+            break;
+
+        case 3: // LSR Rd, Rs
+            if (amount == 0) {
+                result = value;
+            } else if (amount < 32) {
+                carry = (value >> (amount - 1)) & 1u;
+                result = value >> amount;
+                carryChanged = true;
+            } else if (amount == 32) {
+                carry = (value >> 31) & 1u;
+                result = 0;
+                carryChanged = true;
+            } else {
+                carry = 0;
+                result = 0;
+                carryChanged = true;
+            }
+            break;
+
+        case 4: // ASR Rd, Rs
+            if (amount == 0) {
+                result = value;
+            } else if (amount < 32) {
+                carry = (value >> (amount - 1)) & 1u;
+                result = (uint32_t)((int32_t)value >> amount);
+                carryChanged = true;
+            } else {
+                carry = (value >> 31) & 1u;
+                result = carry ? 0xFFFFFFFFu : 0u;
+                carryChanged = true;
+            }
+            break;
+
+        case 7: // ROR Rd, Rs
+            if (amount == 0) {
+                result = value;
+            } else {
+                uint32_t rot = amount & 31u;
+                if (rot == 0) {
+                    result = value;
+                    carry = (value >> 31) & 1u;
+                } else {
+                    result = (value >> rot) | (value << (32 - rot));
+                    carry = (value >> (rot - 1)) & 1u;
+                }
+                carryChanged = true;
+            }
+            break;
+
+        default:
+            return -1;
+    }
+
+    regs[rd] = result;
+
+    uint32_t cpsr = *cpsrInOut;
+    cpsr &= ~((1u << 31) | (1u << 30));
+    cpsr |= result & (1u << 31);
+    if (result == 0)
