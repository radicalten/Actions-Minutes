    uint8_t** map = arm7 ? writeMap7 : (tcm ? writeMap9A : writeMap9B);
    if (uint8_t* data = map[addr >> 12]) { store8_le(data + (addr & 0xFFF), val); return; }
    writeFallback(arm7, addr, val);
