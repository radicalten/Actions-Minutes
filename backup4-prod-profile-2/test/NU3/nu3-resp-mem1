                    case 0x06400000: m = &engAObj[(addr & 0x3FFFF) >> 14]; break;
                    case 0x06600000: m = &engBObj[(addr & 0x1FFFF) >> 14]; break;
                    default: m = &lcdc[(addr & 0xFFFFF) >> 14]; break;
