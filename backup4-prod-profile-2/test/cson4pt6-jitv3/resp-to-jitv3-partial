// ---------------------------------------------------------------------------
// Block compiler: translate a sequence of ARM/Thumb instructions
// Returns the compiled JitBlock, or an invalid block if compilation fails.
// ---------------------------------------------------------------------------

// Max size for a single block's PPC output (in 32-bit words)
static constexpr size_t kMaxBlockWords = 2048;

// Decode and translate one ARM (32-bit) instruction
// Returns number of ARM cycles, or -1 to bail
static int translateArmInsn(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx,
                             bool& blockEnds) {
    int cond = (opcode >> 28) & 0xF;

    if (cond == COND_NV) {
        // ARMv5 special encoding or undefined
        // Check for BLX (imm): cond=NV, bits[27:25]=101
        if ((opcode & 0xFE000000u) == 0xFA000000u) {
            // BLX (immediate) - switch to Thumb
            // For simplicity, bail to interpreter
            return -1;
        }
        return 1; // NOP
    }

    // Emit condition check (if cond != AL)
    CondBranch cb = emitCondCheck(e, cond);

    int cycles = 1;
    uint32_t tag = opcode >> 20; // top 12 bits for decode

    // Decode ARM instruction
    uint32_t bits27_20 = (opcode >> 20) & 0xFF;
    uint32_t bits7_4   = (opcode >> 4)  & 0xF;

    bool decoded = true;

    if ((opcode & 0x0FC000F0u) == 0x00000090u) {
        // Multiply (MUL, MLA)
        bool setFlags = (opcode >> 20) & 1;
        bool accumulate = (opcode >> 21) & 1;
        if (accumulate) cycles = emitMla(e, opcode, pc, setFlags, cpuIdx);
        else            cycles = emitMul(e, opcode, pc, setFlags, cpuIdx);
    }
    else if ((opcode & 0x0F8000F0u) == 0x00800090u) {
        // Long multiply (UMULL, SMULL, UMLAL, SMLAL)
        bool setFlags = (opcode >> 20) & 1;
        bool accumulate = (opcode >> 21) & 1;
        bool isSigned   = (opcode >> 22) & 1;
        if (accumulate) cycles = emitUmlal(e, opcode, pc, setFlags, isSigned, cpuIdx);
        else if (isSigned) cycles = emitSmull(e, opcode, pc, setFlags, cpuIdx);
        else               cycles = emitUmull(e, opcode, pc, setFlags, cpuIdx);
    }
    else if ((opcode & 0x0FB000F0u) == 0x01000090u) {
        // SWP / SWPB
        bool byte = (opcode >> 22) & 1;
        cycles = emitSwp(e, opcode, pc, byte, cpuIdx);
    }
    else if ((opcode & 0x0E000010u) == 0x00000000u &&
             (opcode & 0x00000090u) != 0x00000090u) {
        // Data processing, register operand
        int opc4 = (opcode >> 21) & 0xF;
        bool setFlags = (opcode >> 20) & 1;
        switch (opc4) {
            case  0: cycles = emitAnd(e, opcode, pc, setFlags, cpuIdx); break;
            case  1: cycles = emitEor(e, opcode, pc, setFlags, cpuIdx); break;
            case  2: cycles = emitSub(e, opcode, pc, setFlags, cpuIdx); break;
            case  3: cycles = emitRsb(e, opcode, pc, setFlags, cpuIdx); break;
            case  4: cycles = emitAdd(e, opcode, pc, setFlags, cpuIdx); break;
            case  5: cycles = emitAdc(e, opcode, pc, setFlags, cpuIdx); break;
            case  6: cycles = emitSbc(e, opcode, pc, setFlags, cpuIdx); break;
            case  7: cycles = emitRsc(e, opcode, pc, setFlags, cpuIdx); break;
            case  8: cycles = emitTst(e, opcode, pc, cpuIdx); break;
            case  9: cycles = emitTeq(e, opcode, pc, cpuIdx); break;
            case 10: cycles = emitCmp(e, opcode, pc, cpuIdx); break;
            case 11: cycles = emitCmn(e, opcode, pc, cpuIdx); break;
            case 12: cycles = emitOrr(e, opcode, pc, setFlags, cpuIdx); break;
            case 13: cycles = emitMov(e, opcode, pc, setFlags, cpuIdx); break;
            case 14: cycles = emitBic(e, opcode, pc, setFlags, cpuIdx); break;
            case 15: cycles = emitMvn(e, opcode, pc, setFlags, cpuIdx); break;
            default: decoded = false; break;
        }
    }
    else if ((opcode & 0x0E000000u) == 0x02000000u) {
        // Data processing, immediate
        int opc4 = (opcode >> 21) & 0xF;
        bool setFlags = (opcode >> 20) & 1;
        switch (opc4) {
            case  0: cycles = emitAnd(e, opcode, pc, setFlags, cpuIdx); break;
            case  1: cycles = emitEor(e, opcode, pc, setFlags, cpuIdx); break;
            case  2: cycles = emitSub(e, opcode, pc, setFlags, cpuIdx); break;
            case  3: cycles = emitRsb(e, opcode, pc, setFlags, cpuIdx); break;
            case  4: cycles = emitAdd(e, opcode, pc, setFlags, cpuIdx); break;
            case  5: cycles = emitAdc(e, opcode, pc, setFlags, cpuIdx); break;
            case  6: cycles = emitSbc(e, opcode, pc, setFlags, cpuIdx); break;
            case  7: cycles = emitRsc(e, opcode, pc, setFlags, cpuIdx); break;
            case  8: cycles = emitTst(e, opcode, pc, cpuIdx); break;
            case  9: cycles = emitTeq(e, opcode, pc, cpuIdx); break;
            case 10: cycles = emitCmp(e, opcode, pc, cpuIdx); break;
            case 11: cycles = emitCmn(e, opcode, pc, cpuIdx); break;
            case 12: cycles = emitOrr(e, opcode, pc, setFlags, cpuIdx); break;
            case 13: cycles = emitMov(e, opcode, pc, setFlags, cpuIdx); break;
            case 14: cycles = emitBic(e, opcode, pc, setFlags, cpuIdx); break;
            case 15: cycles = emitMvn(e, opcode, pc, setFlags, cpuIdx); break;
            default: decoded = false; break;
        }
    }
    else if ((opcode & 0x0C000000u) == 0x04000000u) {
        // Load/Store
        bool load  = (opcode >> 20) & 1;
        bool byte  = (opcode >> 22) & 1;
        if (load && !byte) cycles = emitLdr(e, opcode, pc, cpuIdx);
        else if (!load && !byte) cycles = emitStr(e, opcode, pc, cpuIdx);
        else if (load && byte)   cycles = emitLdrb(e, opcode, pc, cpuIdx);
        else                     cycles = emitStrb(e, opcode, pc, cpuIdx);
    }
    else if ((opcode & 0x0E400F90u) == 0x00000090u ||
             (opcode & 0x0E400090u) == 0x00400090u) {
        // Halfword/signed load-store
        bool load  = (opcode >> 20) & 1;
        int  type  = (opcode >> 5) & 0x3; // 01=UH, 10=SB, 11=SH
        if (load) {
            switch (type) {
                case 1: cycles = emitLdrh(e,  opcode, pc, cpuIdx); break;
                case 2: cycles = emitLdrsb(e, opcode, pc, cpuIdx); break;
                case 3: cycles = emitLdrsh(e, opcode, pc, cpuIdx); break;
                default: decoded = false;
            }
        } else {
            if (type == 1) cycles = emitStrh(e, opcode, pc, cpuIdx);
            else decoded = false;
        }
    }
    else if ((opcode & 0x0E000000u) == 0x08000000u) {
        // Block data transfer
        bool load = (opcode >> 20) & 1;
        cycles = emitLdmStm(e, opcode, pc, load, cpuIdx);
    }
    else if ((opcode & 0x0E000000u) == 0x0A000000u) {
        // B / BL
        bool link = (opcode >> 24) & 1;
        cycles = emitB(e, opcode, pc, link, cpuIdx);
        blockEnds = true;
    }
    else if ((opcode & 0x0FFFFFF0u) == 0x012FFF10u) {
        // BX
        cycles = emitBx(e, opcode, pc, cpuIdx);
        blockEnds = true;
    }
    else if ((opcode & 0x0FFFFFF0u) == 0x012FFF30u) {
        // BLX register
        int rm = opcode & 0xF;
        e.li32(armToPpcReg(14), pc + 4);
        // Reuse BX logic
        cycles = emitBx(e, opcode, pc, cpuIdx);
        blockEnds = true;
    }
    else if ((opcode & 0x0F000000u) == 0x0F000000u) {
        // SWI
        cycles = emitSwi(e, opcode, pc, cpuIdx);
        blockEnds = true;
    }
    else if ((opcode & 0x0FBF0FFFu) == 0x010F0000u) {
        // MRS
        cycles = emitMsrMrs(e, opcode, pc, cpuIdx);
    }
    else if ((opcode & 0x0FB0FFFFu) == 0x0120F000u ||
             (opcode & 0x0FB0F000u) == 0x0320F000u) {
        // MSR
        cycles = emitMsrMrs(e, opcode, pc, cpuIdx);
    }
    else if ((opcode & 0x0E000010u) == 0x0E000010u) {
        // MRC/MCR
        cycles = emitCoprocessor(e, opcode, pc, cpuIdx);
    }
    else if ((opcode & 0x0FFF0FF0u) == 0x016F0F10u) {
        // CLZ
        cycles = emitClz(e, opcode, pc, cpuIdx);
    }
    else {
        decoded = false;
    }

    if (!decoded) {
        // Bail to interpreter for unhandled instructions
        if (cb.patchWord) patchBranch(e, cb.patchWord);
        return -1;
    }

    // Patch condition branch to jump past body to here
    if (cb.patchWord) patchBranch(e, cb.patchWord);

    return cycles;
}

// Decode and translate one Thumb (16-bit) instruction
static int translateThumbInsn(Emitter& e, uint16_t opcode, uint32_t pc, int cpuIdx,
                               bool& blockEnds,
                               uint16_t nextOpcode) {
    int cycles = 1;
    bool decoded = true;

    uint32_t bits15_13 = (opcode >> 13) & 0x7;
    uint32_t bits15_11 = (opcode >> 11) & 0x1F;
    uint32_t bits15_8  = (opcode >> 8) & 0xFF;

    if (bits15_11 == 0b00000) { // LSL imm
        cycles = emitThumbLslImm(e, opcode, pc, cpuIdx);
    }
    else if (bits15_11 == 0b00001) { // LSR imm
        cycles = emitThumbLsrImm(e, opcode, pc, cpuIdx);
    }
    else if (bits15_11 == 0b00010) { // ASR imm
        cycles = emitThumbAsrImm(e, opcode, pc, cpuIdx);
    }
    else if (bits15_11 == 0b00011) {
        bool sub = (opcode >> 9) & 1;
        bool imm = (opcode >> 10) & 1;
        if (!imm) {
            if (sub) cycles = emitThumbSubReg(e, opcode, pc, cpuIdx);
            else     cycles = emitThumbAddReg(e, opcode, pc, cpuIdx);
        } else {
            // ADD/SUB imm3
            int imm3 = (opcode >> 6) & 0x7;
            int rn   = (opcode >> 3) & 0x7;
            int rd   =  opcode & 0x7;
            if (sub) {
                e.emit(ppc_li(SCRATCH1, imm3));
                e.emit(ppc_subfc(armToPpcReg(rd), SCRATCH1, armToPpcReg(rn)));
            } else {
                e.emit(ppc_addi(armToPpcReg(rd), armToPpcReg(rn), imm3));
            }
            emitUpdateNZ(e, armToPpcReg(rd));
        }
    }
    else if ((bits15_11 & 0b11100) == 0b00100) { // MOV/CMP/ADD/SUB imm8
        int op  = (opcode >> 11) & 0x3;
        switch (op) {
            case 0: cycles = emitThumbMovImm(e, opcode, pc, cpuIdx); break;
            case 1: cycles = emitThumbCmpImm(e, opcode, pc, cpuIdx); break;
            case 2: cycles = emitThumbAddImm(e, opcode, pc, cpuIdx); break;
            case 3: cycles = emitThumbSubImm(e, opcode, pc, cpuIdx); break;
        }
    }
    else if ((opcode & 0xFF00u) == 0x4300u ||
             (opcode & 0xFFC0u) == 0x4000u) {
        // ALU operations or special
        if ((opcode & 0xFFC0u) == 0x4000u) {
            // Data processing
            cycles = emitThumbDp(e, opcode, pc, cpuIdx);
        } else {
            // Hi register ops: ADD/CMP/MOV/BX
            int op  = (opcode >> 8) & 0x3;
            int rm  = (opcode >> 3) & 0xF;
            int rd  = ((opcode >> 4) & 0x8) | (opcode & 0x7);
            switch (op) {
                case 0: // ADD hi
                    e.emit(ppc_add(armToPpcReg(rd), armToPpcReg(rd), armToPpcReg(rm)));
                    break;
                case 1: { // CMP hi
                    e.emit(ppc_subfc(SCRATCH0, armToPpcReg(rm), armToPpcReg(rd)));
                    emitUpdateNZ(e, SCRATCH0);
                    e.emit(ppc_mfxer(SCRATCH2));
                    e.emit(ppc_rlwinm(SCRATCH5, SCRATCH2, 3, 31, 31));
                    emitUpdateC(e);
                    e.emit(ppc_subfo(SCRATCH3, armToPpcReg(rm), armToPpcReg(rd), false));
                    e.emit(ppc_mfxer(SCRATCH2));
                    e.emit(ppc_rlwinm(SCRATCH4, SCRATCH2, 2, 31, 31));
                    emitUpdateV(e, SCRATCH4);
                    break;
                }
                case 2: // MOV hi
                    e.emit(ppc_mr(armToPpcReg(rd), armToPpcReg(rm)));
                    break;
                case 3: // BX/BLX
                    cycles = emitThumbBx(e, opcode, pc, cpuIdx);
                    blockEnds = true;
                    break;
            }
        }
    }
    else if (bits15_11 == 0b01001) { // LDR PC
        cycles = emitThumbLdrPc(e, opcode, pc, cpuIdx);
    }
    else if ((opcode & 0xF200u) == 0x5000u) { // Load/store register
        int op  = (opcode >> 10) & 0x3;
        int bit9 = (opcode >> 9) & 1;
        if (!bit9) {
            switch (op) {
                case 0: cycles = emitThumbStrReg(e,  opcode, pc, cpuIdx); break;
                case 1: cycles = emitThumbStrhReg(e, opcode, pc, cpuIdx); break;
                case 2: cycles = emitThumbLdrReg(e,  opcode, pc, cpuIdx); break;
                case 3: { // LDSB
                    int rm=(opcode>>6)&7, rn=(opcode>>3)&7, rd=opcode&7;
                    e.emit(ppc_add(SCRATCH3, armToPpcReg(rn), armToPpcReg(rm)));
                    emitMemRead(e, cpuIdx, 1, true, armToPpcReg(rd), SCRATCH3);
                    break;
                }
            }
        } else {
            switch (op) {
                case 0: cycles = emitThumbStrbReg(e, opcode, pc, cpuIdx); break;
                case 1: cycles = emitThumbLdrhReg(e, opcode, pc, cpuIdx); break;
                case 2: cycles = emitThumbLdrbReg(e, opcode, pc, cpuIdx); break;
                case 3: { // LDSH
                    int rm=(opcode>>6)&7, rn=(opcode>>3)&7, rd=opcode&7;
                    e.emit(ppc_add(SCRATCH3, armToPpcReg(rn), armToPpcReg(rm)));
                    emitMemRead(e, cpuIdx, 2, true, armToPpcReg(rd), SCRATCH3);
                    break;
                }
            }
        }
    }
    else if (bits15_13 == 0b011) { // Load/store imm5
        int op = (opcode >> 11) & 0x3;
        switch (op) {
            case 0: cycles = emitThumbStrImm(e,  opcode, pc, cpuIdx); break;
            case 1: cycles = emitThumbLdrImm(e,  opcode, pc, cpuIdx); break;
            case 2: cycles = emitThumbStrbImm(e, opcode, pc, cpuIdx); break;
            case 3: cycles = emitThumbLdrbImm(e, opcode, pc, cpuIdx); break;
        }
    }
    else if (bits15_13 == 0b100) { // Load/store halfword imm5 / SP-relative
        int op = (opcode >> 11) & 0x3;
        switch (op) {
            case 0: cycles = emitThumbStrhImm(e, opcode, pc, cpuIdx); break;
            case 1: cycles = emitThumbLdrhImm(e, opcode, pc, cpuIdx); break;
            case 2: cycles = emitThumbStrSp(e, opcode, pc, cpuIdx); break;
            case 3: cycles = emitThumbLdrSp(e, opcode, pc, cpuIdx); break;
        }
    }
    else if (bits15_12 == 0b1010) { // ADD PC/SP
        int sp  = (opcode >> 11) & 1;
        int rd  = (opcode >> 8)  & 0x7;
        int off = (opcode & 0xFF) << 2;
        int pRd = armToPpcReg(rd);
        if (sp) {
            e.emit(ppc_addi(pRd, armToPpcReg(13), (int32_t)off));
        } else {
            uint32_t pca = ((pc + 4) & ~3u) + off;
            e.li32(pRd, pca);
        }
    }
    else if (bits15_12 == 0b1011) { // Misc
        int op8 = (opcode >> 8) & 0xF;
        if (op8 == 0) { // ADD SP
            cycles = emitThumbAddSp(e, opcode, pc, cpuIdx);
        } else if ((op8 & 0xE) == 0xA) { // PUSH
            cycles = emitThumbPush(e, opcode, pc, cpuIdx);
        } else if ((op8 & 0xE) == 0xE) { // POP
            cycles = emitThumbPop(e, opcode, pc, cpuIdx);
        } else {
            decoded = false;
        }
    }
    else if (bits15_11 == 0b11000) { // STMIA
        cycles = emitThumbStmia(e, opcode, pc, cpuIdx);
    }
    else if (bits15_11 == 0b11001) { // LDMIA
        cycles = emitThumbLdmia(e, opcode, pc, cpuIdx);
    }
    else if (bits15_12 == 0b1101) { // Conditional branch / SWI
        int cond8 = (opcode >> 8) & 0xF;
        if (cond8 == 0xF) {
            // SWI
            emitSpillRegisters(e, cpuIdx, pc);
            JitContext* ctx = &g_jitCtx[cpuIdx];
            e.li32(3, (uint32_t)ctx->interp);
            e.li32(4, (uint32_t)opcode);
            e.emit(ppc_mflr(0)); e.emit(ppc_stw(0, 1, -4));
            e.callAbsolute((void*)jit_swi);
            e.emit(ppc_lwz(0, 1, -4)); e.emit(ppc_mtlr(0));
            emitReloadRegisters(e, cpuIdx);
            blockEnds = true;
        } else {
            cycles = emitThumbCondBranch(e, opcode, pc, cond8, cpuIdx);
            blockEnds = true;
        }
    }
    else if (bits15_11 == 0b11100) { // B
        cycles = emitThumbBranch(e, opcode, pc, cpuIdx);
        blockEnds = true;
    }
    else if (bits15_11 == 0b11110) { // BL/BLX prefix
        // Two-instruction BL sequence
        cycles = emitThumbBl(e, opcode, nextOpcode, pc, cpuIdx);
        blockEnds = true;
        return cycles | (1 << 16); // signal 2-insn consumed
    }
    else if (bits15_11 == 0b11111) { // BL suffix (handled by prefix)
        return 1; // skip (consumed by prefix handler)
    }
    else {
        decoded = false;
    }

    if (!decoded) return -1;
    return cycles;
}

