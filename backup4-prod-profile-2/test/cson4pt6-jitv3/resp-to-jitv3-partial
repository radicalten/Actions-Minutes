static constexpr uint32_t PPC_BLR = 0x4E800020u;

// ---- Load 32-bit immediate (2 instructions) ----
// Use r as scratch: lis rD, hi16(imm); ori rD, rD, lo16(imm)
// If lo16 == 0, just one lis.

// ---------------------------------------------------------------------------
// Code emitter: writes PPC instructions into a buffer
// ---------------------------------------------------------------------------
struct Emitter {
    uint32_t* buf;     // current write pointer
    uint32_t* base;    // block start
    size_t    cap;     // max words remaining

    Emitter(uint32_t* b, size_t capacity)
        : buf(b), base(b), cap(capacity) {}

    void emit(uint32_t insn) {
        if (cap > 0) { *buf++ = insn; --cap; }
    }

    // Load 32-bit immediate into register
    void loadImm32(int rd, uint32_t imm) {
        int32_t hi = (int32_t)(imm >> 16);
        int32_t lo = (int32_t)(imm & 0xFFFF);
        if (lo & 0x8000) hi++; // sign-extend compensation
        if (hi != 0) emit(ppc_lis(rd, hi));
        if (lo != 0 || hi == 0) emit(ppc_ori(rd, (hi!=0)?rd:0, imm & 0xFFFF));
        // If both hi and lo are 0, just emit li rd,0
        if (hi == 0 && lo == 0) emit(ppc_li(rd, 0));
    }

    // Proper 32-bit immediate load
    void li32(int rd, uint32_t imm) {
        uint32_t hi = imm >> 16;
        uint32_t lo = imm & 0xFFFF;
        if (hi == 0) {
            emit(ppc_li(rd, (int32_t)(int16_t)lo));
        } else if (lo == 0) {
            emit(ppc_lis(rd, (int32_t)(int16_t)hi));
        } else {
            emit(ppc_lis(rd, (int32_t)(int16_t)hi));
            emit(ppc_ori(rd, rd, lo));
        }
    }

    // Call a function pointer (absolute address)
    // Uses r0 as scratch, clobbers LR
    void callAbsolute(void* fnPtr) {
        uintptr_t addr = (uintptr_t)fnPtr;
        li32(0, (uint32_t)addr);
        emit(ppc_mtctr(0));
        emit(ppc_bctrl());
    }

    size_t wordCount() const { return (size_t)(buf - base); }
    uint32_t* ptr() const { return buf; }
};

// ---------------------------------------------------------------------------
// JIT block descriptor
// ---------------------------------------------------------------------------
struct JitBlock {
    uint32_t  armPc;        // ARM PC of block start (guest address)
    bool      isThumb;      // Thumb or ARM mode
    uint32_t* code;         // pointer into code cache
    uint32_t  codeWords;    // size in 32-bit words
    uint32_t  guestCycles;  // approximate ARM cycles for this block
    uint32_t  guestInsns;   // number of ARM instructions translated
    bool      valid;        // set false on invalidation
};

// ---------------------------------------------------------------------------
// Forward declarations for JIT helper stubs (called from generated code)
// These are C++ functions that generated PPC code can call via bctrl.
// Calling convention (Wii/PPC EABI):
//   r3 = arg1, r4 = arg2, r5 = arg3, ...
//   r3 = return value
//   r0,r3-r12 are volatile; r13-r31 preserved
// ---------------------------------------------------------------------------

// The JIT context is stored in thread-local/global for helpers to access
struct JitContext {
    Interpreter* interp;
    Core*        core;
    bool         arm7;
};

// Per-core JIT context (one per DS CPU)
static JitContext g_jitCtx[2];

// ---------------------------------------------------------------------------
// Helper stubs — called from JIT-compiled code
// These bridge back into the C++ emulator infrastructure.
// ---------------------------------------------------------------------------

// Read ARM memory (8/16/32 bit)
// Called with: r3=isArm7, r4=address
// Returns r3 = value
extern "C" uint32_t jit_read8 (bool arm7, uint32_t addr) {
    // We need core context here; use a global shim
    return 0; // filled in per-core below
}

// These are the real per-core stubs stored as function pointers
struct JitMemStubs {
    uint32_t (*read8) (uint32_t addr);
    uint32_t (*read16)(uint32_t addr);
    uint32_t (*read32)(uint32_t addr);
    void     (*write8) (uint32_t addr, uint32_t val);
    void     (*write16)(uint32_t addr, uint32_t val);
    void     (*write32)(uint32_t addr, uint32_t val);
    // Signed loads
    int32_t  (*read8s) (uint32_t addr);
    int32_t  (*read16s)(uint32_t addr);
};

// Global stubs for each CPU
static JitMemStubs g_memStubs[2];

// ---------------------------------------------------------------------------
// JIT Code Cache Manager
// ---------------------------------------------------------------------------
class JitCache {
public:
    static constexpr size_t kCacheBytes = JIT_CACHE_SIZE;

    JitCache() {
        // Allocate executable memory
        // On Wii/Gekko, we need to allocate in MEM1 and make it executable.
        // For the emulator context, we'll use memalign.
        m_mem = (uint8_t*)memalign(32, kCacheBytes);
        memset(m_mem, 0x60, kCacheBytes); // fill with NOPs
        m_writePtr = (uint32_t*)m_mem;
        m_endPtr   = (uint32_t*)(m_mem + kCacheBytes);
    }

    ~JitCache() {
        free(m_mem);
    }

    // Allocate space for a new block
    uint32_t* alloc(size_t words) {
        if (m_writePtr + words + 16 >= m_endPtr) {
            flush(); // out of space, flush everything
        }
        uint32_t* p = m_writePtr;
        m_writePtr += words + 8; // small gap between blocks
        return p;
    }

    // Lookup block by ARM PC
    JitBlock* lookup(uint32_t armPc, bool thumb) {
        uint32_t key = armPc ^ (thumb ? 1 : 0);
        auto it = m_map.find(key);
        if (it != m_map.end() && it->second.valid)
            return &it->second;
        return nullptr;
    }

    // Register a compiled block
    void insert(const JitBlock& blk) {
        uint32_t key = blk.armPc ^ (blk.isThumb ? 1 : 0);
        m_map[key] = blk;
    }

    // Invalidate blocks overlapping [start, end)
    void invalidateRange(uint32_t start, uint32_t end) {
        for (auto& kv : m_map) {
            if (kv.second.armPc >= start && kv.second.armPc < end) {
                kv.second.valid = false;
            }
        }
    }

    void flush() {
        m_map.clear();
        m_writePtr = (uint32_t*)m_mem;
        // Reset cache to NOPs
        memset(m_mem, 0x60, kCacheBytes);
    }

    uint8_t* base() const { return m_mem; }

private:
    uint8_t*  m_mem      = nullptr;
    uint32_t* m_writePtr = nullptr;
    uint32_t* m_endPtr   = nullptr;
    std::unordered_map<uint32_t, JitBlock> m_map;
};

static JitCache g_jitCache[2]; // one per CPU

// ---------------------------------------------------------------------------
// ARM register mapping to PPC registers
// ARM R0-R14 -> PPC r14-r28 (non-volatile)
// ARM R15 (PC) is handled specially (stored in interpreter state)
// ---------------------------------------------------------------------------
static inline int armToPpcReg(int armReg) {
    // R0 -> r14, R1 -> r15, ..., R14 -> r28
    return PPC_REG_ARM_BASE + armReg;
}

// Scratch volatile PPC registers for use within JIT sequences
// (These are clobbered by calls; safe to use between calls)
static constexpr int SCRATCH0 = 3;  // r3 (also arg/return)
static constexpr int SCRATCH1 = 4;  // r4
static constexpr int SCRATCH2 = 5;  // r5
static constexpr int SCRATCH3 = 6;  // r6
static constexpr int SCRATCH4 = 7;  // r7
static constexpr int SCRATCH5 = 8;  // r8

// ---------------------------------------------------------------------------
// ARM CPSR flag management in JIT context
//
// Strategy: Keep CPSR value in PPC r29 (PPC_REG_CPSR).
// When flags change, update r29.
// N = bit31, Z = bit30, C = bit29, V = bit28
//
// For condition checks, extract the relevant bits from r29.
// ---------------------------------------------------------------------------

// Emit code to extract N flag into CR0_LT of CR0
// (sets CR0 bit 0 = sign of r29 >> 31)
static void emitExtractN(Emitter& e, int tmpReg) {
    e.emit(ppc_srawi(tmpReg, PPC_REG_CPSR, 31)); // tmpReg = N flag (all bits = N)
    e.emit(ppc_cmpi(0, tmpReg, 0)); // CR0: tmpReg vs 0 -> LT if N=1 (since srawi makes -1 or 0)
}

// ---------------------------------------------------------------------------
// ARM condition evaluation
// Returns: emit code that branches around the instruction body if condition fails
// Returns number of "patch" locations (words in output that need fixup)
// ---------------------------------------------------------------------------

// We evaluate ARM conditions by reading CPSR flags from r29
// and using PPC compare/branch.
//
// Returns the offset (in words from block start) of the branch instruction
// that needs its displacement patched once the body is emitted.
// Returns -1 if condition is AL (always, no branch needed).
// Returns -2 if condition is NV (never — emit nothing).

struct CondBranch {
    uint32_t* patchWord;  // pointer to branch instruction to patch
    int       count;      // number of patch words (0, 1, or 2)
};

static CondBranch emitCondCheck(Emitter& e, int cond) {
    CondBranch result = {nullptr, 0};

    if (cond == COND_AL) return result; // always execute
    if (cond == COND_NV) {
        // Never: emit an unconditional branch past body (will be patched)
        result.patchWord = e.buf;
        e.emit(ppc_b(0)); // placeholder
        result.count = 1;
        return result;
    }

    // Extract CPSR flags into scratch registers
    // N=bit31, Z=bit30, C=bit29, V=bit28
    int cpsrReg = PPC_REG_CPSR;

    switch (cond) {
        case COND_EQ: // Z=1
            // rlwinm SCRATCH0, cpsrReg, 2, 31, 31  -> bit 30 -> bit 0
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 2, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0)); // EQ if Z=1
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // branch if Z=1 -> will be: branch if NOT EQ to skip
            // We want to SKIP if Z=0, so branch if SCRATCH0 == 0
            // Rewrite: beq means branch if CR0_EQ set, but we set by cmpi==0
            // If SCRATCH0(Z)=0 then cmpi says EQ, and we want to SKIP
            // So: if SCRATCH0=0 (Z=0), skip body
            result.count = 1;
            break;

        case COND_NE: // Z=0
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 2, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_bne(0)); // skip if Z=1 (SCRATCH0 != 0)
            result.count = 1;
            break;

        case COND_CS: // C=1
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 3, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if C=0
            result.count = 1;
            break;

        case COND_CC: // C=0
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 3, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_bne(0)); // skip if C=1
            result.count = 1;
            break;

        case COND_MI: // N=1
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 1, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if N=0
            result.count = 1;
            break;

        case COND_PL: // N=0
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 1, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_bne(0)); // skip if N=1
            result.count = 1;
            break;

        case COND_VS: // V=1
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 4, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if V=0
            result.count = 1;
            break;

        case COND_VC: // V=0
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 4, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH0, 0));
            result.patchWord = e.buf;
            e.emit(ppc_bne(0)); // skip if V=1
            result.count = 1;
            break;

        case COND_HI: // C=1 && Z=0
            // Extract C and Z
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 3, 31, 31)); // C in bit0
            e.emit(ppc_rlwinm(SCRATCH1, cpsrReg, 2, 31, 31)); // Z in bit0
            // C=1 && Z=0: SCRATCH0=1 && SCRATCH1=0
            // SCRATCH2 = C & ~Z = SCRATCH0 & ~SCRATCH1
            e.emit(ppc_andc(SCRATCH2, SCRATCH0, SCRATCH1));
            e.emit(ppc_cmpi(0, SCRATCH2, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if HI condition false
            result.count = 1;
            break;

        case COND_LS: // C=0 || Z=1
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 3, 31, 31)); // C
            e.emit(ppc_rlwinm(SCRATCH1, cpsrReg, 2, 31, 31)); // Z
            // LS = !C | Z = ~C | Z
            e.emit(ppc_orc(SCRATCH2, SCRATCH1, SCRATCH0)); // Z | ~C  (orc: ra=rb|~rc)
            e.emit(ppc_andi(SCRATCH2, SCRATCH2, 1));
            e.emit(ppc_cmpi(0, SCRATCH2, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if LS false
            result.count = 1;
            break;

        case COND_GE: // N=V (N==V)
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 1, 31, 31)); // N
            e.emit(ppc_rlwinm(SCRATCH1, cpsrReg, 4, 31, 31)); // V
            e.emit(ppc_xor(SCRATCH2, SCRATCH0, SCRATCH1));
            e.emit(ppc_cmpi(0, SCRATCH2, 0));
            result.patchWord = e.buf;
            e.emit(ppc_bne(0)); // skip if N!=V
            result.count = 1;
            break;

        case COND_LT: // N!=V
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 1, 31, 31));
            e.emit(ppc_rlwinm(SCRATCH1, cpsrReg, 4, 31, 31));
            e.emit(ppc_xor(SCRATCH2, SCRATCH0, SCRATCH1));
            e.emit(ppc_cmpi(0, SCRATCH2, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if N==V
            result.count = 1;
            break;

        case COND_GT: // Z=0 && N==V
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 1, 31, 31)); // N
            e.emit(ppc_rlwinm(SCRATCH1, cpsrReg, 4, 31, 31)); // V
            e.emit(ppc_rlwinm(SCRATCH2, cpsrReg, 2, 31, 31)); // Z
            e.emit(ppc_xor(SCRATCH3, SCRATCH0, SCRATCH1));     // N^V
            e.emit(ppc_or(SCRATCH3, SCRATCH3, SCRATCH2));       // (N^V)|Z
            e.emit(ppc_cmpi(0, SCRATCH3, 0));
            result.patchWord = e.buf;
            e.emit(ppc_bne(0)); // skip if GT false
            result.count = 1;
            break;

        case COND_LE: // Z=1 || N!=V
            e.emit(ppc_rlwinm(SCRATCH0, cpsrReg, 1, 31, 31)); // N
            e.emit(ppc_rlwinm(SCRATCH1, cpsrReg, 4, 31, 31)); // V
            e.emit(ppc_rlwinm(SCRATCH2, cpsrReg, 2, 31, 31)); // Z
            e.emit(ppc_xor(SCRATCH3, SCRATCH0, SCRATCH1));
            e.emit(ppc_or(SCRATCH3, SCRATCH3, SCRATCH2));
            e.emit(ppc_cmpi(0, SCRATCH3, 0));
            result.patchWord = e.buf;
            e.emit(ppc_beq(0)); // skip if LE false
            result.count = 1;
            break;

        default:
            break;
    }
    return result;
}

// Patch a branch instruction to jump to current emit position
static void patchBranch(Emitter& e, uint32_t* patchWord) {
    if (!patchWord) return;
    ptrdiff_t diff = ((uint8_t*)e.buf - (uint8_t*)patchWord);
    // Encode displacement in BC or B instruction
    uint32_t insn = *patchWord;
    uint32_t opcode = insn >> 26;
    if (opcode == 18) { // B-form
        *patchWord = (insn & 0xFC000003u) | ((diff & 0x3FFFFFC));
    } else { // BC-form (opcode 16)
        *patchWord = (insn & 0xFFFF0003u) | ((diff & 0xFFFC));
    }
}

// ---------------------------------------------------------------------------
// ARM barrel shifter helpers
// Generate PPC code to compute shifted operand.
// Result in destReg; carry-out (if S bit) in SCRATCH5 bit 0.
// ---------------------------------------------------------------------------

// Decode shift type and amount from opcode
// Returns shifted value in destReg; sets carry in SCRATCH5 if setCarry=true

static void emitShiftedReg(Emitter& e, uint32_t opcode, int destReg, bool setCarry) {
    // Bits [11:4] of ARM opcode encode shift
    int rm   = (opcode >> 0) & 0xF;
    int type = (opcode >> 5) & 0x3;  // 0=LSL,1=LSR,2=ASR,3=ROR
    bool regShift = (opcode >> 4) & 1;
    int ppcRm = (rm == 15) ? SCRATCH4 : armToPpcReg(rm);

    if (regShift) {
        // Shift amount in register Rs
        int rs = (opcode >> 8) & 0xF;
        int ppcRs = armToPpcReg(rs);
        // Clamp shift amount to 0..31 (or 0..32 for LSR/ASR)
        e.emit(ppc_andi(SCRATCH2, ppcRs, 0xFF)); // use bottom byte of Rs
        switch (type) {
            case 0: // LSL by register
                // if shift >= 32, result = 0; carry = bit(32-shift) of Rm
                e.emit(ppc_cmpi(0, SCRATCH2, 32));
                if (setCarry) {
                    // carry = (shift==0) ? C : bit(32-shift) of Rm, 0 if shift>32
                    // Simplified: carry = (Rm << (shift-1)) >> 31 when shift in [1,32]
                    // if shift == 0: carry unchanged
                    // We'll use: carry = (shift > 0 && shift <= 32) ? (Rm >> (32-shift)) & 1 : 0
                    e.emit(ppc_li(SCRATCH5, 0)); // default carry = 0
                    // Compute 32 - shift -> SCRATCH3
                    e.emit(ppc_subfic(SCRATCH3, SCRATCH2, 32)); // SCRATCH3 = 32 - shift
                    e.emit(ppc_srw(SCRATCH5, ppcRm, SCRATCH3));  // Rm >> (32-shift)
                    e.emit(ppc_andi(SCRATCH5, SCRATCH5, 1));
                    // If shift == 0, carry = existing C from CPSR
                    e.emit(ppc_cmpi(0, SCRATCH2, 0));
                    // (we leave carry as computed; shift==0 case not perfectly handled here
                    //  for simplicity — in practice shift==0 falls to imm path)
                }
                // if shift >= 32, result = 0
                {
                    uint32_t* patch = e.buf;
                    e.emit(ppc_bc(4, CR0_EQ, 0)); // branch if not EQ (shift != 32 exact; handle >= 32)
                    e.emit(ppc_slw(destReg, ppcRm, SCRATCH2));
                    uint32_t* patch2 = e.buf;
                    e.emit(ppc_b(0)); // skip zero-out
                    patchBranch(e, patch);
                    e.emit(ppc_li(destReg, 0));
                    patchBranch(e, patch2);
                }
                break;

            case 1: // LSR by register
                e.emit(ppc_cmpi(0, SCRATCH2, 32));
                if (setCarry) {
                    e.emit(ppc_li(SCRATCH5, 0));
                    e.emit(ppc_addi(SCRATCH3, SCRATCH2, -1)); // shift-1
                    e.emit(ppc_srw(SCRATCH5, ppcRm, SCRATCH3));
                    e.emit(ppc_andi(SCRATCH5, SCRATCH5, 1));
                }
                {
                    uint32_t* patch = e.buf;
                    e.emit(ppc_bc(4, CR0_EQ, 0));
                    e.emit(ppc_srw(destReg, ppcRm, SCRATCH2));
                    uint32_t* patch2 = e.buf;
                    e.emit(ppc_b(0));
                    patchBranch(e, patch);
                    e.emit(ppc_li(destReg, 0));
                    patchBranch(e, patch2);
                }
                break;

            case 2: // ASR by register
                e.emit(ppc_cmpi(0, SCRATCH2, 32));
                if (setCarry) {
                    e.emit(ppc_li(SCRATCH5, 0));
                    e.emit(ppc_addi(SCRATCH3, SCRATCH2, -1));
                    e.emit(ppc_sraw(SCRATCH5, ppcRm, SCRATCH3));
                    e.emit(ppc_andi(SCRATCH5, SCRATCH5, 1));
                }
                {
                    // if shift >= 32, result = sign extension
                    uint32_t* patch = e.buf;
                    e.emit(ppc_bc(4, CR0_EQ, 0)); // if shift != 32
                    e.emit(ppc_sraw(destReg, ppcRm, SCRATCH2));
                    uint32_t* patch2 = e.buf;
                    e.emit(ppc_b(0));
                    patchBranch(e, patch);
                    e.emit(ppc_srawi(destReg, ppcRm, 31)); // arithmetic shift by 31
                    patchBranch(e, patch2);
                }
                break;

            case 3: // ROR by register
                e.emit(ppc_andi(SCRATCH2, SCRATCH2, 31)); // ROR is mod 32
                // PPC has no ROR, but: ROR Rm, n = (Rm >> n) | (Rm << (32-n))
                e.emit(ppc_subfic(SCRATCH3, SCRATCH2, 32));
                e.emit(ppc_srw(SCRATCH4, ppcRm, SCRATCH2));
                e.emit(ppc_slw(SCRATCH1, ppcRm, SCRATCH3));
                e.emit(ppc_or(destReg, SCRATCH4, SCRATCH1));
                if (setCarry) {
                    e.emit(ppc_rlwinm(SCRATCH5, destReg, 0, 31, 31)); // bit 31 -> bit 31, but extract...
                    e.emit(ppc_srwi_alias: // there's no srwi alias yet
                    // use srawi: extract bit31
                    );
                    e.emit(ppc_rlwinm(SCRATCH5, destReg, 1, 31, 31)); // top bit -> bit 0
                }
                break;
        }
    } else {
        // Immediate shift amount
        int shiftAmt = (opcode >> 7) & 0x1F;
        switch (type) {
            case 0: // LSL #imm
                if (shiftAmt == 0) {
                    if (rm != 15) e.emit(ppc_mr(destReg, ppcRm));
                    else e.emit(ppc_mr(destReg, SCRATCH4)); // PC+8
                    if (setCarry) {
                        // carry = existing C bit
                        e.emit(ppc_rlwinm(SCRATCH5, PPC_REG_CPSR, 3, 31, 31));
                    }
                } else {
                    e.emit(ppc_rlwinm(destReg, ppcRm, shiftAmt, 0, 31-shiftAmt));
                    if (setCarry) {
                        // carry = bit (32-shiftAmt) of Rm
                        e.emit(ppc_rlwinm(SCRATCH5, ppcRm, shiftAmt, 31, 31));
                    }
                }
                break;

            case 1: // LSR #imm (0 means 32)
                if (shiftAmt == 0) {
                    // LSR #32: result=0, carry=bit31 of Rm
                    e.emit(ppc_li(destReg, 0));
                    if (setCarry)
                        e.emit(ppc_rlwinm(SCRATCH5, ppcRm, 1, 31, 31));
                } else {
                    e.emit(ppc_rlwinm(destReg, ppcRm, 32-shiftAmt, shiftAmt, 31));
                    if (setCarry)
                        e.emit(ppc_rlwinm(SCRATCH5, ppcRm, 32-shiftAmt+1, 31, 31));
                }
                break;

            case 2: // ASR #imm (0 means 32)
                if (shiftAmt == 0) {
                    // ASR #32: result=sign, carry=bit31 of Rm
                    e.emit(ppc_srawi(destReg, ppcRm, 31));
                    if (setCarry)
                        e.emit(ppc_rlwinm(SCRATCH5, ppcRm, 1, 31, 31));
                } else {
                    e.emit(ppc_srawi(destReg, ppcRm, shiftAmt));
                    if (setCarry)
                        e.emit(ppc_rlwinm(SCRATCH5, ppcRm, shiftAmt == 1 ? 32 : 32-shiftAmt+1, 31, 31));
                }
                break;

            case 3: // ROR #imm (0 = RRX)
                if (shiftAmt == 0) {
                    // RRX: rotate right through carry
                    // result = (C << 31) | (Rm >> 1)
                    e.emit(ppc_rlwinm(SCRATCH3, PPC_REG_CPSR, 3, 31, 31)); // C bit -> bit0
                    if (setCarry)
                        e.emit(ppc_rlwinm(SCRATCH5, ppcRm, 0, 31, 31));    // old bit0 = carry
                    e.emit(ppc_rlwinm(SCRATCH3, SCRATCH3, 31, 0, 0));       // C << 31
                    e.emit(ppc_rlwinm(destReg, ppcRm, 0, 1, 31));           // Rm >> 1 = rlwinm rd,rs,31,1,31 ? no
                    // srwi 1
                    e.emit(ppc_rlwinm(destReg, ppcRm, 31, 1, 31));
                    e.emit(ppc_or(destReg, destReg, SCRATCH3));
                } else {
                    // ROR #shiftAmt
                    // (Rm >> shiftAmt) | (Rm << (32-shiftAmt))
                    e.emit(ppc_rlwinm(SCRATCH3, ppcRm, 32-shiftAmt, 0, shiftAmt-1)); // high part
                    e.emit(ppc_rlwinm(destReg,  ppcRm, 32-shiftAmt, shiftAmt, 31)); // low part
                    // Actually rlwinm can do rotation directly:
                    // rlwinm destReg, ppcRm, 32-shiftAmt, 0, 31 = ROR by shiftAmt
                    e.emit(ppc_rlwinm(destReg, ppcRm, 32-shiftAmt, 0, 31));
                    if (setCarry)
                        e.emit(ppc_rlwinm(SCRATCH5, destReg, 1, 31, 31)); // bit31 -> bit0
                }
                break;
        }
    }
}

// Emit code to load ARM immediate (rotated immediate from opcode bits [11:0])
// Result in destReg; if setCarry, carry in SCRATCH5 bit0
static void emitImmediate(Emitter& e, uint32_t opcode, int destReg, bool setCarry) {
    uint32_t imm8  = opcode & 0xFF;
    uint32_t rot   = ((opcode >> 8) & 0xF) * 2;
    uint32_t value = (rot == 0) ? imm8 : ((imm8 >> rot) | (imm8 << (32 - rot)));
    e.li32(destReg, value);
    if (setCarry) {
        if (rot == 0) {
            // Carry unchanged
            e.emit(ppc_rlwinm(SCRATCH5, PPC_REG_CPSR, 3, 31, 31));
        } else {
            // Carry = bit31 of rotated value
            e.emit(ppc_li(SCRATCH5, (value >> 31) & 1));
        }
    }
}

// ---------------------------------------------------------------------------
// CPSR flag update helpers
// After an arithmetic or logical operation, update r29 (CPSR) flags.
// ---------------------------------------------------------------------------

// Update N and Z flags based on result in resultReg
// N = bit31 of result, Z = (result == 0)
// Clobbers SCRATCH0
static void emitUpdateNZ(Emitter& e, int resultReg) {
    // Clear N and Z bits in CPSR (bits 31 and 30)
    e.emit(ppc_rlwinm(PPC_REG_CPSR, PPC_REG_CPSR, 0, 2, 31)); // clear bits 31,30,29,28? no
    // Clear N (bit31) and Z (bit30)
    // Mask: ~(CPSR_N | CPSR_Z) = ~0xC0000000
    // Use: rlwinm to clear top 2 bits (rotate 0, mb=2, me=31 keeps bits 0-29)
    // Actually: clear bits 31 and 30:
    e.emit(ppc_rlwinm(PPC_REG_CPSR, PPC_REG_CPSR, 0, 2, 31)); // keep bits 0..29

    // Set N = bit31 of resultReg
    e.emit(ppc_rlwinm(SCRATCH0, resultReg, 0, 0, 0)); // isolate bit31 -> SCRATCH0
    e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH0)); // set N

    // Set Z = (resultReg == 0)
    e.emit(ppc_cmpi(0, resultReg, 0));
    uint32_t* skipZ = e.buf;
    e.emit(ppc_bne(0)); // if not zero, don't set Z
    e.emit(ppc_oris(PPC_REG_CPSR, PPC_REG_CPSR, 0x4000)); // set bit30 (Z)
    patchBranch(e, skipZ);
}

// Update C flag from carry (SCRATCH5 bit0)
static void emitUpdateC(Emitter& e) {
    // Clear C bit (bit29) in CPSR
    e.emit(ppc_rlwinm(PPC_REG_CPSR, PPC_REG_CPSR, 0, 0, 29)); // keep bits [31:30] and [28:0]
    // Hmm, rlwinm(ra, rs, sh, mb, me): rotate left by sh, then mask mb..me
    // To clear bit29: we need to zero bit29, keep everything else
    // = rlwinm(CPSR, CPSR, 0, 0, 28) would keep bits 0-28, but clears 29-31 too
    // Better approach: use andi with mask
    // CPSR & ~CPSR_C:
    //   CPSR_C = 0x20000000 = bit29
    //   ~CPSR_C upper 16 = 0xDFFF, lower 16 = 0xFFFF
    e.emit(ppc_rlwinm(PPC_REG_CPSR, PPC_REG_CPSR, 0, 0, 28)); // clear bits 29,30,31... wrong
    // We need a proper bit clear. Let's use a different approach:
    // Save N,Z,V, reinsert C
    // Actually let's just use:
    // CPSR = (CPSR & ~0x20000000) | (carry << 29)
    // Implement with:
    //   rlwinm SCRATCH0, CPSR, 0, 0, 28  -- but this clears bits 29,30,31... too broad
    //
    // Correct approach: clear just bit 29
    //   rlwinm dest, src, sh, mb, me clears bits outside [mb,me] after rotation
    //   To clear just bit 29 of a 32-bit value, keeping all others:
    //   We can't do it in one rlwinm alone.
    //   Use: and CPSR, CPSR, mask_reg
    //   Where mask_reg = ~CPSR_C = ~(1<<29)

    // Use SCRATCH0 as mask
    e.li32(SCRATCH0, ~CPSR_C);
    e.emit(ppc_and(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH0));

    // Shift carry bit into position 29: SCRATCH5 bit0 << 29
    e.emit(ppc_rlwinm(SCRATCH5, SCRATCH5, 29, 29, 29));
    e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH5));
}

// Update V flag from overflow (SCRATCH4 bit0 or from XER SO)
static void emitUpdateV(Emitter& e, int vBit0Reg) {
    e.li32(SCRATCH0, ~CPSR_V);
    e.emit(ppc_and(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH0));
    e.emit(ppc_rlwinm(vBit0Reg, vBit0Reg, 28, 28, 28));
    e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, vBit0Reg));
}

// Update N, Z, C, V from a PPC add that set XER (use addo/subfo)
// XER: OV=bit1, CA=bit2, SO=bit0
// After addo/subfo:
//   N = result bit31
//   Z = result == 0
//   C = XER[CA] (bit 29 of XER, or bit 2 of low byte)
//   V = XER[OV]
static void emitUpdateNZCV_fromALU(Emitter& e, int resultReg) {
    emitUpdateNZ(e, resultReg);

    // Extract C and V from XER
    e.emit(ppc_mfxer(SCRATCH0));
    // XER layout (32-bit): SO[31] OV[30] CA[29] ...
    // CA is bit29, OV is bit30, SO is bit31

    // Update C from XER[CA] (bit29)
    e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31)); // CA -> bit0
    emitUpdateC(e);

    // Update V from XER[OV] (bit30)
    e.emit(ppc_rlwinm(SCRATCH4, SCRATCH0, 2, 31, 31)); // OV -> bit0
    emitUpdateV(e, SCRATCH4);
}

// ---------------------------------------------------------------------------
// Spill/Restore ARM registers to/from interpreter state
// The Interpreter object layout (via pointers):
// We need to access registersUsr[0..15] from the Interpreter*.
// Since registersUsr is private, we use the fact that registers[] points to them.
//
// Actually: we pass register values in PPC non-volatile regs r14-r28.
// Before calling any C++ function that might access ARM registers through
// the interpreter, we must spill them back. After returning, reload.
//
// We define a "register save area" in the interpreter object.
// In practice, since registers[] is an array of uint32_t*, each registers[i]
// points to the actual register storage. We need to write through those pointers.
//
// For simplicity: we call a helper that saves/restores registers.
// ---------------------------------------------------------------------------

// Offsets of Interpreter fields (computed at runtime from a test object)
// We use a dedicated save/restore stub instead of hardcoding offsets.

// Forward declare the save/restore stubs
extern "C" void jit_saveArmRegs(Interpreter* interp, uint32_t* regs);
extern "C" void jit_loadArmRegs(Interpreter* interp, uint32_t* regs);

// We keep a flat array of 16 uint32_t alongside the JIT for register spill
// (This is the "JIT register file" — a shadow copy for helper calls)
struct JitRegFile {
    uint32_t r[16];   // ARM R0-R15
    uint32_t cpsr;
};

// One reg file per CPU
static JitRegFile g_regFile[2];

// Save r14-r28 (ARM R0-R14) to g_regFile, r29 (CPSR) to cpsr
// PC is passed separately
static void emitSpillRegisters(Emitter& e, int cpuIdx, uint32_t pc) {
    // Store ARM R0-R14 (PPC r14-r28) into g_regFile[cpuIdx].r[0..14]
    JitRegFile* rf = &g_regFile[cpuIdx];
    uintptr_t base = (uintptr_t)rf;

    // Load base address
    e.li32(SCRATCH0, (uint32_t)base);
    for (int i = 0; i < 15; i++) {
        e.emit(ppc_stw(armToPpcReg(i), SCRATCH0, (int32_t)(i * 4)));
    }
    // Store PC
    e.li32(SCRATCH1, pc);
    e.emit(ppc_stw(SCRATCH1, SCRATCH0, 15 * 4));
    // Store CPSR
    e.emit(ppc_stw(PPC_REG_CPSR, SCRATCH0, 16 * 4));
}

static void emitReloadRegisters(Emitter& e, int cpuIdx) {
    JitRegFile* rf = &g_regFile[cpuIdx];
    uintptr_t base = (uintptr_t)rf;
    e.li32(SCRATCH0, (uint32_t)base);
    for (int i = 0; i < 15; i++) {
        e.emit(ppc_lwz(armToPpcReg(i), SCRATCH0, (int32_t)(i * 4)));
    }
    e.emit(ppc_lwz(PPC_REG_CPSR, SCRATCH0, 16 * 4));
}

// ---------------------------------------------------------------------------
// ARM instruction translators
// Each emits PPC instructions into the emitter for one ARM instruction.
// Returns the number of ARM cycles consumed (approx).
// Returns -1 to signal "bail out to interpreter" for complex instructions.
// ---------------------------------------------------------------------------

// Get PPC register for ARM register Rn (handles R15 specially)
// If R15 (PC) is needed, loads PC+8 into a scratch reg and returns that reg number.
static int getArmReg(Emitter& e, int armReg, uint32_t pc, int scratchReg = SCRATCH4) {
    if (armReg == 15) {
        e.li32(scratchReg, pc + 8); // ARM pipeline: PC = current + 8
        return scratchReg;
    }
    return armToPpcReg(armReg);
}

// Get destination PPC register for ARM Rd
// Returns the PPC reg to write result into
static int getDestReg(int rd) {
    if (rd == 15) return SCRATCH4; // PC writes need special handling
    return armToPpcReg(rd);
}

// After writing to rd, handle PC writeback if rd==15
static void emitWriteback(Emitter& e, int rd, int ppcDest, uint32_t& blockEndPc, bool& blockEnds) {
    if (rd == 15) {
        // PC has been written to SCRATCH4; this ends the block
        // Store the new PC somewhere (we'll return to dispatch)
        // For now, we just mark block as ending
        // The new PC is in SCRATCH4; store to regFile[15]
        blockEnds = true;
        blockEndPc = 0; // dynamic PC
    }
}

// ---- Data Processing Instructions ----

// Emit AND / ANDS
static int emitAnd(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;

    if (isImm) {
        // Immediate operand
        uint32_t imm8 = opcode & 0xFF;
        uint32_t rot  = ((opcode >> 8) & 0xF) * 2;
        uint32_t imm  = (rot == 0) ? imm8 : ((imm8 >> rot) | (imm8 << (32 - rot)));
        e.li32(SCRATCH1, imm);
        e.emit(ppc_and(pRd, pRn, SCRATCH1, setFlags));
        if (setFlags) {
            if (rot != 0) e.emit(ppc_li(SCRATCH5, (imm >> 31) & 1)); // carry
            else          e.emit(ppc_rlwinm(SCRATCH5, PPC_REG_CPSR, 3, 31, 31));
            emitUpdateNZ(e, pRd);
            emitUpdateC(e);
        }
    } else {
        emitShiftedReg(e, opcode, SCRATCH1, setFlags);
        e.emit(ppc_and(pRd, pRn, SCRATCH1, false));
        if (setFlags) {
            emitUpdateNZ(e, pRd);
            emitUpdateC(e);
            // V is unchanged for logical ops
        }
    }
    return 1;
}

// Emit EOR / EORS
static int emitEor(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) {
        emitImmediate(e, opcode, SCRATCH1, setFlags);
        e.emit(ppc_xor(pRd, pRn, SCRATCH1));
    } else {
        emitShiftedReg(e, opcode, SCRATCH1, setFlags);
        e.emit(ppc_xor(pRd, pRn, SCRATCH1));
    }
    if (setFlags) {
        emitUpdateNZ(e, pRd);
        emitUpdateC(e);
    }
    return 1;
}

// Emit SUB / SUBS
static int emitSub(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) {
        emitImmediate(e, opcode, SCRATCH1, false);
    } else {
        emitShiftedReg(e, opcode, SCRATCH1, false);
    }

    if (setFlags) {
        // ARM SUB sets C = NOT borrow = (Rn >= op2 unsigned)
        // Use subfc: subf and set CA
        // subfc rd, ra, rb: rd = rb - ra (not ra - rb!)
        // We want: rd = Rn - op2 = Rn - SCRATCH1
        // so: subfc rd, SCRATCH1, pRn  -> rd = pRn - SCRATCH1
        e.emit(ppc_subfc(pRd, SCRATCH1, pRn, false)); // pRd = pRn - SCRATCH1
        emitUpdateNZ(e, pRd);
        // C (ARM) = NOT borrow = XER.CA
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31)); // XER.CA -> bit0
        emitUpdateC(e);
        // V = overflow: (Rn >= 0 && op2 < 0 && rd < 0) || (Rn < 0 && op2 >= 0 && rd >= 0)
        // Use subfo for V
        e.emit(ppc_subfo(SCRATCH3, SCRATCH1, pRn, false)); // same computation, sets XER.OV
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH4, SCRATCH0, 2, 31, 31)); // XER.OV -> bit0
        emitUpdateV(e, SCRATCH4);
    } else {
        e.emit(ppc_subf(pRd, SCRATCH1, pRn)); // pRd = pRn - SCRATCH1
    }
    return 1;
}

// Emit RSB / RSBS (reverse subtract: rd = op2 - Rn)
static int emitRsb(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) {
        emitImmediate(e, opcode, SCRATCH1, false);
    } else {
        emitShiftedReg(e, opcode, SCRATCH1, false);
    }

    if (setFlags) {
        // rd = SCRATCH1 - pRn = subf rd, pRn, SCRATCH1
        e.emit(ppc_subfc(pRd, pRn, SCRATCH1, false));
        emitUpdateNZ(e, pRd);
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
        emitUpdateC(e);
        e.emit(ppc_subfo(SCRATCH3, pRn, SCRATCH1, false));
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH4, SCRATCH0, 2, 31, 31));
        emitUpdateV(e, SCRATCH4);
    } else {
        e.emit(ppc_subf(pRd, pRn, SCRATCH1)); // rd = SCRATCH1 - pRn
    }
    return 1;
}

// Emit ADD / ADDS
static int emitAdd(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) {
        emitImmediate(e, opcode, SCRATCH1, false);
    } else {
        emitShiftedReg(e, opcode, SCRATCH1, false);
    }

    if (setFlags) {
        e.emit(ppc_addc(pRd, pRn, SCRATCH1, false)); // sets XER.CA
        emitUpdateNZ(e, pRd);
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
        emitUpdateC(e);
        e.emit(ppc_addo(SCRATCH3, pRn, SCRATCH1, false)); // sets XER.OV
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH4, SCRATCH0, 2, 31, 31));
        emitUpdateV(e, SCRATCH4);
    } else {
        e.emit(ppc_add(pRd, pRn, SCRATCH1));
    }
    return 1;
}

// Emit ADC / ADCS (add with carry)
static int emitAdc(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, false);
    else       emitShiftedReg(e, opcode, SCRATCH1, false);

    // Extract ARM carry into XER.CA for PPC adde
    // XER.CA is set by addic/subfc; we need to prime it from CPSR.C
    // CPSR.C is bit29 of r29
    e.emit(ppc_rlwinm(SCRATCH2, PPC_REG_CPSR, 3, 31, 31)); // C -> bit0
    // Use addic to set XER.CA: addic rd, SCRATCH2, -1 will set CA if SCRATCH2 != 0
    // Actually, to load carry into XER: subfic r0, SCRATCH2, 0 sets CA = (SCRATCH2 == 0)
    // which is NOT carry. We need CA = SCRATCH2.
    // subfic r0, r0, 0: CA = (r0 == 0) -- no
    // Method: addic sets CA iff result < 0 (unsigned overflow)
    // To set CA = C: if C=1, we want CA=1.
    //   addi SCRATCH3, SCRATCH2, -1 -> if C=1: SCRATCH3=0, CA... no
    //   Use: subfic SCRATCH0, SCRATCH2, 1  -> 1-SCRATCH2, CA = (SCRATCH2 <= 1) if unsigned
    // Simplest: negate then addc
    // SCRATCH2 = C (0 or 1)
    // subfic SCRATCH0, SCRATCH2, 0 -> result = -SCRATCH2, CA = (SCRATCH2==0) ? 0 : 1 when subtracted from 0... 
    // Actually subfic rd, ra, SIMM: rd = SIMM - ra, CA = (SIMM >= ra unsigned)
    // subfic SCRATCH0, SCRATCH2, 0: rd = 0 - SCRATCH2, CA = (0 >= SCRATCH2)
    //   if SCRATCH2=0: CA=1 (wrong, we want CA=0)
    //   if SCRATCH2=1: CA=0 (wrong, we want CA=1)
    // So: negate: subfic SCRATCH0, SCRATCH2, 0 gives CA = NOT C
    // Then adde will add 1 when CA=1, which is when C=0. Wrong.
    // We need: adde rd, ra, rb uses XER.CA directly.
    // To prime XER.CA = ARM_C:
    //   if ARM_C=0: addic SCRATCH0, r0, 0 -- r0=0, so addic r0,r0,0: CA = 0 (no carry from 0+0)... 
    //      but r0 might not be 0.
    //   Cleanest: li SCRATCH0, 0; addic SCRATCH0, SCRATCH0, 0 -> CA=0
    //             if ARM_C: addi SCRATCH0, 0, 0xFFFF; addic SCRATCH0, SCRATCH0, 1 -> CA=1
    // Pragmatic approach: use conditional
    e.emit(ppc_cmpi(0, SCRATCH2, 0));
    {
        // Prime XER.CA based on C flag
        uint32_t* patchNoC = e.buf;
        e.emit(ppc_beq(0)); // if C=0, set CA=0 path
        // C=1: addic r0, r0, 0 with carry: subfic sets CA=1 nicely with -1+1 
        // Use: addic SCRATCH0, r0, -1 where r0 must be 0... unreliable.
        // Better: subfc rd, rd, rd: rd=0, CA=1 (0-0 with borrow=0) wait...
        // subfc rd, ra, rb: rd = rb - ra, CA = (rb >= ra unsigned)
        // subfc SCRATCH0, SCRATCH0, SCRATCH0: SCRATCH0=0, CA = (SCRATCH0>=SCRATCH0) = 1... let's try
        // Actually: for subfc, CA is set based on the complement: CA = NOT borrow = 1 iff rb >= ra
        // subfc SCRATCH0, SCRATCH0, SCRATCH0: 0 - 0 = 0, no borrow -> CA = 1. Yes!
        e.emit(ppc_subfc(SCRATCH0, SCRATCH0, SCRATCH0)); // CA = 1
        uint32_t* patchEnd = e.buf;
        e.emit(ppc_b(0));
        patchBranch(e, patchNoC);
        // C=0: need CA=0
        // addic SCRATCH0, SCRATCH0, 0: doesn't change CA
        // addic with value that won't overflow: li 0, 0; addic 0, 0, 0 -> CA=0 if r0=0
        // Simplest: subfic SCRATCH0, r0, 0 where r0=0 gives CA=1... no
        // Use: li SCRATCH0, 1; addic SCRATCH0, SCRATCH0, -1 -> 1+(-1)=0, no carry -> CA=0
        e.emit(ppc_li(SCRATCH0, 1));
        e.emit(ppc_addic(SCRATCH0, SCRATCH0, -1)); // CA = 0
        patchBranch(e, patchEnd);
    }

    // Now XER.CA = ARM carry. Use adde.
    if (setFlags) {
        e.emit(ppc_adde(pRd, pRn, SCRATCH1, false));
        emitUpdateNZ(e, pRd);
        // New carry from XER.CA
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
        emitUpdateC(e);
        // Overflow: use addeo
        // Re-do with addeo for OV flag
        // We already computed result; just need OV
        // We'd need to redo the add... use addeo instead
        // Actually: the adde above didn't set OV. We need addeo.
        // Let's recompute:
        e.emit(ppc_mfxer(SCRATCH0));       // get CA from previous adde
        // reload carry into XER.CA again... this is getting complex
        // For simplicity, compute OV manually:
        // V = (pRn[31] == SCRATCH1[31]) && (pRd[31] != pRn[31])
        e.emit(ppc_rlwinm(SCRATCH0, pRn,   1, 31, 31)); // sign of Rn
        e.emit(ppc_rlwinm(SCRATCH1, SCRATCH1, 1, 31, 31)); // sign of op2 (clobbered!)
        // Oops, SCRATCH1 was op2 but may be clobbered by adde if pRd==SCRATCH1
        // We need to save op2 sign before the adde...
        // This is getting complex; for now emit a simplified V calc
        e.emit(ppc_rlwinm(SCRATCH2, pRd,   1, 31, 31)); // sign of result
        e.emit(ppc_xor(SCRATCH3, SCRATCH0, SCRATCH2)); // Rn.sign != result.sign
        e.emit(ppc_xor(SCRATCH4, SCRATCH1, SCRATCH2)); // op2 sign != result sign... not right for add
        // V = (Rn.sign == op2.sign) && (result.sign != Rn.sign)
        // = ~(Rn.sign ^ op2.sign) & (Rn.sign ^ result.sign)
        e.emit(ppc_xor(SCRATCH0, SCRATCH0, SCRATCH1)); // Rn.sign ^ op2.sign
        e.emit(ppc_nor(SCRATCH0, SCRATCH0, SCRATCH0)); // ~(Rn.sign ^ op2.sign)... nor(x,x) = ~x
        e.emit(ppc_and(SCRATCH4, SCRATCH0, SCRATCH3));
        e.emit(ppc_andi(SCRATCH4, SCRATCH4, 1));
        emitUpdateV(e, SCRATCH4);
    } else {
        e.emit(ppc_adde(pRd, pRn, SCRATCH1));
    }
    return 1;
}

// Emit SBC / SBCS (subtract with carry: rd = Rn - op2 - NOT C)
static int emitSbc(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, false);
    else       emitShiftedReg(e, opcode, SCRATCH1, false);

    // SBC: rd = Rn - op2 - (1-C) = Rn - op2 + C - 1
    // ARM carry convention: C=1 means no borrow
    // PPC subfe: rd = ~ra + rb + XER.CA
    // So: ~SCRATCH1 + pRn + XER.CA
    // We need XER.CA = ARM.C

    // Prime XER.CA = ARM_C (same as ADC)
    e.emit(ppc_rlwinm(SCRATCH2, PPC_REG_CPSR, 3, 31, 31));
    e.emit(ppc_cmpi(0, SCRATCH2, 0));
    {
        uint32_t* patch0 = e.buf; e.emit(ppc_beq(0));
        e.emit(ppc_subfc(SCRATCH0, SCRATCH0, SCRATCH0)); // CA=1
        uint32_t* patch1 = e.buf; e.emit(ppc_b(0));
        patchBranch(e, patch0);
        e.emit(ppc_li(SCRATCH0, 1));
        e.emit(ppc_addic(SCRATCH0, SCRATCH0, -1)); // CA=0
        patchBranch(e, patch1);
    }

    if (setFlags) {
        e.emit(ppc_subfe(pRd, SCRATCH1, pRn)); // pRd = ~SCRATCH1 + pRn + CA = pRn - SCRATCH1 + C - 1... 
        // Wait: subfe rd, ra, rb = ~ra + rb + CA
        // = ~SCRATCH1 + pRn + CA
        // ARM SBC: rd = Rn - op2 - (1-C) = Rn + ~op2 + C = pRn + ~SCRATCH1 + CA  ✓
        emitUpdateNZ(e, pRd);
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
        emitUpdateC(e);
        // V: overflow when subtracting
        e.emit(ppc_rlwinm(SCRATCH0, pRn,    1, 31, 31));
        e.emit(ppc_rlwinm(SCRATCH2, SCRATCH1, 1, 31, 31));
        e.emit(ppc_rlwinm(SCRATCH3, pRd,    1, 31, 31));
        // V = (Rn.sign != op2.sign) && (result.sign != Rn.sign)
        e.emit(ppc_xor(SCRATCH4, SCRATCH0, SCRATCH2)); // sign(Rn) ^ sign(op2)
        e.emit(ppc_xor(SCRATCH5, SCRATCH0, SCRATCH3)); // sign(Rn) ^ sign(result)
        e.emit(ppc_and(SCRATCH4, SCRATCH4, SCRATCH5));
        e.emit(ppc_andi(SCRATCH4, SCRATCH4, 1));
        emitUpdateV(e, SCRATCH4);
    } else {
        e.emit(ppc_subfe(pRd, SCRATCH1, pRn));
    }
    return 1;
}

// Emit RSC (reverse subtract with carry)
static int emitRsc(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, false);
    else       emitShiftedReg(e, opcode, SCRATCH1, false);

    // RSC: rd = op2 - Rn - (1-C) = op2 + ~Rn + C
    // subfe rd, pRn, SCRATCH1 = ~pRn + SCRATCH1 + CA ✓

    e.emit(ppc_rlwinm(SCRATCH2, PPC_REG_CPSR, 3, 31, 31));
    e.emit(ppc_cmpi(0, SCRATCH2, 0));
    {
        uint32_t* p0 = e.buf; e.emit(ppc_beq(0));
        e.emit(ppc_subfc(SCRATCH0, SCRATCH0, SCRATCH0));
        uint32_t* p1 = e.buf; e.emit(ppc_b(0));
        patchBranch(e, p0);
        e.emit(ppc_li(SCRATCH0, 1));
        e.emit(ppc_addic(SCRATCH0, SCRATCH0, -1));
        patchBranch(e, p1);
    }

    if (setFlags) {
        e.emit(ppc_subfe(pRd, pRn, SCRATCH1)); // ~pRn + SCRATCH1 + CA
        emitUpdateNZ(e, pRd);
        e.emit(ppc_mfxer(SCRATCH0));
        e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
        emitUpdateC(e);
        // V flag for reverse subtract
        e.emit(ppc_rlwinm(SCRATCH0, SCRATCH1, 1, 31, 31)); // sign of op2
        e.emit(ppc_rlwinm(SCRATCH2, pRn,      1, 31, 31)); // sign of Rn
        e.emit(ppc_rlwinm(SCRATCH3, pRd,      1, 31, 31)); // sign of result
        e.emit(ppc_xor(SCRATCH4, SCRATCH0, SCRATCH2));
        e.emit(ppc_xor(SCRATCH5, SCRATCH0, SCRATCH3));
        e.emit(ppc_and(SCRATCH4, SCRATCH4, SCRATCH5));
        e.emit(ppc_andi(SCRATCH4, SCRATCH4, 1));
        emitUpdateV(e, SCRATCH4);
    } else {
        e.emit(ppc_subfe(pRd, pRn, SCRATCH1));
    }
    return 1;
}

// Emit TST (AND, set flags only)
static int emitTst(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int pRn = getArmReg(e, rn, pc);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) {
        emitImmediate(e, opcode, SCRATCH1, true);
    } else {
        emitShiftedReg(e, opcode, SCRATCH1, true);
    }
    e.emit(ppc_and(SCRATCH0, pRn, SCRATCH1));
    emitUpdateNZ(e, SCRATCH0);
    emitUpdateC(e);
    return 1;
}

// Emit TEQ (EOR, set flags only)
static int emitTeq(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int pRn = getArmReg(e, rn, pc);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, true);
    else       emitShiftedReg(e, opcode, SCRATCH1, true);

    e.emit(ppc_xor(SCRATCH0, pRn, SCRATCH1));
    emitUpdateNZ(e, SCRATCH0);
    emitUpdateC(e);
    return 1;
}

// Emit CMP (SUB, set flags only)
static int emitCmp(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int pRn = getArmReg(e, rn, pc);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, false);
    else       emitShiftedReg(e, opcode, SCRATCH1, false);

    e.emit(ppc_subfc(SCRATCH0, SCRATCH1, pRn)); // Rn - op2
    emitUpdateNZ(e, SCRATCH0);
    e.emit(ppc_mfxer(SCRATCH2));
    e.emit(ppc_rlwinm(SCRATCH5, SCRATCH2, 3, 31, 31)); // CA
    emitUpdateC(e);
    // OV via subfo
    e.emit(ppc_subfo(SCRATCH3, SCRATCH1, pRn, false));
    e.emit(ppc_mfxer(SCRATCH2));
    e.emit(ppc_rlwinm(SCRATCH4, SCRATCH2, 2, 31, 31));
    emitUpdateV(e, SCRATCH4);
    return 1;
}

// Emit CMN (ADD, set flags only)
static int emitCmn(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int pRn = getArmReg(e, rn, pc);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, false);
    else       emitShiftedReg(e, opcode, SCRATCH1, false);

    e.emit(ppc_addc(SCRATCH0, pRn, SCRATCH1));
    emitUpdateNZ(e, SCRATCH0);
    e.emit(ppc_mfxer(SCRATCH2));
    e.emit(ppc_rlwinm(SCRATCH5, SCRATCH2, 3, 31, 31));
    emitUpdateC(e);
    e.emit(ppc_addo(SCRATCH3, pRn, SCRATCH1, false));
    e.emit(ppc_mfxer(SCRATCH2));
    e.emit(ppc_rlwinm(SCRATCH4, SCRATCH2, 2, 31, 31));
    emitUpdateV(e, SCRATCH4);
    return 1;
}

// Emit ORR / ORRS
static int emitOrr(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, setFlags);
    else       emitShiftedReg(e, opcode, SCRATCH1, setFlags);

    e.emit(ppc_or(pRd, pRn, SCRATCH1));
    if (setFlags) { emitUpdateNZ(e, pRd); emitUpdateC(e); }
    return 1;
}

// Emit MOV / MOVS
static int emitMov(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rd  = (opcode >> 12) & 0xF;
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) {
        emitImmediate(e, opcode, pRd, setFlags);
    } else {
        emitShiftedReg(e, opcode, pRd, setFlags);
    }
    if (setFlags) { emitUpdateNZ(e, pRd); emitUpdateC(e); }
    return 1;
}

// Emit BIC / BICS (bit clear)
static int emitBic(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rn  = (opcode >> 16) & 0xF;
    int rd  = (opcode >> 12) & 0xF;
    int pRn = getArmReg(e, rn, pc);
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, setFlags);
    else       emitShiftedReg(e, opcode, SCRATCH1, setFlags);

    // BIC: rd = Rn & ~op2 = andc rd, Rn, op2
    e.emit(ppc_andc(pRd, pRn, SCRATCH1));
    if (setFlags) { emitUpdateNZ(e, pRd); emitUpdateC(e); }
    return 1;
}

// Emit MVN / MVNS (move not)
static int emitMvn(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rd  = (opcode >> 12) & 0xF;
    int pRd = getDestReg(rd);

    bool isImm = (opcode >> 25) & 1;
    if (isImm) emitImmediate(e, opcode, SCRATCH1, setFlags);
    else       emitShiftedReg(e, opcode, SCRATCH1, setFlags);

    e.emit(ppc_nor(pRd, SCRATCH1, SCRATCH1)); // ~SCRATCH1
    if (setFlags) { emitUpdateNZ(e, pRd); emitUpdateC(e); }
    return 1;
}

// ---- Multiply instructions ----

// Emit MUL (Rd = Rm * Rs)
static int emitMul(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rd = (opcode >> 16) & 0xF;
    int rs = (opcode >> 8)  & 0xF;
    int rm = (opcode >> 0)  & 0xF;
    int pRd = armToPpcReg(rd);
    int pRs = armToPpcReg(rs);
    int pRm = armToPpcReg(rm);

    e.emit(ppc_mullw(pRd, pRm, pRs, false));
    if (setFlags) emitUpdateNZ(e, pRd);
    return 2;
}

// Emit MLA (Rd = Rm * Rs + Rn)
static int emitMla(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rd = (opcode >> 16) & 0xF;
    int rn = (opcode >> 12) & 0xF;
    int rs = (opcode >> 8)  & 0xF;
    int rm = (opcode >> 0)  & 0xF;
    int pRd = armToPpcReg(rd);
    int pRn = armToPpcReg(rn);
    int pRs = armToPpcReg(rs);
    int pRm = armToPpcReg(rm);

    e.emit(ppc_mullw(SCRATCH0, pRm, pRs, false));
    e.emit(ppc_add(pRd, SCRATCH0, pRn));
    if (setFlags) emitUpdateNZ(e, pRd);
    return 2;
}

// Emit UMULL (64-bit unsigned multiply)
static int emitUmull(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rdHi = (opcode >> 16) & 0xF;
    int rdLo = (opcode >> 12) & 0xF;
    int rs   = (opcode >> 8)  & 0xF;
    int rm   = (opcode >> 0)  & 0xF;
    int pRdHi = armToPpcReg(rdHi);
    int pRdLo = armToPpcReg(rdLo);
    int pRs   = armToPpcReg(rs);
    int pRm   = armToPpcReg(rm);

    e.emit(ppc_mulhwu(pRdHi, pRm, pRs)); // hi word
    e.emit(ppc_mullw (pRdLo, pRm, pRs)); // lo word
    if (setFlags) {
        // N = bit31 of hi, Z = (hi==0 && lo==0)
        e.emit(ppc_or(SCRATCH0, pRdHi, pRdLo));
        emitUpdateNZ(e, SCRATCH0);
        // Also update N from hi word
        e.emit(ppc_rlwinm(SCRATCH0, pRdHi, 0, 0, 0)); // bit31 of hi
        e.li32(SCRATCH1, ~CPSR_N);
        e.emit(ppc_and(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH1));
        e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH0));
    }
    return 3;
}

// Emit SMULL (64-bit signed multiply)
static int emitSmull(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, int cpuIdx) {
    int rdHi = (opcode >> 16) & 0xF;
    int rdLo = (opcode >> 12) & 0xF;
    int rs   = (opcode >> 8)  & 0xF;
    int rm   = (opcode >> 0)  & 0xF;
    int pRdHi = armToPpcReg(rdHi);
    int pRdLo = armToPpcReg(rdLo);
    int pRs   = armToPpcReg(rs);
    int pRm   = armToPpcReg(rm);

    e.emit(ppc_mulhw (pRdHi, pRm, pRs));
    e.emit(ppc_mullw (pRdLo, pRm, pRs));
    if (setFlags) {
        e.emit(ppc_or(SCRATCH0, pRdHi, pRdLo));
        emitUpdateNZ(e, SCRATCH0);
        e.emit(ppc_rlwinm(SCRATCH0, pRdHi, 0, 0, 0));
        e.li32(SCRATCH1, ~CPSR_N);
        e.emit(ppc_and(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH1));
        e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH0));
    }
    return 3;
}

// Emit UMLAL / SMLAL (multiply accumulate long)
static int emitUmlal(Emitter& e, uint32_t opcode, uint32_t pc, bool setFlags, bool isSigned, int cpuIdx) {
    int rdHi = (opcode >> 16) & 0xF;
    int rdLo = (opcode >> 12) & 0xF;
    int rs   = (opcode >> 8)  & 0xF;
    int rm   = (opcode >> 0)  & 0xF;
    int pRdHi = armToPpcReg(rdHi);
    int pRdLo = armToPpcReg(rdLo);
    int pRs   = armToPpcReg(rs);
    int pRm   = armToPpcReg(rm);

    // Compute 64-bit product
    if (isSigned) {
        e.emit(ppc_mulhw (SCRATCH0, pRm, pRs)); // product hi (signed)
    } else {
        e.emit(ppc_mulhwu(SCRATCH0, pRm, pRs)); // product hi (unsigned)
    }
    e.emit(ppc_mullw(SCRATCH1, pRm, pRs)); // product lo

    // Add to {RdHi, RdLo}
    e.emit(ppc_addc(pRdLo, pRdLo, SCRATCH1)); // lo + product_lo, sets CA
    e.emit(ppc_adde(pRdHi, pRdHi, SCRATCH0)); // hi + product_hi + CA

    if (setFlags) {
        e.emit(ppc_or(SCRATCH0, pRdHi, pRdLo));
        emitUpdateNZ(e, SCRATCH0);
        e.emit(ppc_rlwinm(SCRATCH0, pRdHi, 0, 0, 0));
        e.li32(SCRATCH1, ~CPSR_N);
        e.emit(ppc_and(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH1));
        e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH0));
    }
    return 4;
}

// ---- Branch instructions ----

// Emit B (branch)
static int emitB(Emitter& e, uint32_t opcode, uint32_t pc, bool link, int cpuIdx) {
    int32_t offset = (int32_t)((opcode & 0x00FFFFFF) << 8) >> 6; // sign-extend 24-bit, *4
    uint32_t target = pc + 8 + (uint32_t)offset;

    if (link) {
        // LR = PC + 4 (next instruction)
        e.li32(armToPpcReg(14), pc + 4);
    }

    // Store new PC to regFile[15]
    JitRegFile* rf = &g_regFile[cpuIdx];
    e.li32(SCRATCH0, (uint32_t)rf);
    e.li32(SCRATCH1, target);
    e.emit(ppc_stw(SCRATCH1, SCRATCH0, 15 * 4));

    return 3;
}

// Emit BX (branch and exchange)
static int emitBx(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    int rm   = opcode & 0xF;
    int pRm  = armToPpcReg(rm);

    // New PC = Rm & ~1 (bit0 sets Thumb mode in CPSR)
    e.emit(ppc_rlwinm(SCRATCH0, pRm, 0, 0, 30)); // clear bit 0 (align)

    // Update T bit in CPSR based on bit0 of Rm
    e.emit(ppc_rlwinm(SCRATCH1, pRm, 0, 31, 31)); // bit0 of Rm
    // T bit is CPSR bit5
    e.li32(SCRATCH2, ~CPSR_T);
    e.emit(ppc_and(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH2));
    e.emit(ppc_rlwinm(SCRATCH1, SCRATCH1, 5, 27, 27)); // bit0 -> bit5
    e.emit(ppc_or(PPC_REG_CPSR, PPC_REG_CPSR, SCRATCH1));

    // Store new PC
    JitRegFile* rf = &g_regFile[cpuIdx];
    e.li32(SCRATCH2, (uint32_t)rf);
    e.emit(ppc_stw(SCRATCH0, SCRATCH2, 15 * 4));

    return 3;
}

// ---- Load/Store instructions ----
// For memory accesses, we call the Memory::read/write through stubs.
// Calling convention: r3=arm7, r4=address, r5=value(for writes)
// We must spill/reload ARM regs around calls since they may modify emulator state.

// Emit code to call memory read stub
// addr must be in SCRATCH1 before call
// result ends in SCRATCH0 (r3) after call
static void emitMemRead(Emitter& e, int cpuIdx, int size, bool sign, int destPpcReg, int addrReg) {
    // We need to call: core->memory.read<T>(arm7, address)
    // The stub handles MMU, TCM, etc.
    // We set up args and call via function pointer stored in g_memStubs

    JitMemStubs* stubs = &g_memStubs[cpuIdx];

    // Load appropriate stub function pointer
    void* fn;
    if (sign) {
        fn = (size == 1) ? (void*)stubs->read8s : (void*)stubs->read16s;
    } else {
        fn = (size == 1) ? (void*)stubs->read8 :
             (size == 2) ? (void*)stubs->read16 : (void*)stubs->read32;
    }

    // Move address into r3 (arg1)
    if (addrReg != 3) e.emit(ppc_mr(3, addrReg));

    // Save LR (we'll clobber it with bctrl)
    e.emit(ppc_mflr(0));
    e.emit(ppc_stw(0, 1, -4)); // store on stack (simple frame)

    e.callAbsolute(fn);

    // Restore LR
    e.emit(ppc_lwz(0, 1, -4));
    e.emit(ppc_mtlr(0));

    // Move result from r3 to destPpcReg
    if (destPpcReg != 3) e.emit(ppc_mr(destPpcReg, 3));
}

static void emitMemWrite(Emitter& e, int cpuIdx, int size, int valReg, int addrReg) {
    JitMemStubs* stubs = &g_memStubs[cpuIdx];

    void* fn = (size == 1) ? (void*)stubs->write8 :
               (size == 2) ? (void*)stubs->write16 : (void*)stubs->write32;

    // arg1 = address (r3), arg2 = value (r4)
    if (addrReg != 3) e.emit(ppc_mr(3, addrReg));
    if (valReg  != 4) e.emit(ppc_mr(4, valReg));

    e.emit(ppc_mflr(0));
    e.emit(ppc_stw(0, 1, -4));

    e.callAbsolute(fn);

    e.emit(ppc_lwz(0, 1, -4));
    e.emit(ppc_mtlr(0));
}

// Compute load/store address from opcode
// Returns address in SCRATCH3; modifies base if writeback
// isLoad: true for loads, false for stores
// Returns cycle count addition
static int emitAddressCalc(Emitter& e, uint32_t opcode, uint32_t pc, bool isHalfWord) {
    int rn  = (opcode >> 16) & 0xF;
    int pRn = getArmReg(e, rn, pc);

    bool P = (opcode >> 24) & 1; // pre/post index
    bool U = (opcode >> 23) & 1; // add/subtract offset
    bool W = (opcode >> 21) & 1; // writeback

    int offsetReg = SCRATCH2;
    bool isImm;

    if (isHalfWord) {
        // Halfword/signed load: immediate or register offset
        isImm = (opcode >> 22) & 1;
        if (isImm) {
            uint32_t off = ((opcode >> 8) & 0xF) << 4 | (opcode & 0xF);
            e.li32(offsetReg, off);
        } else {
            int rm = opcode & 0xF;
            e.emit(ppc_mr(offsetReg, armToPpcReg(rm)));
        }
    } else {
        // Normal load/store: register or immediate offset
        bool regOff = !((opcode >> 25) & 1); // bit25=1 means register, bit25=0 means immediate
        // Wait: for normal LDR/STR, bit25=0 means immediate, bit25=1 means register shifted
        isImm = !((opcode >> 25) & 1);
        if (isImm) {
            uint32_t off = opcode & 0xFFF;
            e.li32(offsetReg, off);
        } else {
            // Shifted register
            emitShiftedReg(e, opcode, offsetReg, false);
        }
    }

    // Pre-indexed: address = Rn +/- offset
    // Post-indexed: address = Rn, then Rn +/- offset
    if (P) {
        // Pre-index
        if (U) e.emit(ppc_add(SCRATCH3, pRn, offsetReg));
        else   e.emit(ppc_subf(SCRATCH3, offsetReg, pRn)); // Rn - offset
    } else {
        // Post-index: use Rn as address
        e.emit(ppc_mr(SCRATCH3, pRn));
    }

    // Writeback: update Rn
    bool doWriteback = (!P) || W; // post always writebacks, pre with W
    if (doWriteback && rn != 15) {
        if (!P) {
            // Post: Rn = Rn +/- offset
            if (U) e.emit(ppc_add(pRn, pRn, offsetReg));
            else   e.emit(ppc_subf(pRn, offsetReg, pRn));
        } else {
            // Pre with W: Rn = calculated address
            e.emit(ppc_mr(pRn, SCRATCH3));
        }
    }

    return 0;
}

// Emit LDR
static int emitLdr(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    int rd  = (opcode >> 12) & 0xF;
    int pRd = (rd == 15) ? SCRATCH4 : armToPpcReg(rd);

    emitAddressCalc(e, opcode, pc, false);

    // Spill regs around call since rd may alias SCRATCH regs
    emitMemRead(e, cpuIdx, 4, false, pRd, SCRATCH3);

    if (rd == 15) {
        // PC write: store to regFile
        JitRegFile* rf = &g_regFile[cpuIdx];
        e.li32(SCRATCH0, (uint32_t)rf);
        e.emit(ppc_stw(pRd, SCRATCH0, 15 * 4));
    }
    return 3;
}

