// ---- Block Data Transfer (LDM/STM) ----
// These are complex enough that we fall back to interpreter helpers.
// We emit a call to a C++ helper function.

// Helper called from JIT for LDM/STM
extern "C" int jit_ldm_stm(Interpreter* interp, uint32_t opcode, bool isLoad);

// Emit LDM/STM
static int emitLdmStm(Emitter& e, uint32_t opcode, uint32_t pc, bool isLoad, int cpuIdx) {
    // Spill all ARM registers to regFile
    emitSpillRegisters(e, cpuIdx, pc);

    // Call the interpreter's actual LDM/STM handler
    // We'll use a simplified approach: call back into interpreter
    JitContext* ctx = &g_jitCtx[cpuIdx];
    Interpreter* interp = ctx->interp;

    // r3 = interpreter pointer
    e.li32(3, (uint32_t)interp);
    // r4 = opcode
    e.li32(4, opcode);
    // r5 = isLoad
    e.emit(ppc_li(5, isLoad ? 1 : 0));

    e.emit(ppc_mflr(0));
    e.emit(ppc_stw(0, 1, -4));
    e.callAbsolute((void*)jit_ldm_stm);
    e.emit(ppc_lwz(0, 1, -4));
    e.emit(ppc_mtlr(0));

    // Reload registers
    emitReloadRegisters(e, cpuIdx);
    return 4;
}

// ---- SWI ----
// Software interrupt: fall back to interpreter
extern "C" void jit_swi(Interpreter* interp, uint32_t opcode);

static int emitSwi(Emitter& e, uint32_t opcode, uint32_t pc, int cpuIdx) {
    emitSpillRegisters(e, cpuIdx, pc);

    JitContext* ctx = &g_jitCtx[cpuIdx];
    e.li32(3, (uint32_t)ctx->interp);
    e.li32(4, opcode);

    e.emit(ppc_mflr(0));
    e.emit(ppc_stw(0, 1, -4));
    e.callAbsolute((void*)jit_swi);
    e.emit(ppc_lwz(0, 1, -4));
    e.emit(ppc_mtlr(0));

    emitReloadRegisters(e, cpuIdx);
    return 3;
}

