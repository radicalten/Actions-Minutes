// ---------------------------------------------------------------------------
// Wii/Gekko cache management intrinsics
// ---------------------------------------------------------------------------
static inline void ppc_dcbst(void* addr) {
    asm volatile("dcbst 0,%0" :: "r"(addr) : "memory");
}
static inline void ppc_icbi(void* addr) {
    asm volatile("icbi 0,%0" :: "r"(addr) : "memory");
}
static inline void ppc_sync() {
    asm volatile("sync" ::: "memory");
}
static inline void ppc_isync() {
    asm volatile("isync" ::: "memory");
}

// Flush and invalidate a range of cache lines (32-byte lines on Gekko)
static void flushCodeCache(void* start, size_t size) {
    uintptr_t addr = (uintptr_t)start & ~31u;
    uintptr_t end  = ((uintptr_t)start + size + 31) & ~31u;
    for (; addr < end; addr += 32) {
        ppc_dcbst((void*)addr);
    }
    ppc_sync();
    addr = (uintptr_t)start & ~31u;
    for (; addr < end; addr += 32) {
        ppc_icbi((void*)addr);
    }
    ppc_sync();
    ppc_isync();
}

