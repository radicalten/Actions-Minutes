// bc: BO, BI, BD
// BO: 0001y = decrement CTR, branch if CTR!=0 and ~cond
//     0100y = branch if cond true
//     0000y = decrement CTR, branch if CTR!=0
//     1010y = branch if cond false
// Common BO values:
//   12 = branch if CR bit set (0b01100)
//   4  = branch if CR bit clear (0b00100... actually 4 = 0b00100)
// Standard: BO=12 (branch if CR[BI]=1), BO=4 (branch if CR[BI]=0)
static inline uint32_t ppc_bc(int bo, int bi, int32_t bd, bool aa=false, bool lk=false) {
    return PO(16)|(bo<<21)|(bi<<16)|((bd&0xFFFC))|(aa?2:0)|(lk?1:0);
}
// Convenience: branch if CR0.EQ set/clear, etc.
// CR0 bits: 0=LT, 1=GT, 2=EQ, 3=SO  (bits 0..3 of CR, field 0)
static constexpr int CR0_LT = 0;
static constexpr int CR0_GT = 1;
static constexpr int CR0_EQ = 2;
static constexpr int CR0_SO = 3;
static constexpr int CR1_LT = 4;  // CR field 1
// CR0 for ARM N,Z,C,V in CR field 6 and 7 (avoid overwriting standard CRs)
static constexpr int ARM_CR_N  = 24; // CR6 bit 0
static constexpr int ARM_CR_Z  = 25; // CR6 bit 1
static constexpr int ARM_CR_C  = 26; // CR6 bit 2
static constexpr int ARM_CR_V  = 27; // CR6 bit 3

static inline uint32_t ppc_blt(int32_t bd) { return ppc_bc(12, CR0_LT, bd); }
static inline uint32_t ppc_bgt(int32_t bd) { return ppc_bc(12, CR0_GT, bd); }
static inline uint32_t ppc_beq(int32_t bd) { return ppc_bc(12, CR0_EQ, bd); }
static inline uint32_t ppc_bge(int32_t bd) { return ppc_bc(4,  CR0_LT, bd); }
static inline uint32_t ppc_ble(int32_t bd) { return ppc_bc(4,  CR0_GT, bd); }
static inline uint32_t ppc_bne(int32_t bd) { return ppc_bc(4,  CR0_EQ, bd); }

