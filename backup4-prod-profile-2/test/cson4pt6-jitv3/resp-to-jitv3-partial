// Encode a 16-bit signed immediate, clamped
static inline uint32_t simm16(int32_t v) { return (uint32_t)(v & 0xFFFF); }
static inline uint32_t uimm16(uint32_t v){ return v & 0xFFFF; }

// Primary opcode field [31:26]
static inline uint32_t PO(uint32_t op)  { return op << 26; }
// Register fields
static inline uint32_t FD(uint32_t r)   { return r << 21; }
static inline uint32_t FS(uint32_t r)   { return r << 21; }
static inline uint32_t FA(uint32_t r)   { return r << 16; }
static inline uint32_t FB(uint32_t r)   { return r << 11; }
static inline uint32_t FC(uint32_t r)   { return r << 6; }
static inline uint32_t XO(uint32_t xo)  { return xo << 1; }
static inline uint32_t RC(uint32_t rc)  { return rc & 1; }
static inline uint32_t OE(uint32_t oe)  { return oe << 10; }

