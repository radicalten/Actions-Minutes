// ---- Thumb DP (data processing) ----
static int emitThumbDp(Emitter& e, uint16_t opcode, uint32_t pc, int cpuIdx) {
    int op  = (opcode >> 6) & 0xF;
    int rm  = (opcode >> 3) & 0x7;
    int rd  =  opcode & 0x7;
    int pRm = armToPpcReg(rm);
    int pRd = armToPpcReg(rd);

    switch (op) {
        case 0:  // AND
            e.emit(ppc_and(pRd, pRd, pRm));
            emitUpdateNZ(e, pRd);
            return 1;
        case 1:  // EOR
            e.emit(ppc_xor(pRd, pRd, pRm));
            emitUpdateNZ(e, pRd);
            return 1;
        case 2: { // LSL
            e.emit(ppc_andi(SCRATCH2, pRm, 0xFF));
            e.emit(ppc_addi(SCRATCH3, SCRATCH2, -1));
            e.emit(ppc_srw(SCRATCH5, pRd, SCRATCH3));
            e.emit(ppc_andi(SCRATCH5, SCRATCH5, 1)); // carry = bit shifted out
            e.emit(ppc_slw(pRd, pRd, SCRATCH2));
            emitUpdateNZ(e, pRd);
            emitUpdateC(e);
            return 1;
        }
        case 3: { // LSR
            e.emit(ppc_andi(SCRATCH2, pRm, 0xFF));
            e.emit(ppc_addi(SCRATCH3, SCRATCH2, -1));
            e.emit(ppc_slw(SCRATCH5, pRd, SCRATCH3)); // shift left by (n-1)... wrong
            // carry = bit (n-1) from right = bit0 after right shift by (n-1)... 
            // carry = (pRd >> (n-1)) & 1 when n>=1
            e.emit(ppc_srw(SCRATCH5, pRd, SCRATCH3));
            e.emit(ppc_andi(SCRATCH5, SCRATCH5, 1));
            e.emit(ppc_srw(pRd, pRd, SCRATCH2));
            emitUpdateNZ(e, pRd);
            emitUpdateC(e);
            return 1;
        }
        case 4: { // ASR
            e.emit(ppc_andi(SCRATCH2, pRm, 0xFF));
            e.emit(ppc_addi(SCRATCH3, SCRATCH2, -1));
            e.emit(ppc_sraw(SCRATCH5, pRd, SCRATCH3));
            e.emit(ppc_andi(SCRATCH5, SCRATCH5, 1));
            e.emit(ppc_sraw(pRd, pRd, SCRATCH2));
            emitUpdateNZ(e, pRd);
            emitUpdateC(e);
            return 1;
        }
        case 5: { // ADC
            e.emit(ppc_rlwinm(SCRATCH2, PPC_REG_CPSR, 3, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH2, 0));
            uint32_t* p0 = e.buf; e.emit(ppc_beq(0));
            e.emit(ppc_subfc(SCRATCH0, SCRATCH0, SCRATCH0)); // CA=1
            uint32_t* p1 = e.buf; e.emit(ppc_b(0));
            patchBranch(e, p0);
            e.emit(ppc_li(SCRATCH0, 1)); e.emit(ppc_addic(SCRATCH0, SCRATCH0, -1));
            patchBranch(e, p1);
            e.emit(ppc_adde(pRd, pRd, pRm));
            emitUpdateNZ(e, pRd);
            e.emit(ppc_mfxer(SCRATCH0));
            e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
            emitUpdateC(e);
            return 1;
        }
        case 6: { // SBC
            e.emit(ppc_rlwinm(SCRATCH2, PPC_REG_CPSR, 3, 31, 31));
            e.emit(ppc_cmpi(0, SCRATCH2, 0));
            uint32_t* p0 = e.buf; e.emit(ppc_beq(0));
            e.emit(ppc_subfc(SCRATCH0, SCRATCH0, SCRATCH0));
            uint32_t* p1 = e.buf; e.emit(ppc_b(0));
            patchBranch(e, p0);
            e.emit(ppc_li(SCRATCH0, 1)); e.emit(ppc_addic(SCRATCH0, SCRATCH0, -1));
            patchBranch(e, p1);
            e.emit(ppc_subfe(pRd, pRm, pRd));
            emitUpdateNZ(e, pRd);
            e.emit(ppc_mfxer(SCRATCH0));
            e.emit(ppc_rlwinm(SCRATCH5, SCRATCH0, 3, 31, 31));
            emitUpdateC(e);
            return 1;
        }
        case 7: { // ROR
            e.emit(ppc_andi(SCRATCH2, pRm, 31));
            e.emit(ppc_subfic(SCRATCH3, SCRATCH2, 32));
            e.emit(ppc_srw(SCRATCH0, pRd, SCRATCH2));
            e.emit(ppc_slw(SCRATCH1, pRd, SCRATCH3));
            e.emit(ppc_or(pRd, SCRATCH0, SCRATCH1));
            e.emit(ppc_rlwinm(SCRATCH5, pRd, 1, 31, 31)); // carry = bit31 of result
            emitUpdateNZ(e, pRd);
            emitUpdateC(e);
            return 1;
        }
        case 8: { // TST
            e.emit(ppc_and(SCRATCH0, pRd, pRm));
            emitUpdateNZ(e, SCRATCH0);
            return 1;
        }
        case 9: { // NEG (RSB #0)
            e.emit(ppc_neg(pRd, pRm, false));
            emitUpdateNZ(e, pRd);
            // C flag for NEG: C = (Rm == 0) ? 1 : 0
            e.emit(ppc_cmpi(0, pRm, 0));
            e.emit(ppc_li(SCRATCH5, 0));
            uint32_t* pne = e.buf; e.emit(ppc_bne(0));
            e.emit(ppc_li(SCRATCH5, 1));
            patchBranch(e, pne);
            emitUpdateC(e);
            return 1;
        }
        case 10: { // CMP
            e.emit(ppc_subfc(SCRATCH0, pRm, pRd));
            emitUpdateNZ(e, SCRATCH0);
            e.emit(ppc_mfxer(SCRATCH2));
            e.emit(ppc_rlwinm(SCRATCH5, SCRATCH2, 3, 31, 31));
            emitUpdateC(e);
            e.emit(ppc_subfo(SCRATCH3, pRm, pRd, false));
            e.emit(ppc_mfxer(SCRATCH2));
            e.emit(ppc_rlwinm(SCRATCH4, SCRATCH2, 2, 31, 31));
            emitUpdateV(e, SCRATCH4);
            return 1;
        }
        case 11: { // CMN
            e.emit(ppc_addc(SCRATCH0, pRd, pRm));
            emitUpdateNZ(e, SCRATCH0);
            e.emit(ppc_mfxer(SCRATCH2));
            e.emit(ppc_rlwinm(SCRATCH5, SCRATCH2, 3, 31, 31));
            emitUpdateC(e);
            e.emit(ppc_addo(SCRATCH3, pRd, pRm, false));
            e.emit(ppc_mfxer(SCRATCH2));
            e.emit(ppc_rlwinm(SCRATCH4, SCRATCH2, 2, 31, 31));
            emitUpdateV(e, SCRATCH4);
            return 1;
        }
        case 12: { // ORR
            e.emit(ppc_or(pRd, pRd, pRm));
            emitUpdateNZ(e, pRd);
            return 1;
        }
        case 13: { // MUL
            e.emit(ppc_mullw(pRd, pRd, pRm));
            emitUpdateNZ(e, pRd);
            return 2;
        }
        case 14: { // BIC
            e.emit(ppc_andc(pRd, pRd, pRm));
            emitUpdateNZ(e, pRd);
            return 1;
        }
        case 15: { // MVN
            e.emit(ppc_nor(pRd, pRm, pRm));
            emitUpdateNZ(e, pRd);
            return 1;
        }
    }
    return 1;
}

// ---- Thumb PUSH/POP ----
extern "C" void jit_thumb_push(Interpreter* interp, uint16_t opcode);
extern "C" void jit_thumb_pop (Interpreter* interp, uint16_t opcode);

static int emitThumbPush(Emitter& e, uint16_t opcode, uint32_t pc, int cpuIdx) {
    emitSpillRegisters(e, cpuIdx, pc);
    JitContext* ctx = &g_jitCtx[cpuIdx];
    e.li32(3, (uint32_t)ctx->interp);
    e.emit(ppc_li(4, (int32_t)(uint32_t)opcode));
    e.emit(ppc_mflr(0)); e.emit(ppc_stw(0, 1, -4));
    e.callAbsolute((void*)jit_thumb_push);
    e.emit(ppc_lwz(0, 1, -4)); e.emit(ppc_mtlr(0));
    emitReloadRegisters(e, cpuIdx);
    return 4;
}

