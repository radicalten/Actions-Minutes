// ========================= prologue / epilogue =========================
static void emitPrologue(Ctx& ctx) {
    ctx.E(ppc_mflr(0));
    ctx.E(ppc_stwu(1, -(int16_t)FRAME_SIZE, 1));
    ctx.E(ppc_stw(0, (int16_t)FRAME_LR_OFF, 1));
    for (int r = 14; r <= 31; r++)
        ctx.E(ppc_stw(r, FRAME_SAVE + (r-14)*4, 1));

    ctx.li(TA, (uint32_t)(uintptr_t)ctx.core);
    ctx.E(ppc_stw(TA, FRAME_CORE, 1));
    ctx.li(TA, (uint32_t)(uintptr_t)ctx.interp);
    ctx.E(ppc_stw(TA, FRAME_INTERP, 1));
    ctx.E(ppc_addi(TA, 0, (int16_t)ctx.cpuIdx));
    ctx.E(ppc_stw(TA, FRAME_CPUIDX, 1));
}

static void emitEpilogue(Ctx& ctx) {
    for (int r = 14; r <= 31; r++)
        ctx.E(ppc_lwz(r, FRAME_SAVE + (r-14)*4, 1));
    ctx.E(ppc_lwz(0, (int16_t)FRAME_LR_OFF, 1));
    ctx.E(ppc_mtlr(0));
    ctx.E(ppc_addi(1, 1, (int16_t)FRAME_SIZE));
    ctx.E(ppc_blr());
}

// ── FIX 4: emitSyncFrom — on failure path we must set EXIT_FALLBACK
//           before returning, otherwise the runner sees a stale EXIT_NORMAL.
static void emitSyncFrom(Ctx& ctx) {
    ctx.ldInterp();
    ctx.E(ppc_addi(TB, 1, (int16_t)FRAME_REGSYNC));
    ctx.E(ppc_addi(TC, 1, (int16_t)FRAME_CPSR));
    ctx.call((void*)JitHelp_syncFrom);

    // r3 == 0 → success; branch to body
    ctx.E(ppc_cmpi(0, TA, 0));
    size_t bOk = ctx.sz();
    ctx.E(ppc_bc(12, 2, 0));   // beq body

    // failure path — set g_exitReason[cpu] = EXIT_FALLBACK then return
    // We do this inline: store 1 into g_exitReason[cpuIdx]
    ctx.li(TA, (uint32_t)(uintptr_t)g_exitReason);
    ctx.E(ppc_lwz(TB, FRAME_CPUIDX, 1));    // TB = cpuIdx (0 or 1)
    ctx.E(ppc_rlwinm(TB, TB, 2, 0, 29));    // TB <<= 2 (word offset)
    ctx.E(ppc_add(TA, TA, TB));             // TA = &g_exitReason[cpuIdx]
    ctx.E(ppc_addi(TB, 0, EXIT_FALLBACK));
    ctx.E(ppc_stw(TB, 0, TA));
    emitEpilogue(ctx);

    // body
    int32_t d = (int32_t)((ctx.sz() - bOk) * 4);
    ctx.base[bOk] = ppc_bc(12, 2, (int16_t)d);

    // load guest regs into PPC registers
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_lwz(RA[i], FRAME_REGSYNC + i*4, 1));
    ctx.E(ppc_lwz(RCPSR, FRAME_CPSR, 1));
}

static void emitSpill(Ctx& ctx) {
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_stw(RA[i], FRAME_REGSYNC + i*4, 1));
    ctx.E(ppc_stw(RCPSR, FRAME_CPSR, 1));
}

static void emitReload(Ctx& ctx) {
    for (int i = 0; i < 15; i++)
        ctx.E(ppc_lwz(RA[i], FRAME_REGSYNC + i*4, 1));
    ctx.E(ppc_lwz(RCPSR, FRAME_CPSR, 1));
}

static void emitCommitExit(Ctx& ctx, uint32_t nextPC, int reason) {
    emitSpill(ctx);
    ctx.ldInterp();                                   // r3
    ctx.ldCpu();                                      // r4
    ctx.E(ppc_addi(TC, 1, (int16_t)FRAME_REGSYNC));  // r5
    ctx.E(ppc_mr(TD, RCPSR));                         // r6
    ctx.li(TE, nextPC);                               // r7
    ctx.E(ppc_addi(TF, 0, (int16_t)reason));          // r8
    ctx.call((void*)JitHelp_commit);
    emitEpilogue(ctx);
}

static void emitCommitExitDyn(Ctx& ctx, int reason) {
    emitSpill(ctx);
    ctx.ldInterp();
    ctx.ldCpu();
    ctx.E(ppc_addi(TC, 1, (int16_t)FRAME_REGSYNC));
    ctx.E(ppc_mr(TD, RCPSR));
    ctx.E(ppc_lwz(TE, FRAME_PC, 1));
    ctx.E(ppc_addi(TF, 0, (int16_t)reason));
    ctx.call((void*)JitHelp_commit);
    emitEpilogue(ctx);
}

// ========================= condition skip =========================
// ── FIX 5: emitCondSkip — always-true (cond 14) must return SIZE_MAX
//           so callers skip the conditional branch entirely.
//           Returns SIZE_MAX for unconditional; otherwise index of the
//           branch instruction to back-patch with patchSkip().
static size_t emitCondSkip(Ctx& ctx, uint8_t cond) {
    if (cond == 14) return SIZE_MAX;    // always — no branch needed
    if (cond == 15) return SIZE_MAX;    // arch-undefined — treat as always

    ctx.E(ppc_mr(TA, RCPSR));
    ctx.E(ppc_addi(TB, 0, (int16_t)cond));
    ctx.call((void*)JitHelp_testCond);
    // TA = 1 if condition true.  Skip body when cond is FALSE (TA==0).
    ctx.E(ppc_cmpi(0, TA, 0));
    size_t idx = ctx.sz();
    ctx.E(ppc_bc(12, 2, 0));   // placeholder: beq skip_body
    return idx;
}

static void patchSkip(Ctx& ctx, size_t idx) {
    if (idx == SIZE_MAX) return;
    int32_t off = (int32_t)((ctx.sz() - idx) * 4);
    if (off < -32768 || off > 32764) { ctx.overflow = true; return; }
    ctx.base[idx] = ppc_bc(12, 2, (int16_t)off);
}

// ========================= flags =========================
static void setNZ(Ctx& ctx, uint8_t r) {
    // Clear N+Z in CPSR (bits 31,30), then set from result
    ctx.E(ppc_rlwinm(RCPSR, RCPSR, 0, 2, 31));   // clear bits 31,30
    // N = result[31]
    ctx.E(ppc_rlwimi(RCPSR, r, 0, 0, 0));         // CPSR[31] = r[31]
    // Z = (r == 0)
    ctx.E(ppc_cmpi(6, r, 0));                      // CR6: EQ if r==0
    ctx.E(ppc_mfcr(TA));
    // CR6 EQ is bit 25 of CR word; rotate to bit 30
    ctx.E(ppc_rlwinm(TA, TA, 25, 1, 1));           // TA[30] = CR6.EQ
    ctx.E(ppc_or(RCPSR, RCPSR, TA));
}

