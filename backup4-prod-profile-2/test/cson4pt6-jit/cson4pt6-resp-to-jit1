int jit_run(ArmCpuState* cpu, int cycles) {
    if (!g_jit) jit_init();

    int remaining = cycles;

    while (remaining > 0 && !cpu->halted) {
        uint32_t pc = cpu->regs[ARM_PC];

        // Don't JIT THUMB mode - fall back (not implemented here)
        if (cpu->cpsr & CPSR_T) {
