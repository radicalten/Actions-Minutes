        JitBlock* block = g_jit->getOrTranslate(cpu, pc);
        if (!block) {
            // Translation failed; shouldn't happen
            remaining -= 1;
            continue;
        }

        uint32_t consumed = JitTranslator::executeBlock(cpu, block);
        remaining -= (int)consumed;
    }

    return cycles - remaining;
}

