            ctx.E(ppc_creqv(0, 31, 28));  // CR0[LT] = N EQV V
            bo = 12; bi = 0;
            break;
        case 11: // LT: N != V
            ctx.E(ppc_crxor(0, 31, 28));  // CR0[LT] = N XOR V
            bo = 12; bi = 0;
            break;
        case 12: // GT: Z=0 && N==V
            ctx.E(ppc_creqv(0, 31, 28));  // CR0[LT] = N EQV V
            ctx.E(ppc_crandc(0, 0, 30));  // CR0[LT] = (N EQV V) AND NOT Z
            bo = 12; bi = 0;
