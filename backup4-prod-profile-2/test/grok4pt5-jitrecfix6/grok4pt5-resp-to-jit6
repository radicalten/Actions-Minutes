        case 13: // LE: Z=1 || N!=V  ==  !(Z=0 && N==V)
            ctx.E(ppc_creqv(0, 31, 28));
            ctx.E(ppc_crandc(0, 0, 30));
            bo =  4; bi = 0;
            break;

        default:
            return SIZE_MAX;
