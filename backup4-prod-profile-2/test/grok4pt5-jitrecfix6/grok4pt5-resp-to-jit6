### A. CR logical ops + correct condition emit

Replace `condPpc` / `emitLoadCR7` / `emitCondSkip` and add encoders:

```cpp
// XL-form CR ops
static inline uint32_t ppc_crandc(uint8_t bt, uint8_t ba, uint8_t bb) {
    return (19u<<26)|((uint32_t)bt<<21)|((uint32_t)ba<<16)|
           ((uint32_t)bb<<11)|(129u<<1);
}
static inline uint32_t ppc_creqv(uint8_t bt, uint8_t ba, uint8_t bb) {
    return (19u<<26)|((uint32_t)bt<<21)|((uint32_t)ba<<16)|
           ((uint32_t)bb<<11)|(289u<<1);
}
static inline uint32_t ppc_crxor(uint8_t bt, uint8_t ba, uint8_t bb) {
    return (19u<<26)|((uint32_t)bt<<21)|((uint32_t)ba<<16)|
           ((uint32_t)bb<<11)|(193u<<1);
}

// mtcrf 0x01: CR7[LT]=V(28), CR7[GT]=C(29), CR7[EQ]=Z(30), CR7[SO]=N(31)
static void emitLoadCR7(Ctx& ctx){ ctx.E(ppc_mtcrf(0x01, RCPSR)); }

// Returns index of placeholder b to patch, or SIZE_MAX if always/never handled.
// Layout:  bc(+8) ; b after_body ; body... ; after_body:
//   cond true  -> skip b, run body
//   cond false -> take b, skip body
static size_t emitCondSkip(Ctx& ctx, uint8_t cond) {
    if (cond == 14) return SIZE_MAX;       // AL
    if (cond == 15) return SIZE_MAX;       // NV — let caller fall back

    emitLoadCR7(ctx);

    uint8_t bo, bi;
    switch (cond) {
        case  0: bo=12; bi=30; break;                 // EQ: Z
        case  1: bo= 4; bi=30; break;                 // NE
        case  2: bo=12; bi=29; break;                 // CS/HS: C
        case  3: bo= 4; bi=29; break;                 // CC/LO
        case  4: bo=12; bi=31; break;                 // MI: N
        case  5: bo= 4; bi=31; break;                 // PL
        case  6: bo=12; bi=28; break;                 // VS: V
        case  7: bo= 4; bi=28; break;                 // VC
        case  8: // HI: C && !Z
            ctx.E(ppc_crandc(0, 29, 30));
            bo=12; bi=0; break;
        case  9: // LS: !(C && !Z)
            ctx.E(ppc_crandc(0, 29, 30));
            bo= 4; bi=0; break;
        case 10: // GE: N == V
            ctx.E(ppc_creqv(0, 31, 28));
            bo=12; bi=0; break;
        case 11: // LT: N != V
            ctx.E(ppc_crxor(0, 31, 28));
            bo=12; bi=0; break;
        case 12: // GT: !Z && N==V
            ctx.E(ppc_creqv(0, 31, 28));
            ctx.E(ppc_crandc(0, 0, 30));
            bo=12; bi=0; break;
        case 13: // LE: Z || N!=V
            ctx.E(ppc_creqv(0, 31, 28));
            ctx.E(ppc_crandc(0, 0, 30));
            bo= 4; bi=0; break;
        default:
            return SIZE_MAX;
    }

    // if cond TRUE, skip the following b (offset +8) and run body
    ctx.E(ppc_bc(bo, bi, 8));
    size_t idx = ctx.sz();
    ctx.E(ppc_b(0)); // patched to after body
    return idx;
}
```

