if (!inMem1) {
    // try cached alias only for MEM1 physical/uncached forms
    if (addr < 0x01800000u) {
        addr |= 0x80000000u;
        inMem1 = (addr + JIT_BYTES <= 0x81800000u);
    } else if (addr >= 0xC0000000u && addr < 0xC1800000u) {
        addr -= 0x40000000u;
        inMem1 = true;
    }
