### B. Fix thumb conditional branches to use the same helper

```cpp
static bool emitT_branch(Ctx& ctx, uint16_t op, uint32_t curPC) {
    uint8_t h = (op >> 12) & 0xF;

    if (h == 0xE) {
        // Unconditional B
        int32_t off = (int32_t)((int16_t)(op << 5)) >> 4;
        emitExit(ctx, (uint32_t)(curPC + 4 + off), EXIT_NORMAL);
        ctx.done = true;
        return true;
    }

    if (h == 0xD) {
        uint8_t cond = (op >> 8) & 0xF;
        if (cond >= 0xE) return false; // SWI / reserved

        int32_t off = (int32_t)(int8_t)(op & 0xFF);
        off <<= 1;
        uint32_t tgt  = curPC + 4 + off;
        uint32_t fall = curPC + 2;

        size_t si = emitCondSkip(ctx, cond);
        if (si == SIZE_MAX) return false;

        emitExit(ctx, tgt, EXIT_NORMAL);   // taken
        patchSkip(ctx, si);
        emitExit(ctx, fall, EXIT_NORMAL);  // not taken
        ctx.done = true;
        return true;
    }
    return false;
}
```

