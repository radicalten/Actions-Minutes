// ── C helpers ─────────────────────────────────────────────────────────
extern "C" {

int JitHelp_testCond(uint32_t cpsr,uint32_t cond){
    const uint32_t N=(cpsr>>31)&1u,Z=(cpsr>>30)&1u,
                   C=(cpsr>>29)&1u,V=(cpsr>>28)&1u;
    switch(cond&15u){
        case  0:return(int)Z;
        case  1:return(int)(Z^1u);
        case  2:return(int)C;
        case  3:return(int)(C^1u);
        case  4:return(int)N;
        case  5:return(int)(N^1u);
        case  6:return(int)V;
        case  7:return(int)(V^1u);
        case  8:return(int)(C&(Z^1u));
        case  9:return(int)((C^1u)|Z);
        case 10:return N==V;
        case 11:return N!=V;
        case 12:return(Z==0u&&N==V);
        case 13:return(Z==1u||N!=V);
        case 14:return 1;
        default:return 0;
    }
}

int JitHelp_syncFrom(Interpreter* interp,uint32_t* regs,uint32_t* outCPSR){
    if(!interp||!regs||!outCPSR)return -1;
    if(!interp->isReady())return -1;
    uint32_t** p=interp->getRegisters();
    if(!p)return -1;
    for(int i=0;i<15;i++){
        if(!p[i])return -1;
        regs[i]=*p[i];
    }
    *outCPSR=interp->getCpsrRef();
    return 0;
}

// FIX: Must update CPSR mode in Interpreter before writing registers to prevent banked register corruption
int JitHelp_commit(Interpreter* interp,int cpu,
                   uint32_t* regs,uint32_t cpsr,
                   uint32_t pc,int reason){
    if(!interp||!regs||cpu<0||cpu>1)return -1;
    
    // First update CPSR mode so register pointers adapt to new CPU mode
    interp->writeCpsr(cpsr);
    
    uint32_t** p=interp->getRegisters();
    if(!p)return -1;
    for(int i=0;i<15;i++){
        if(!p[i])return -1;
        *p[i]=regs[i];
    }
    
    g_exitPC[cpu]    =pc;
    g_exitCPSR[cpu]  =cpsr;
    g_exitReason[cpu]=reason;
    interp->setPC(pc);
    return 0;
}

} // extern "C"

// ── Thumb BL / BLX fix in compile() and emitT_bl() ────────────────────
static bool emitT_bl(Ctx& ctx,uint16_t op1,uint16_t op2,uint32_t curPC){
    int32_t hi=(int32_t)((op1&0x7FF)<<21)>>9,lo=(op2&0x7FF)<<1;
    uint32_t tgt=(uint32_t)(curPC+4+hi+lo);
    
    // FIX: 0x1D is Thumb BLX suffix (11101), 0x1C was B offset (11100)!
    bool blx=((op2>>11)&0x1F)==0x1D;
    
    ctx.li(RA[14],(curPC+4)|1u);
    if(blx){
        tgt&=~3u;
        ctx.li(TA,~(1u<<5));
        ctx.E(ppc_and(RCPSR,RCPSR,TA)); // Switch to ARM mode (clear T bit)
    }
    emitCommitExit(ctx,tgt&~1u,EXIT_NORMAL);
    ctx.done=true;
    return true;
}

// FIX: emitT_hiReg for Thumb BLX Rm
static bool emitT_hiReg(Ctx& ctx,uint16_t op,uint32_t curPC){
    uint8_t o=(op>>8)&3,rs=((op>>3)&7)|(((op>>6)&1)<<3),rd=(op&7)|(((op>>7)&1)<<3);
    
    if(o==3){ // BX / BLX
        bool isBlx = ((op >> 7) & 1) != 0; // Check H1 bit for BLX Rm
        if(isBlx) {
            ctx.li(RA[14], (curPC + 2) | 1u); // Set LR to return address in Thumb mode
        }
        if(rs==15)ctx.li(TA,(curPC+4)&~1u);else ctx.E(ppc_mr(TA,RA[rs]));
        ctx.E(ppc_stw(TA,FRAME_SCR0,1));
        emitBX_target(ctx);
        ctx.done=true;
        return true;
    }
    // ... rest of hiReg
    return true;
}

// ── Fixed NDS Runner with Dual-Core Interleaving ─────────────────────
void runJitNds(Core& core){
    if(!g_jitLive||!codeBuf){Interpreter::runCoreNds(core);return;}

    uint32_t acc0 = 0;
    uint32_t acc1 = 0;

    for(int i = 0; i < ITERS_NDS; i++){
        uint32_t c0 = runCpu(core, 0, false); // ARM9 (67.03 MHz)
        uint32_t c1 = runCpu(core, 1, false); // ARM7 (33.51 MHz)

        acc0 += c0;
        acc1 += c1 * 2; // Convert ARM7 cycles to ARM9 clock scale

        // Interleaved scheduler tick so IPC interrupts fire on time
        if((i & 3) == 3){
            uint32_t slice = (acc0 > acc1) ? acc0 : acc1;
            if(slice > 0){
                tickInline(core, slice);
                acc0 = 0;
                acc1 = 0;
            }
        }
    }

    uint32_t rem = (acc0 > acc1) ? acc0 : acc1;
    uint32_t charge = (rem > 64) ? rem : 64;
    tickInline(core, charge);
    logStatus(core);
}
