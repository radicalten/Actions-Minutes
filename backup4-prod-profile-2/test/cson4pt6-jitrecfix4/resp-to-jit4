    ctx.E(ppc_rlwinm(TC, TA, 0, 31, 31));  // TC = Rm[0] (bit 0)
    ctx.E(ppc_rlwinm(TC, TC, 5, 26, 26)); // TC = Rm[0] << 5 (-> bit 5 position)
    
