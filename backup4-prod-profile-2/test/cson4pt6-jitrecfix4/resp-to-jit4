// jit_ppc.cpp - Fix runJitNds and runJitGba
void runJitNds(Core& core) {
    for (int cpu = 0; cpu < 2; cpu++) {
        Interpreter& interp = core.interpreter[cpu];
        if (interp.halted) continue;

        uint32_t pc = interp.getActualPC();
        
        // Don't compile if PC is clearly invalid
        if (pc == 0 || pc == 0xFFFFFFFF) {
            interp.jitRunOpcode();
            continue;
        }

        JitBlock* b = compile(&interp, &core, pc, cpu == 1, cpu);
        if (b && b->nW > 0) {
            executeBlock_asm(b->code);
            
            uint32_t exitPC = g_exitPC[cpu];
            int reason = g_exitReason[cpu];
            
            // Validate exit PC before applying
            if (exitPC != 0 && exitPC != 0xFFFFFFFF) {
                interp.setPC(exitPC);
                if (reason == EXIT_FALLBACK) {
                    interp.jitRunOpcode();
                }
            } else {
                // Bad exit PC — fall back to interpreter
                interp.jitRunOpcode();
            }
        } else {
            interp.jitRunOpcode();
        }
    }
    JitHelp_tick(&core);
}

void runJitGba(Core& core) {
    Interpreter& interp = core.interpreter[1];
    if (!interp.halted) {
        uint32_t pc = interp.getActualPC();
        
        if (pc == 0 || pc == 0xFFFFFFFF) {
            interp.jitRunOpcode();
        } else {
            JitBlock* b = compile(&interp, &core, pc, true, 1);
            if (b && b->nW > 0) {
                executeBlock_asm(b->code);
                
                uint32_t exitPC = g_exitPC[1];
                int reason = g_exitReason[1];
                
                if (exitPC != 0 && exitPC != 0xFFFFFFFF) {
                    interp.setPC(exitPC);
                    if (reason == EXIT_FALLBACK) {
                        interp.jitRunOpcode();
                    }
                } else {
                    interp.jitRunOpcode();
                }
            } else {
                interp.jitRunOpcode();
            }
        }
    }
    JitHelp_tick(&core);
}
