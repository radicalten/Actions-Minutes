The NDS crash shows `PC = 0xFFFFDB74` with `LR = 0x8034FA78` - the inline asm in `executeBlock` is broken because devkitPPC's GCC doesn't support the `asm` block properly in this context, and the JIT block is jumping to address 0xFFFFDB74 (garbage). The GBA ISI is still `PC = LR = 0x000E2B04` meaning the same LR corruption.

The real fix is to write `executeBlock` as a **separate `.S` assembly file** so the compiler cannot touch it at all, and to fix the block's prologue to not rely on LR being set by `bctrl` - instead pass the return address explicitly.

Let me redesign the calling convention completely:

**New convention**: The caller (`executeBlock`) passes a return-address pointer in a callee-saved register slot in the JIT frame. The block stores and restores its own LR from `FRAME_LR`. The trampoline is written purely in `.S` assembly.

```asm
# jit_trampoline.S
# executeBlock(uint32_t* blockCode)
# r3 = blockCode on entry

    .section .text
    .global executeBlock_asm
    .type   executeBlock_asm, @function
    .align  5

executeBlock_asm:
    # Standard ABI prologue
    mflr    %r0
    stwu    %r1, -32(%r1)       # allocate 32-byte frame
    stw     %r0,  36(%r1)       # save LR at old_r1+4 (ABI: [r1+framesize+4])
    stw     %r31, 28(%r1)       # save r31 (we'll use it as scratch)

    # Load block address and call it
    mtctr   %r3                 # CTR = blockCode
    bctrl                       # call block; LR = next instruction below

    # Block returned via blr to here:
    lwz     %r31, 28(%r1)       # restore r31
    lwz     %r0,  36(%r1)       # restore saved LR
    addi    %r1,  %r1, 32       # deallocate frame
    mtlr    %r0
    blr                         # return to C++ caller

    .size executeBlock_asm, .-executeBlock_asm
```

But wait - the JIT block's prologue still does `mflr` to capture the return address. After `bctrl` in the trampoline, LR = address of the `lwz r31, 28(r1)` instruction above. The block's prologue does:

```
mflr r0        ; r0 = addr of "lwz r31,28(r1)" in trampoline -- VALID PPC addr
stwu r1,-192(r1)
stw  r0, 8(r1) ; saved
```

Epilogue:
```
lwz r0, 8(r1)  ; r0 = addr of "lwz r31,28(r1)"
mtlr r0
addi r1,r1,192
blr            ; jump to trampoline's restore code -- CORRECT
```

This will work correctly. Now let me write the complete fixed implementation:

**`jit_trampoline.S`:**
```asm
/*
 * jit_trampoline.S - JIT block execution trampoline for PowerPC (Wii/Broadway)
 *
 * void executeBlock_asm(uint32_t* blockCode);
 *
 * Calls blockCode as a PPC function using bctrl so that:
 *   - LR is set to a valid PPC return address before the block executes
 *   - The block's mflr captures that address correctly
 *   - The block's blr returns here
 */

    .section .text
    .global executeBlock_asm
    .type   executeBlock_asm, @function
    .balign 32

executeBlock_asm:
    # Save our return address and allocate minimal frame
    mflr    %r0
    stwu    %r1, -32(%r1)       /* 32-byte frame: 16 min + 16 for saves */
    stw     %r0,  36(%r1)       /* LR at old_r1 + 4 (ABI LR save area)  */
    stw     %r31, 28(%r1)       /* save r31 (scratch)                    */
    stw     %r30, 24(%r1)       /* save r30 (scratch)                    */

    /* r3 = blockCode, load into CTR and call */
    mtctr   %r3
    bctrl                       /* LR = address of next instruction      */

    /* Block's blr returns here */
    lwz     %r30, 24(%r1)
    lwz     %r31, 28(%r1)
    lwz     %r0,  36(%r1)
    addi    %r1,  %r1, 32
    mtlr    %r0
    blr

    .size executeBlock_asm, .-executeBlock_asm
```

