```cpp
static bool emitT_branch(Ctx& ctx, uint16_t op, uint32_t curPC){
    uint8_t h = (op >> 12) & 0xF;

    if(h == 0xE){
        int32_t off = (int32_t)((int16_t)(op << 5)) >> 4;
        emitExit(ctx, (uint32_t)(curPC + 4 + off), EXIT_NORMAL);
        ctx.done = true;
        return true;
    }

    if(h == 0xD){
        uint8_t cond = (op >> 8) & 0xF;
        if(cond == 0xF) return false;

        int32_t off = (int32_t)(int8_t)(op & 0xFF);
        off <<= 1;
        uint32_t tgt  = curPC + 4 + off;
        uint32_t fall = curPC + 2;

        // Thumb Bcc has an 8-bit offset = max ±256 bytes.
        // The emitted exits are multiple instructions each.
        // Use safe long-branch pattern via emitCondSkip.
        emitLoadCR7(ctx);
        CB cb = condPpc(cond);
        if(!cb.ok) return false;

        // Emit: bc inv, bi, +8  (skip b if condition TRUE -> take branch)
        //        b  fall_exit    (condition FALSE -> fall through)
        uint8_t inv = (cb.bo == 12) ? 4u : 12u;
        ctx.E(ppc_bc(inv, cb.bi, 8));
        size_t bIdx = ctx.sz();
        ctx.E(ppc_b(0));  // placeholder for fall-through

        emitExit(ctx, tgt, EXIT_NORMAL);   // taken branch (condition TRUE)

        // Patch the `b` to jump to here (fall-through exit)
        {
            int32_t d = (int32_t)((ctx.sz() - bIdx) * 4);
            ctx.base[bIdx] = ppc_b(d);
        }

        emitExit(ctx, fall, EXIT_NORMAL);  // not-taken branch

        ctx.done = true;
        return true;
    }

    return false;
}
```

