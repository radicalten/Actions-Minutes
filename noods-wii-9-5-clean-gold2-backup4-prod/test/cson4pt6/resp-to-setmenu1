                if (g_cursorX < 0.0f)   g_cursorX = 0.0f;
                if (g_cursorX > 640.0f) g_cursorX = 640.0f;
                if (g_cursorY < 0.0f)   g_cursorY = 0.0f;
                if (g_cursorY > 480.0f) g_cursorY = 480.0f;
